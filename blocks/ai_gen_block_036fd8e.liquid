{% doc %}
  @prompt
    Create a brand logo image space , one stacked on top of the other please, only two logos, make the top image much much smaller and can it have a link embedded to www.ateliermodernista.com. Can you make both logos width being controlled. Can you add 'Art You Can Wear' in mixed lower and uppercase underneath the second image, please?, add a link to the top logo please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-stack-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px;
  }

  .ai-logo-stack__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    width: 100%;
  }

  .ai-logo-stack__top-link-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.top_logo_width }}%;
    max-width: 100%;
  }

  .ai-logo-stack__top-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-stack__top-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-stack__top-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-logo-stack__bottom-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.text_spacing }}px;
    width: {{ block.settings.bottom_logo_width }}%;
    max-width: 100%;
  }

  .ai-logo-stack__bottom-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-stack__bottom-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-stack__bottom-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-logo-stack__tagline-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: center;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-stack__top-link-{{ ai_gen_id }} {
      width: {{ block.settings.top_logo_width | times: 0.8 }}%;
    }

    .ai-logo-stack__bottom-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.bottom_logo_width | times: 0.8 }}%;
    }
  }
{% endstyle %}

<div class="ai-logo-stack-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-stack__container-{{ ai_gen_id }}">
    {% if block.settings.top_logo_link != blank %}
      <a href="{{ block.settings.top_logo_link }}" class="ai-logo-stack__top-link-{{ ai_gen_id }}">
        {% if block.settings.top_logo %}
          <img
            src="{{ block.settings.top_logo | image_url: width: 800 }}"
            alt="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}"
            loading="eager"
            width="{{ block.settings.top_logo.width }}"
            height="{{ block.settings.top_logo.height }}"
            class="ai-logo-stack__top-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-logo-stack__top-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </a>
    {% else %}
      <div class="ai-logo-stack__top-link-{{ ai_gen_id }}">
        {% if block.settings.top_logo %}
          <img
            src="{{ block.settings.top_logo | image_url: width: 800 }}"
            alt="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}"
            loading="eager"
            width="{{ block.settings.top_logo.width }}"
            height="{{ block.settings.top_logo.height }}"
            class="ai-logo-stack__top-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-logo-stack__top-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-logo-stack__bottom-wrapper-{{ ai_gen_id }}">
      {% if block.settings.bottom_logo %}
        <img
          src="{{ block.settings.bottom_logo | image_url: width: 1200 }}"
          alt="{{ block.settings.bottom_logo.alt | default: 'Atelier Modernista — Art You Can Wear' | escape }}"
          loading="eager"
          width="{{ block.settings.bottom_logo.width }}"
          height="{{ block.settings.bottom_logo.height }}"
          class="ai-logo-stack__bottom-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-logo-stack__bottom-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <p class="ai-logo-stack__tagline-{{ ai_gen_id }}">Art You Can Wear</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Stacked brand logos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Top logo"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Top logo image"
    },
    {
      "type": "url",
      "id": "top_logo_link",
      "label": "Top logo link"
    },
    {
      "type": "range",
      "id": "top_logo_width",
      "label": "Top logo width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Bottom logo"
    },
    {
      "type": "image_picker",
      "id": "bottom_logo",
      "label": "Bottom logo image"
    },
    {
      "type": "range",
      "id": "bottom_logo_width",
      "label": "Bottom logo width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "logo_spacing",
      "label": "Space between logos",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Space between logo and text",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Stacked brand logos"
    }
  ]
}
{% endschema %}
