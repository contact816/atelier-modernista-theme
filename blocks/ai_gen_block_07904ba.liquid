{% doc %}
  @prompt
    Create a brand logo image space , one stacked on top of the other please, only two logos, make the top image much much smaller and can it have a link embedded to www.ateliermodernista.com. Can you make both logos width being controlled. Can you add 'Art You Can Wear' in mixed lower and uppercase underneath the second image, please?, add a link to each  logo and the text please. and make it be Cormorant font., please centre everything.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-logos-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
    padding: 20px;
  }

  .ai-brand-logos-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-brand-logo-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .ai-brand-logo-link-{{ ai_gen_id }} {
    display: inline-block;
    max-width: 100%;
  }

  .ai-brand-logo-bottom-{{ ai_gen_id }} {
  width: {{ block.settings.bottom_logo_width }}%;
  max-width: 100%;
  height: auto;
 aspect-ratio: 600 / 74;
  display: block;
  margin: 0 auto;
}

.ai-brand-logo-top-{{ ai_gen_id }} {
  width: {{ block.settings.top_logo_width }}%;
  max-width: 100%;
  height: auto;
  aspect-ratio: {{ block.settings.top_logo.width }} / {{ block.settings.top_logo.height }};
  display: block;
  margin: 0 auto;
}

  .ai-brand-logo-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100px;
    border-radius: 4px;
    margin: 0 auto;
  }

  .ai-brand-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-brand-tagline-{{ ai_gen_id }} {
    font-family: {{ block.settings.tagline_font.family }}, {{ block.settings.tagline_font.fallback_families }};
    font-weight: {{ block.settings.tagline_font.weight }};
    font-style: {{ block.settings.tagline_font.style }};
    font-size: {{ block.settings.tagline_font_size }}px;
    color: {{ block.settings.tagline_color }};
    margin: 0 auto;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-brand-tagline-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-logos-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-brand-logos-container-{{ ai_gen_id }} {
      gap: 15px;
    }
  }
{% endstyle %}

<brand-logos-{{ ai_gen_id }} class="ai-brand-logos-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-logos-container-{{ ai_gen_id }}">
    <div class="ai-brand-logo-wrapper-{{ ai_gen_id }}">
      {% if block.settings.top_logo_link != blank %}
        <a href="{{ block.settings.top_logo_link }}" class="ai-brand-logo-link-{{ ai_gen_id }}" aria-label="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}">
      {% endif %}
        {% if block.settings.top_logo %}
          <img
            src="{{ block.settings.top_logo | image_url: width: 600 }}"
            alt="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}"
            loading="eager"
            width="{{ block.settings.top_logo.width }}"
            height="{{ block.settings.top_logo.height }}"
            class="ai-brand-logo-top-{{ ai_gen_id }}"
            style="width: {{ block.settings.top_logo_width }}%; aspect-ratio: {{ block.settings.top_logo.width }} / {{ block.settings.top_logo.height }};"
          >
        {% endif %}
      {% if block.settings.top_logo_link != blank %}
        </a>
      {% endif %}
    </div>

    <div class="ai-brand-logo-wrapper-{{ ai_gen_id }}">
      {% if block.settings.bottom_logo_link != blank %}
        <a href="{{ block.settings.bottom_logo_link }}" class="ai-brand-logo-link-{{ ai_gen_id }}" aria-label="{{ block.settings.bottom_logo.alt | default: 'Atelier Modernista' | escape }}">
      {% endif %}
        {% if block.settings.bottom_logo %}
          <img
            src="{{ block.settings.bottom_logo | image_url: width: 600 }}"
            alt="{{ block.settings.bottom_logo.alt | default: 'Atelier Modernista — Art You Can Wear' | escape }}"
            loading="eager"
            width="600"
            height="{{ block.settings.bottom_logo.height }}"
            class="ai-brand-logo-bottom-{{ ai_gen_id }}"
            style="width: {{ block.settings.bottom_logo_width }}%; aspect-ratio: 600 / 74;"
        {% else %}
          <div class="ai-brand-logo-placeholder-{{ ai_gen_id }}" style="width: {{ block.settings.bottom_logo_width }}%;">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% if block.settings.bottom_logo_link != blank %}
        </a>
      {% endif %}
    </div>

    {% if block.settings.tagline_text != blank %}
      {% if block.settings.tagline_link != blank %}
        <a href="{{ block.settings.tagline_link }}" class="ai-brand-tagline-{{ ai_gen_id }}">
          {{ block.settings.tagline_text }}
        </a>
      {% else %}
        <p class="ai-brand-tagline-{{ ai_gen_id }}">{{ block.settings.tagline_text }}</p>
      {% endif %}
    {% endif %}
  </div>
</brand-logos-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Brand logos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Top logo"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Top logo image"
    },
    {
      "type": "url",
      "id": "top_logo_link",
      "label": "Top logo link"
    },
    {
      "type": "range",
      "id": "top_logo_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Top logo width",
      "default": 30
    },
    {
      "type": "header",
      "content": "Bottom logo"
    },
    {
      "type": "image_picker",
      "id": "bottom_logo",
      "label": "Bottom logo image"
    },
    {
      "type": "url",
      "id": "bottom_logo_link",
      "label": "Bottom logo link"
    },
    {
      "type": "range",
      "id": "bottom_logo_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Bottom logo width",
      "default": 60
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "text",
      "id": "tagline_text",
      "label": "Tagline text",
      "default": "Art You Can Wear"
    },
    {
      "type": "url",
      "id": "tagline_link",
      "label": "Tagline link"
    },
    {
      "type": "font_picker",
      "id": "tagline_font",
      "label": "Tagline font",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "tagline_font_size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Tagline font size",
      "default": 18
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Brand logos"
    }
  ]
}
{% endschema %}
