    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content gap",
      "min": 20,
      "max": 60,
      "step": 5,
