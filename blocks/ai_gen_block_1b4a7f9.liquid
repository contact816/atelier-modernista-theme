{% doc %}
  @prompt
    Can you make a n announcement bar with Free UK Shipping, No Minimum Spend , make it yellow background please and a leaf image, not a black leaf, a green one, put a green leaf either side and add another announcement please, add the leaf on the other side of the 'spend' text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    text-align: center;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    position: relative;
  }

  .ai-announcement-bar__content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .ai-announcement-bar__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-announcement-bar__icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    fill: currentColor;
  }

  .ai-announcement-bar__text-{{ ai_gen_id }} {
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-announcement-bar__link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: {{ block.settings.link_style }};
    display: inline-block;
  }

  .ai-announcement-bar__link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-announcement-bar__divider-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    margin: 0 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-announcement-bar__icon-{{ ai_gen_id }} svg {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-announcement-bar__content-{{ ai_gen_id }} {
      flex-wrap: wrap;
      gap: 8px;
    }
  }
{% endstyle %}

<div class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar__content-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <span class="ai-announcement-bar__icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
        </svg>
      </span>
    {% endif %}

    <div class="ai-announcement-bar__text-{{ ai_gen_id }}">
      {% if block.settings.link_url != blank %}
        <a href="{{ block.settings.link_url }}" class="ai-announcement-bar__link-{{ ai_gen_id }}">
          {{ block.settings.announcement_text }}
        </a>
      {% else %}
        {{ block.settings.announcement_text }}
      {% endif %}
      
      {% if block.settings.show_icon %}
        <span class="ai-announcement-bar__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
          </svg>
        </span>
      {% endif %}
    </div>

    {% if block.settings.show_second_announcement and block.settings.announcement_text_2 != blank %}
      <span class="ai-announcement-bar__divider-{{ ai_gen_id }}">|</span>
      
      <div class="ai-announcement-bar__text-{{ ai_gen_id }}">
        {% if block.settings.link_url_2 != blank %}
          <a href="{{ block.settings.link_url_2 }}" class="ai-announcement-bar__link-{{ ai_gen_id }}">
            {{ block.settings.announcement_text_2 }}
          </a>
        {% else %}
          {{ block.settings.announcement_text_2 }}
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "First announcement"
    },
    
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Second announcement"
    },
    {
      "type": "checkbox",
      "id": "show_second_announcement",
      "label": "Show second announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Text",
      "default": "Shop Now & Save"
    },
    {
      "type": "url",
      "id": "link_url_2",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "link_style",
      "label": "Link style",
      "options": [
        {
          "value": "none",
          "label": "No underline"
        },
        {
          "value": "underline",
          "label": "Underline"
        }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show leaf icons",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#228B22"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4bf1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "default": 1000
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}