{% doc %}
  @prompt
    A long title across the top of the collection cards, centred in Cormorant font, saying Atelier Modernista and centred below it in burgundy 'Art You Can Wear' in a mix of cpas and lower case. Thank you.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-header-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-brand-header__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    line-height: 1.2;
    letter-spacing: {{ block.settings.title_letter_spacing }}em;
  }

  .ai-brand-header__subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtitle_font.family }}, {{ block.settings.subtitle_font.fallback_families }};
    font-weight: {{ block.settings.subtitle_font.weight }};
    font-style: {{ block.settings.subtitle_font.style }};
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.4;
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}em;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-header__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-brand-header__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h1 class="ai-brand-header__title-{{ ai_gen_id }}">
      {{ block.settings.title }}
    </h1>
  {% endif %}

  {% if block.settings.subtitle != blank %}
    <p class="ai-brand-header__subtitle-{{ ai_gen_id }}">
      {{ block.settings.subtitle }}
    </p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Brand header",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Atelier Modernista"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Font",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 48
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "unit": "em",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Art You Can Wear"
    },
    {
      "type": "font_picker",
      "id": "subtitle_font",
      "label": "Font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 24
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color",
      "default": "#800020"
    },
    {
      "type": "range",
      "id": "subtitle_letter_spacing",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "unit": "em",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 4,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Space between title and subtitle",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Brand header"
    }
  ]
}
{% endschema %}
