    lease add a Mother's Day Gifts carousel below the tagline Handmade Contemporary Jewellery, can you add in three image cards which link to a product, delete the cards you have. We will have a feature product, for mther's day. Have one small image with a link, then three prdcut images all for the same product., make the imain mage much mich smaller, delete the second prduct image, one header picture and three prict images, all alighned, make it very petite,  one header image  portrait on the left and three landscape product images aligned t it on the right , can you make it much more condensed, like a left justified portrait and then three landscapes on the right directly aligned with the portait, please make it ONE portrait to the left and three small product boxes to the right of it, aligned
    
    , this is great. please leqve it as it is, but add a title and make the pruct boxes half as wide. thank you, centre it all
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mothers-day-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px 0;
  }

  .ai-mothers-day-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-mothers-day-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .ai-mothers-day-container-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: stretch;
    max-width: max-content;
  }

  .ai-mothers-day-header-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.header_width }}%;
    display: flex;
    flex-direction: column;
  }

  .ai-mothers-day-header-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-mothers-day-header-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
    min-height: 300px;
  }

  .ai-mothers-day-header-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-mothers-day-products-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: space-between;
    max-width: 50%;
  }

  .ai-mothers-day-product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    background-color: {{ block.settings.product_bg_color }};
    padding: 8px;
    border-radius: {{ block.settings.border_radius }}px;
    text-decoration: none;
    transition: transform 0.2s ease;
    flex: 1;
  }

  .ai-mothers-day-product-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-mothers-day-product-image-{{ ai_gen_id }} {
    width: {{ block.settings.product_image_size }}px;
    height: {{ block.settings.product_image_size }}px;
    flex-shrink: 0;
  }

  .ai-mothers-day-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-mothers-day-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-mothers-day-product-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-mothers-day-product-info-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-mothers-day-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ai-mothers-day-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-mothers-day-empty-state-{{ ai_gen_id }} {
    font-size: 12px;
    color: #999;
    text-align: center;
    padding: 8px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-mothers-day-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-mothers-day-header-{{ ai_gen_id }} {
      flex: 0 0 auto;
    }

    .ai-mothers-day-products-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-mothers-day-header-placeholder-{{ ai_gen_id }} {
      min-height: 200px;
    }
  }
{% endstyle %}

<div class="ai-mothers-day-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    <h2 class="ai-mothers-day-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-mothers-day-wrapper-{{ ai_gen_id }}">
    <div class="ai-mothers-day-container-{{ ai_gen_id }}">
      <div class="ai-mothers-day-header-{{ ai_gen_id }}">
        {% if block.settings.header_image %}
          <img
            src="{{ block.settings.header_image | image_url: width: 600 }}"
            alt="{{ block.settings.header_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.header_image.width }}"
            height="{{ block.settings.header_image.height }}"
            class="ai-mothers-day-header-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-mothers-day-header-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-mothers-day-products-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
          %}

          {% if product != blank %}
            <a
              href="{{ product.url }}"
              class="ai-mothers-day-product-{{ ai_gen_id }}"
            >
              <div class="ai-mothers-day-product-image-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 200 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {% else %}
                  <div class="ai-mothers-day-product-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-mothers-day-product-info-{{ ai_gen_id }}">
                <h3 class="ai-mothers-day-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-mothers-day-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            </a>
          {% else %}
            <div class="ai-mothers-day-product-{{ ai_gen_id }}">
              <div class="ai-mothers-day-product-image-{{ ai_gen_id }}">
                <div class="ai-mothers-day-product-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-mothers-day-product-info-{{ ai_gen_id }}">
                <div class="ai-mothers-day-empty-state-{{ ai_gen_id }}">
                  Add product {{ i }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mother's Day gifts",
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Mother's Day Gifts"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Header image"
    },
    {
      "type": "image_picker",
      "id": "header_image",
      "label": "Portrait image"
    },
    {
      "type": "range",
      "id": "header_width",
      "label": "Header width",
      "min": 20,
      "max": 40,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "range",
      "id": "product_image_size",
      "label": "Product image size",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product title size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "product_price_size",
      "label": "Product price size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "product_bg_color",
      "label": "Product background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Mother's Day gifts"
    }
  ]
}
{% endschema %}
