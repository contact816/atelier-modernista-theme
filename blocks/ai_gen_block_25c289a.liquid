{% doc %}
  @prompt
    a logo with link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-link-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-logo-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
  }

  .ai-logo-image-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: 4px;
    padding: 20px;
  }

  .ai-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    max-width: 200px;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-image-{{ ai_gen_id }},
    .ai-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-link-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-container-{{ ai_gen_id }}">
    {% if block.settings.logo_link != blank %}
      <a href="{{ block.settings.logo_link }}" aria-label="{{ block.settings.logo_alt_text | default: 'Logo' }}">
        {% if block.settings.logo %}
          <img
            src="{{ block.settings.logo | image_url: width: 600 }}"
            alt="{{ block.settings.logo_alt_text | escape }}"
            class="ai-logo-image-{{ ai_gen_id }}"
            width="{{ block.settings.logo_width }}"
            height="auto"
            loading="lazy"
          >
        {% else %}
          <div class="ai-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </a>
    {% else %}
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ block.settings.logo_alt_text | escape }}"
          class="ai-logo-image-{{ ai_gen_id }}"
          width="{{ block.settings.logo_width }}"
          height="auto"
          loading="lazy"
        >
      {% else %}
        <div class="ai-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Logo with link",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt_text",
      "label": "Logo alt text",
      "default": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Logo with link"
    }
  ]
}
{% endschema %}
