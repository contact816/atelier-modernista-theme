{% doc %}
  @prompt
    A product box, with controls the width and height and background colur, with controls for padding. Please make the p[ading quite large bettn blocks. , centre it, can you put a lot of padding between the block above (collection carsd) and this, can you ake the image taller please, can you make the button text smaller, the button higher and the text Garamond please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-box-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: {{ block.settings.top_spacing }}px;
    margin-bottom: {{ block.settings.block_spacing }}px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-product-box-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    height: {{ block.settings.box_height }}px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-box-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-box-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-box-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-box-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
  }

  .ai-product-box-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: center;
    align-items: center;
  }

  .ai-product-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  .ai-product-box-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-product-box-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-product-box-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_height }}px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    transition: background-color 0.3s ease;
    margin-top: auto;
    font-size: {{ block.settings.button_text_size }}px;
    font-family: Garamond, serif;
  }

  .ai-product-box-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-product-box-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-product-box-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-product-box-container-{{ ai_gen_id }} {
      height: auto;
      min-height: {{ block.settings.box_height | times: 0.7 }}px;
    }

    .ai-product-box-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<product-box-{{ ai_gen_id }} class="ai-product-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-box-container-{{ ai_gen_id }}">
    {% if block.settings.product %}
      <div class="ai-product-box-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product.featured_image %}
          <img
            src="{{ block.settings.product.featured_image | image_url: width: 600 }}"
            alt="{{ block.settings.product.featured_image.alt | escape }}"
            class="ai-product-box-image-{{ ai_gen_id }}"
            loading="lazy"
            width="600"
            height="600"
          >
        {% else %}
          <div class="ai-product-box-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-product-box-content-{{ ai_gen_id }}">
        <h3 class="ai-product-box-title-{{ ai_gen_id }}">{{ block.settings.product.title }}</h3>
        
        <p class="ai-product-box-price-{{ ai_gen_id }}">{{ block.settings.product.price | money }}</p>

        {% if block.settings.show_description and block.settings.product.description != blank %}
          <div class="ai-product-box-description-{{ ai_gen_id }}">
            {{ block.settings.product.description | strip_html | truncate: 120 }}
          </div>
        {% endif %}

        <a href="{{ block.settings.product.url }}" class="ai-product-box-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% else %}
      <div class="ai-product-box-image-wrapper-{{ ai_gen_id }}" style="position: relative;">
        <div class="ai-product-box-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
        <div class="ai-product-box-empty-state-{{ ai_gen_id }}">
          Next, select a product to display
        </div>
      </div>
    {% endif %}
  </div>
</product-box-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductBox{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-box-{{ ai_gen_id }}', ProductBox{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product box",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "header",
      "content": "Box dimensions"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "box_height",
      "label": "Box height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 150,
      "max": 500,
      "step": 25,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Space above block",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "block_spacing",
      "label": "Space below block",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Box border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_height",
      "label": "Button height",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Product box"
    }
  ]
}
{% endschema %}