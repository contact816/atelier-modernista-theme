{% doc %}
  @prompt
    six collection cards, three stacked on three in New York font
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-collection-cards__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
    width: 100%;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-collection-card__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collection-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collection-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-card__title-{{ ai_gen_id }} {
    font-family: 'New York', 'Times New Roman', serif;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-collection-card__description-{{ ai_gen_id }} {
    font-family: 'New York', 'Times New Roman', serif;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-collection-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    font-family: 'New York', 'Times New Roman', serif;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }

    .ai-collection-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-collection-card__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<collection-cards-{{ ai_gen_id }} class="ai-collection-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-cards__grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign collection = block.settings[collection_key]
      %}

      <div class="ai-collection-card-{{ ai_gen_id }}">
        {% if collection != blank %}
          <a href="{{ collection.url }}" class="ai-collection-card__link-{{ ai_gen_id }}">
            <div class="ai-collection-card__image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                 src="{{ collection.featured_image | image_url: width: 400 }}"
srcset="{{ collection.featured_image | image_url: width: 200 }} 200w,
        {{ collection.featured_image | image_url: width: 400 }} 400w,
        {{ collection.featured_image | image_url: width: 600 }} 600w"
sizes="(max-width: 749px) calc(50vw - 20px), 300px"
                  alt="{{ collection.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                  class="ai-collection-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-collection-card__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-collection-card__content-{{ ai_gen_id }}">
              <h3 class="ai-collection-card__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              {% if block.settings.show_description and collection.description != blank %}
                <p class="ai-collection-card__description-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: 80 }}
                </p>
              {% endif %}
            </div>
          </a>
        {% else %}
          <div class="ai-collection-card__image-wrapper-{{ ai_gen_id }}">
            <div class="ai-collection-card__placeholder-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
              <div class="ai-collection-card__empty-state-{{ ai_gen_id }}">
                Add collection {{ i }}
              </div>
            </div>
          </div>
          <div class="ai-collection-card__content-{{ ai_gen_id }}">
            <h3 class="ai-collection-card__title-{{ ai_gen_id }}">Collection {{ i }}</h3>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</collection-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-collection-card-{{ ai_gen_id }}');
      }
    }

    customElements.define('collection-cards-{{ ai_gen_id }}', CollectionCards{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection cards",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Collection 3"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Collection 4"
    },
    {
      "type": "collection",
      "id": "collection_5",
      "label": "Collection 5"
    },
    {
      "type": "collection",
      "id": "collection_6",
      "label": "Collection 6"
