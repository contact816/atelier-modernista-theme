{% doc %}
  @prompt
    Six small collection cards stacked three upon three with 'Atelier Modernista' in very elegant Didot font above them, and Art You Can Wear underneath the heading. Can the cards be rounded and have space for title text at the bottom of each card. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collection-cards__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-collection-cards__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-collection-cards__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-style: {{ block.settings.title_font.style }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    letter-spacing: 0.05em;
  }

  .ai-collection-cards__subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.subtitle_font.family }}, {{ block.settings.subtitle_font.fallback_families }};
    font-weight: {{ block.settings.subtitle_font.weight }};
    font-style: {{ block.settings.subtitle_font.style }};
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ai-collection-cards__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-collection-cards__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-collection-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-collection-cards__card-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-cards__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px 0 0;
  }

  .ai-collection-cards__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-cards__card-{{ ai_gen_id }}:hover .ai-collection-cards__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-cards__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-cards__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-cards__card-title-{{ ai_gen_id }} {
    padding: {{ block.settings.card_title_padding }}px;
    text-align: {{ block.settings.card_title_alignment }};
    background-color: {{ block.settings.card_background }};
    border-radius: 0 0 {{ block.settings.card_border_radius }}px {{ block.settings.card_border_radius }}px;
  }

  .ai-collection-cards__card-title-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, {{ block.settings.card_title_font.fallback_families }};
    font-weight: {{ block.settings.card_title_font.weight }};
    font-style: {{ block.settings.card_title_font.style }};
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0;
    letter-spacing: 0.02em;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }

    .ai-collection-cards__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-collection-cards__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .ai-collection-cards__card-title-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<collection-cards-{{ ai_gen_id }} class="ai-collection-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-cards__container-{{ ai_gen_id }}">
    <div class="ai-collection-cards__header-{{ ai_gen_id }}">
      <h2 class="ai-collection-cards__title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      <p class="ai-collection-cards__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    </div>

    <div class="ai-collection-cards__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}

        <div class="ai-collection-cards__card-{{ ai_gen_id }}">
          {% if collection != blank %}
            <a href="{{ collection.url }}" class="ai-collection-cards__card-link-{{ ai_gen_id }}">
              <div class="ai-collection-cards__image-wrapper-{{ ai_gen_id }}">
                {% if collection.featured_image %}
                  <img
                    src="{{ collection.featured_image | image_url: width: 600 }}"
                    alt="{{ collection.featured_image.alt | escape }}"
                    class="ai-collection-cards__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  >
                {% else %}
                  <div class="ai-collection-cards__placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-collection-cards__card-title-{{ ai_gen_id }}">
                <h3 class="ai-collection-cards__card-title-text-{{ ai_gen_id }}">{{ collection.title }}</h3>
              </div>
            </a>
          {% else %}
            <div class="ai-collection-cards__card-link-{{ ai_gen_id }}">
              <div class="ai-collection-cards__image-wrapper-{{ ai_gen_id }}">
                <div class="ai-collection-cards__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-collection-cards__card-title-{{ ai_gen_id }}">
                <h3 class="ai-collection-cards__card-title-text-{{ ai_gen_id }}">Collection {{ i }}</h3>
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</collection-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-collection-cards__card-{{ ai_gen_id }}');
      }
    }

    customElements.define('collection-cards-{{ ai_gen_id }}', CollectionCards{{ ai_gen_id }});
  })();
</script>

