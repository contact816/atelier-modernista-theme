{% doc %}
  @prompt
    Merged split banner section combining all settings from both versions. Gradient overlay follows content position. Desktop width control. Border radius option. CLS fix via aspect-ratio. Cormorant Garamond throughout. Cobalt #0047AB default button. Per-panel settings for image, heading, subheading, button text and link.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-split-banner-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_between_panels }}px;
    width: 100%;
    align-items: stretch;
  }

  .ai-split-banner-panel-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    overflow: hidden;
    aspect-ratio: {{ block.settings.aspect_ratio_desktop }};
    min-height: {{ block.settings.min_height_desktop }}px;
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    text-decoration: none;
    cursor: pointer;
  }

  .ai-split-banner-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .ai-split-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    right: 0;
    padding: {{ block.settings.overlay_padding }}px;
    pointer-events: none;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 12px;

    {% if block.settings.vertical_position == 'top' %}
      top: 0;
      bottom: auto;
      background: linear-gradient(to bottom, {{ block.settings.overlay_color }}, transparent);
      justify-content: flex-start;
    {% elsif block.settings.vertical_position == 'middle' %}
      top: 50%;
      transform: translateY(-50%);
      background: {{ block.settings.overlay_color }};
      justify-content: center;
    {% else %}
      bottom: 0;
      top: auto;
      background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
      justify-content: flex-end;
    {% endif %}

    {% if block.settings.text_alignment == 'left' %}
      align-items: flex-start;
      text-align: left;
    {% elsif block.settings.text_alignment == 'right' %}
      align-items: flex-end;
      text-align: right;
    {% else %}
      align-items: center;
      text-align: center;
    {% endif %}
  }

  .ai-split-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.2;
    color: #ffffff;
  }

  .ai-split-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.4;
    color: #ffffff;
  }

  .ai-split-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    pointer-events: auto;
    z-index: 3;
    position: relative;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-split-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-split-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.min_height_desktop }}px;
  }

  .ai-split-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (max-width: 749px) {
  .ai-split-banner-panel-{{ ai_gen_id }} {
    min-height: {{ block.settings.min_height_mobile }}px;
    aspect-ratio: 4 / 3;
  }

    .ai-split-banner-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_between_panels }}px;
    }

    .ai-split-banner-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-split-banner-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.8);
    }

    .ai-split-banner-button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_font_size }}px * 0.9);
    }

    .ai-split-banner-overlay-{{ ai_gen_id }} {
      padding: {{ block.settings.overlay_padding | times: 0.75 | round }}px;
    }
  }
{% endstyle %}

<div class="ai-split-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-banner-container-{{ ai_gen_id }}">

    <a href="{{ block.settings.panel_1_link }}" class="ai-split-banner-panel-{{ ai_gen_id }}" aria-label="{{ block.settings.panel_1_heading | default: 'View collection' | escape }}">
      {% if block.settings.panel_1_image %}
        <img
          src="{{ block.settings.panel_1_image | image_url: width: 1200 }}"
          srcset="{{ block.settings.panel_1_image | image_url: width: 600 }} 600w,
                  {{ block.settings.panel_1_image | image_url: width: 900 }} 900w,
                  {{ block.settings.panel_1_image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 749px) 100vw, {{ block.settings.desktop_width_percent | divided_by: 2 }}vw"
          alt="{{ block.settings.panel_1_image.alt | escape }}"
          class="ai-split-banner-image-{{ ai_gen_id }}"
          loading="eager"
          fetchpriority="high"
          width="{{ block.settings.panel_1_image.width | default: 600 }}"
height="{{ block.settings.panel_1_image.height | default: 800 }}"
        >
      {% else %}
        <div class="ai-split-banner-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <div class="ai-split-banner-overlay-{{ ai_gen_id }}">
        {% if block.settings.panel_1_heading != blank %}
          <h2 class="ai-split-banner-heading-{{ ai_gen_id }}">{{ block.settings.panel_1_heading }}</h2>
        {% endif %}
        {% if block.settings.panel_1_subheading != blank %}
          <p class="ai-split-banner-subheading-{{ ai_gen_id }}">{{ block.settings.panel_1_subheading }}</p>
        {% endif %}
        {% if block.settings.panel_1_button_text != blank %}
          <span class="ai-split-banner-button-{{ ai_gen_id }}">{{ block.settings.panel_1_button_text }}</span>
        {% endif %}
      </div>
    </a>

    <a href="{{ block.settings.panel_2_link }}" class="ai-split-banner-panel-{{ ai_gen_id }}" aria-label="{{ block.settings.panel_2_heading | default: 'View collection' | escape }}">
      {% if block.settings.panel_2_image %}
        <img
          src="{{ block.settings.panel_2_image | image_url: width: 1200 }}"
          srcset="{{ block.settings.panel_2_image | image_url: width: 600 }} 600w,
                  {{ block.settings.panel_2_image | image_url: width: 900 }} 900w,
                  {{ block.settings.panel_2_image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 749px) 100vw, {{ block.settings.desktop_width_percent | divided_by: 2 }}vw"
          alt="{{ block.settings.panel_2_image.alt | escape }}"
          class="ai-split-banner-image-{{ ai_gen_id }}"
          loading="eager"
          fetchpriority="high"
          width="{{ block.settings.panel_2_image.width | default: 600 }}"
          height="{{ block.settings.panel_2_image.height | default: 800 }}"
        >
      {% else %}
        <div class="ai-split-banner-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <div class="ai-split-banner-overlay-{{ ai_gen_id }}">
        {% if block.settings.panel_2_heading != blank %}
          <h2 class="ai-split-banner-heading-{{ ai_gen_id }}">{{ block.settings.panel_2_heading }}</h2>
        {% endif %}
        {% if block.settings.panel_2_subheading != blank %}
          <p class="ai-split-banner-subheading-{{ ai_gen_id }}">{{ block.settings.panel_2_subheading }}</p>
        {% endif %}
        {% if block.settings.panel_2_button_text != blank %}
          <span class="ai-split-banner-button-{{ ai_gen_id }}">{{ block.settings.panel_2_button_text }}</span>
        {% endif %}
      </div>
    </a>

  </div>
</div>

{% schema %}
{
  "name": "Split banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Panel 1"
    },
    {
      "type": "image_picker",
      "id": "panel_1_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "panel_1_heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "panel_1_subheading",
      "label": "Subheading",
      "default": "Explore our most coveted pieces"
    },
    {
      "type": "text",
      "id": "panel_1_button_text",
      "label": "Button text",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "panel_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Panel 2"
    },
    {
      "type": "image_picker",
      "id": "panel_2_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "panel_2_heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "panel_2_subheading",
      "label": "Subheading",
      "default": "Discover our newest additions"
    },
    {
      "type": "text",
      "id": "panel_2_button_text",
      "label": "Button text",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "panel_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap_between_panels",
      "label": "Gap between panels",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Minimum height (desktop)",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Minimum height (mobile)",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 350
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Image aspect ratio (desktop)",
      "options": [
        { "value": "3 / 4", "label": "Portrait 3:4" },
        { "value": "4 / 5", "label": "Portrait 4:5" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 3", "label": "Landscape 4:3" },
        { "value": "16 / 9", "label": "Landscape 16:9" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "image_crop",
      "label": "Image crop",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill" }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content position"
    },
    {
      "type": "select",
      "id": "vertical_position",
      "label": "Vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "label": "Overlay padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background colour",
      "default": "#0047AB"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background colour",
      "default": "#003580"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Split banner"
    }
  ]
}
{% endschema %}