{% doc %}
  @prompt
    A small  carousel feature box, connected to a product, can you make it very narrow and align it with the collections cards below please, centre it on the page, could you please add an Alignment button, can you give choices for image size please, make it landscape. Centred Add To Cart button, make it a carousel of six prducts, individual
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.alignment }};
  }

  .ai-product-carousel-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
  }

  .ai-product-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-product-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    flex-shrink: 0;
  }

  .ai-product-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-product-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-carousel-controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 10px;
    pointer-events: none;
  }

  .ai-product-carousel-button-{{ ai_gen_id }} {
    pointer-events: auto;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .ai-product-carousel-button-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-product-carousel-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-product-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
  }

  .ai-product-carousel-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-product-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-product-carousel-info-{{ ai_gen_id }} {
    margin-top: 16px;
  }

  .ai-product-carousel-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-carousel-price-{{ ai_gen_id }} {
    font-size: 16px;
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-carousel-add-to-cart-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.cart_button_background }};
    color: {{ block.settings.cart_button_text }};
    border: none;
    border-radius: {{ block.settings.cart_button_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-product-carousel-add-to-cart-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-product-carousel-empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-product-carousel-image-{{ ai_gen_id }},
    .ai-product-carousel-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }}
  class="ai-product-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% assign products_array = '' %}
  {% assign products_array = products_array | append: block.settings.product_1.id | append: ',' %}
  {% assign products_array = products_array | append: block.settings.product_2.id | append: ',' %}
  {% assign products_array = products_array | append: block.settings.product_3.id | append: ',' %}
  {% assign products_array = products_array | append: block.settings.product_4.id | append: ',' %}
  {% assign products_array = products_array | append: block.settings.product_5.id | append: ',' %}
  {% assign products_array = products_array | append: block.settings.product_6.id %}

  {% assign has_products = false %}
  {% if block.settings.product_1 or block.settings.product_2 or block.settings.product_3 or block.settings.product_4 or block.settings.product_5 or block.settings.product_6 %}
    {% assign has_products = true %}
  {% endif %}

  {% if has_products %}
    <div class="ai-product-carousel-container-{{ ai_gen_id }}">
      <div class="ai-product-carousel-track-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% assign product_key = 'product_' | append: i %}
          {% assign current_product = block.settings[product_key] %}

          {% if current_product %}
            <div class="ai-product-carousel-slide-{{ ai_gen_id }}" data-product-index="{{ forloop.index0 }}">
              {% if current_product.featured_image %}
                <img
                  src="{{ current_product.featured_image | image_url: width: 400 }}"
                  srcset="{{ current_product.featured_image | image_url: width: 200 }} 200w,
                          {{ current_product.featured_image | image_url: width: 400 }} 400w,
                          {{ current_product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) calc(50vw - 20px), 400px"
                  alt="{{ current_product.featured_image.alt | escape }}"
                  class="ai-product-carousel-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-product-carousel-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% assign product_count = 0 %}
      {% for i in (1..6) %}
        {% assign product_key = 'product_' | append: i %}
        {% if block.settings[product_key] %}
          {% assign product_count = product_count | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% if product_count > 1 %}
        <div class="ai-product-carousel-controls-{{ ai_gen_id }}">
          <button
            class="ai-product-carousel-button-{{ ai_gen_id }} ai-product-carousel-prev-{{ ai_gen_id }}"
            aria-label="Previous product"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button
            class="ai-product-carousel-button-{{ ai_gen_id }} ai-product-carousel-next-{{ ai_gen_id }}"
            aria-label="Next product"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>

        <div class="ai-product-carousel-dots-{{ ai_gen_id }}">
          {% for i in (1..6) %}
            {% assign product_key = 'product_' | append: i %}
            {% if block.settings[product_key] %}
              <button
                class="ai-product-carousel-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                data-index="{{ forloop.index | minus: 1 }}"
                aria-label="Go to product {{ forloop.index }}"
              ></button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-carousel-info-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% assign product_key = 'product_' | append: i %}
        {% assign current_product = block.settings[product_key] %}
        {% if current_product %}
          <div
            class="ai-product-carousel-product-info-{{ ai_gen_id }}"
            data-product-info="{{ forloop.index | minus: 1 }}"
            style="{% unless forloop.first %}display: none;{% endunless %}"
          >
            <h3 class="ai-product-carousel-title-{{ ai_gen_id }}">{{ current_product.title }}</h3>
            <div class="ai-product-carousel-price-{{ ai_gen_id }}">{{ current_product.price | money }}</div>
            <a
              href="{{ current_product.url }}"
              class="ai-product-carousel-add-to-cart-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-product-carousel-empty-{{ ai_gen_id }}">
      <div class="ai-product-carousel-image-placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
      <p style="margin-top: 16px;">Select up to 6 products to display</p>
    </div>
  {% endif %}
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-product-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-product-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-product-carousel-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-product-carousel-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-product-carousel-dot-{{ ai_gen_id }}');
        this.productInfos = this.querySelectorAll('.ai-product-carousel-product-info-{{ ai_gen_id }}');

        if (this.slides.length <= 1) return;

        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });
      }

      prev() {
        this.currentIndex = this.currentIndex === 0 ? this.slides.length - 1 : this.currentIndex - 1;
        this.updateCarousel();
      }

      next() {
        this.currentIndex = this.currentIndex === this.slides.length - 1 ? 0 : this.currentIndex + 1;
        this.updateCarousel();
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
      }

      updateCarousel() {
        this.track.style.transform = `translateX(-${this.currentIndex * 100}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.productInfos.forEach((info, index) => {
          if (index === this.currentIndex) {
            info.style.display = 'block';
          } else {
            info.style.display = 'none';
          }
        });
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product carousel",
  "settings": [
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "product",
      "id": "product_4",
      "label": "Product 4"
    },
    {
      "type": "product",
      "id": "product_5",
      "label": "Product 5"
    },
    {
      "type": "product",
      "id": "product_6",
      "label": "Product 6"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add to Collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Image size",
      "options": [
        {
          "value": "200",
          "label": "Small"
        },
        {
          "value": "300",
          "label": "Medium"
        },
        {
          "value": "400",
          "label": "Large"
        }
      ],
      "default": "300"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Navigation button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Navigation button icon",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "cart_button_background",
      "label": "Add to cart background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "cart_button_text",
      "label": "Add to collection text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "cart_button_radius",
      "label": "Add to cart border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}
