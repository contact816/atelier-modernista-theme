{% doc %}
  @prompt
    a small box to hold the logo at the bottom, with a link to the collection, centred, no white background and a bigger image size please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-box-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
  }

  .ai-logo-box-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.padding }}px;
    background-color: transparent;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-logo-box-link-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 1.5 }});
  }

  .ai-logo-box-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-logo-box-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .ai-logo-box-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-logo-box-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-logo-box-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: #999;
    text-align: center;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-box-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.8 }}px;
      height: {{ block.settings.logo_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.collection != blank %}
    <a href="{{ block.settings.collection.url }}" class="ai-logo-box-link-{{ ai_gen_id }}">
      <div class="ai-logo-box-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <img
            src="{{ block.settings.logo | image_url: width: 600 }}"
            alt="{{ block.settings.logo.alt | escape }}"
            class="ai-logo-box-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
          >
        {% else %}
          <div class="ai-logo-box-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-logo-box-empty-state-{{ ai_gen_id }}">Add logo</div>
          </div>
        {% endif %}
      </div>
    </a>
  {% else %}
    <div class="ai-logo-box-link-{{ ai_gen_id }}">
      <div class="ai-logo-box-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.logo %}
          <img
            src="{{ block.settings.logo | image_url: width: 600 }}"
            alt="{{ block.settings.logo.alt | escape }}"
            class="ai-logo-box-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
          >
        {% else %}
          <div class="ai-logo-box-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-logo-box-empty-state-{{ ai_gen_id }}">Add logo and collection</div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Logo box",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 100,
      "max": 500,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 100,
      "max": 500,
      "step": 20,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Box style"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Logo box"
    }
  ]
}
{% endschema %}
