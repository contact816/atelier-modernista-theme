{% doc %}
  @prompt
    Create a brand logo image space , one stacked on top of the other please, only two logos, make the top image much much smaller and can it have a link embedded to www.ateliermodernista.com. Can you add 'Art You Can Wear' in mixed lower and uppercase underneath the second image, please?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-stack-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    text-align: center;
  }

  .ai-logo-stack__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.spacing_between }}px;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-logo-stack__top-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.top_logo_width }}px;
  }

  .ai-logo-stack__top-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-logo-stack__top-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-stack__top-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-stack__top-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-logo-stack__bottom-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.bottom_logo_width }}px;
  }

  .ai-logo-stack__bottom-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-logo-stack__bottom-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-logo-stack__bottom-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-logo-stack__text-{{ ai_gen_id }} {
    margin-top: {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-stack__top-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.top_logo_width | times: 0.8 }}px;
    }

    .ai-logo-stack__bottom-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.bottom_logo_width | times: 0.8 }}px;
    }

    .ai-logo-stack__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-stack-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-stack__container-{{ ai_gen_id }}">
    <div class="ai-logo-stack__top-wrapper-{{ ai_gen_id }}">
      <a href="{{ block.settings.top_logo_link }}" class="ai-logo-stack__top-link-{{ ai_gen_id }}">
        {% if block.settings.top_logo %}
          <img
            src="{{ block.settings.top_logo | image_url: width: 800 }}"
            
            loading="eager"
            alt="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}"
            height="{{ block.settings.top_logo.height }}"
            class="ai-logo-stack__top-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-logo-stack__top-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </a>
    </div>

    <div class="ai-logo-stack__bottom-wrapper-{{ ai_gen_id }}">
      {% if block.settings.bottom_logo %}
        <img
          src="{{ block.settings.bottom_logo | image_url: width: 1200 }}"
          alt="{{ block.settings.bottom_logo.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.bottom_logo.width }}"
          height="{{ block.settings.bottom_logo.height }}"
          class="ai-logo-stack__bottom-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-logo-stack__bottom-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.bottom_text != blank %}
        <div class="ai-logo-stack__text-{{ ai_gen_id }}">
          {{ block.settings.bottom_text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Stacked logo images",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Top logo"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Top logo image"
    },
    {
      "type": "url",
      "id": "top_logo_link",
      "label": "Top logo link"
    },
    {
      "type": "range",
      "id": "top_logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Top logo width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Bottom logo"
    },
    {
      "type": "image_picker",
      "id": "bottom_logo",
      "label": "Bottom logo image"
    },
    {
      "type": "range",
      "id": "bottom_logo_width",
      "min": 100,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Bottom logo width",
      "default": 400
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Text below bottom logo",
      "default": "Art You Can Wear"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_between",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Space between logos",
      "default": 30
    },
    {
      "type": "range",
      "id": "text_spacing",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Space above text",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Stacked logo images"
    }
  ]
}
{% endschema %}
