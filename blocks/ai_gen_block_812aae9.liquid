{% doc %}
  @prompt
    Creat a brand logo image space , one stacked on top of the other please, only two logos, make the top image much much smaller, Can you add 'Art You Can Wear' in mixed lower and uppercase underneath the second image, please?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-logos-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-logos-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-brand-logo-top-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.top_logo_width }}px;
  }

  .ai-brand-logo-bottom-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.tagline_spacing }}px;
    width: 100%;
  }

  .ai-brand-logo-bottom-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.bottom_logo_width }}px;
  }

  .ai-brand-logo-top-{{ ai_gen_id }} img,
  .ai-brand-logo-bottom-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-brand-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 100px;
  }

  .ai-brand-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-brand-logo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-brand-tagline-{{ ai_gen_id }} {
    font-size: {{ block.settings.tagline_font_size }}px;
    color: {{ block.settings.tagline_color }};
    text-align: center;
    font-family: {{ block.settings.tagline_font.family }}, {{ block.settings.tagline_font.fallback_families }};
    font-weight: {{ block.settings.tagline_font.weight }};
    font-style: {{ block.settings.tagline_font.style }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-logos-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px 16px;
    }

    .ai-brand-logo-top-{{ ai_gen_id }} {
      max-width: {{ block.settings.top_logo_width | times: 0.8 }}px;
    }

    .ai-brand-logo-bottom-{{ ai_gen_id }} {
      max-width: {{ block.settings.bottom_logo_width | times: 0.8 }}px;
    }

    .ai-brand-tagline-{{ ai_gen_id }} {
      font-size: {{ block.settings.tagline_font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-logos-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-logos-container-{{ ai_gen_id }}">
    <div class="ai-brand-logo-top-{{ ai_gen_id }}">
      {% if block.settings.top_logo %}
        <img
          src="{{ block.settings.top_logo | image_url: width: 800 }}"
          alt="{{ block.settings.top_logo.alt | default: 'Atelier Modernista' | escape }}"
          loading="lazy"
          width="{{ block.settings.top_logo.width }}"
          height="{{ block.settings.top_logo.height }}"
        >
      {% else %}
        <div class="ai-brand-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-brand-logo-empty-state-{{ ai_gen_id }}">
            Add top logo
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-brand-logo-bottom-wrapper-{{ ai_gen_id }}">
      <div class="ai-brand-logo-bottom-{{ ai_gen_id }}">
        {% if block.settings.bottom_logo %}
          <img
            src="{{ block.settings.bottom_logo | image_url: width: 1200 }}"
            alt="{{ block.settings.bottom_logo.alt | default: 'Atelier Modernista — Art You Can Wear' | escape }}"
            loading="lazy"
            width="{{ block.settings.bottom_logo.width }}"
            height="{{ block.settings.bottom_logo.height }}"
          >
        {% else %}
          <div class="ai-brand-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-brand-logo-empty-state-{{ ai_gen_id }}">
              Add bottom logo
            </div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_tagline %}
        <p class="ai-brand-tagline-{{ ai_gen_id }}">{{ block.settings.tagline_text }}</p>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Stacked brand logos",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Top logo"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "top_logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Maximum width",
      "default": 150
    },
    {
      "type": "header",
      "content": "Bottom logo"
    },
    {
      "type": "image_picker",
      "id": "bottom_logo",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "bottom_logo_width",
      "min": 100,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Maximum width",
      "default": 500
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "checkbox",
      "id": "show_tagline",
      "label": "Show tagline",
      "default": true
    },
    {
      "type": "text",
      "id": "tagline_text",
      "label": "Text",
      "default": "Art You Can Wear"
    },
    {
      "type": "font_picker",
      "id": "tagline_font",
      "label": "Font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "tagline_font_size",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 18
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Letter spacing",
      "default": 2
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "tagline_spacing",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Space above tagline",
      "default": 15
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "logo_spacing",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Space between logos",
      "default": 30
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Stacked brand logos"
    }
  ]
}
{% endschema %}
