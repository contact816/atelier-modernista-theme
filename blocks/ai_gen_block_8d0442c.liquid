{% doc %}
  @prompt
    A single product feature box, aligned with the collection cards, and called Designer Edit, please, connect to a prouct, can you make it very narrow and align it with the collections cards below please, can you remove the top button, and make the box wider, and align exactly with the section below, centre it on the page, could you please add an Alignment button, can you give choices for image size please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-edit-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-designer-edit-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-designer-edit-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-designer-edit-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-designer-edit-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-designer-edit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  .ai-designer-edit-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-designer-edit-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-designer-edit-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-designer-edit-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  {% if block.settings.image_size == 'small' %}
    .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
      max-height: 300px;
    }
    .ai-designer-edit-image-{{ ai_gen_id }} {
      object-fit: cover;
      height: 300px;
    }
  {% elsif block.settings.image_size == 'medium' %}
    .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
      max-height: 500px;
    }
    .ai-designer-edit-image-{{ ai_gen_id }} {
      object-fit: cover;
      height: 500px;
    }
  {% elsif block.settings.image_size == 'large' %}
    .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
      max-height: 700px;
    }
    .ai-designer-edit-image-{{ ai_gen_id }} {
      object-fit: cover;
      height: 700px;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-designer-edit-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<div class="ai-designer-edit-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-designer-edit-container-{{ ai_gen_id }}">
    <div class="ai-designer-edit-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product and block.settings.product.featured_image %}
        <img
      src="{{ block.settings.product.featured_image | image_url: width: 400 }}"
          srcset="{{ block.settings.product.featured_image | image_url: width: 200 }} 200w,
                  {{ block.settings.product.featured_image | image_url: width: 400 }} 400w,
                  {{ block.settings.product.featured_image | image_url: width: 800 }} 800w"
          sizes="(max-width: 749px) calc(50vw - 20px), 400px"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          loading="lazy"
          width="400"
          height="400"
          class="ai-designer-edit-image-{{ ai_gen_id }}"
      {% else %}
        <div class="ai-designer-edit-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
          <div class="ai-designer-edit-empty-state-{{ ai_gen_id }}">
            Next, select a product
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-designer-edit-content-{{ ai_gen_id }}">
      {% if block.settings.show_title %}
        <h3 class="ai-designer-edit-title-{{ ai_gen_id }}">
          {% if block.settings.product %}
            {{ block.settings.product.title }}
          {% else %}
            Designer Edit
          {% endif %}
        </h3>
      {% endif %}

      {% if block.settings.show_description and block.settings.product %}
        <div class="ai-designer-edit-description-{{ ai_gen_id }}">
          {{ block.settings.product.description | strip_html | truncate: 150 }}
        </div>
      {% endif %}

      {% if block.settings.show_price and block.settings.product %}
        <div class="ai-designer-edit-price-{{ ai_gen_id }}">
          {{ block.settings.product.price | money }}
        </div>
      {% endif %}

      {% if block.settings.show_button and block.settings.product %}
        <a href="{{ block.settings.product.url }}" class="ai-designer-edit-link-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Designer Edit",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Image size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "auto",
          "label": "Auto"
        }
      ],
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show title",
      "default": true
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    }
  ],
  "presets": [
    {
      "name": "Designer Edit"
    }
  ]
}
{% endschema %}
