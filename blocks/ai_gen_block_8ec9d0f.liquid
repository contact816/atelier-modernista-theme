{% doc %}
  @prompt
    A banner that runs along below the logo saying 25% off with 'Happy2026' in bold
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 20px;
    text-align: center;
  }

  .ai-promo-banner__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-promo-banner__code-{{ ai_gen_id }} {
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .ai-promo-banner__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.9);
    }
  }
{% endstyle %}

<promo-banner-{{ ai_gen_id }}
  class="ai-promo-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <p class="ai-promo-banner__content-{{ ai_gen_id }}">
    {{ block.settings.message_before }}
    <span class="ai-promo-banner__code-{{ ai_gen_id }}">{{ block.settings.promo_code }}</span>
    {{ block.settings.message_after }}
  </p>
</promo-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class PromoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('promo-banner-{{ ai_gen_id }}', PromoBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "message_before",
      "label": "Message before code",
      "default": "25% off with"
    },
    {
      "type": "text",
      "id": "promo_code",
      "label": "Promo code",
      "default": "Happy2026"
    },
    {
      "type": "text",
      "id": "message_after",
      "label": "Message after code"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#334fb4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Promo banner"
    }
  ]
}
{% endschema %}
