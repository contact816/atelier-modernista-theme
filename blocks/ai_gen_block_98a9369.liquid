{% doc %}
  @prompt
    CAN YOU CREATE A DISCREET MENU TO SIT BELOW THE TEXT BOX, WITH LINKS TO THE OTHER COLLECTIONS
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-menu-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-collection-menu__nav-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ block.settings.alignment }};
    gap: {{ block.settings.link_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px 0;
    list-style: none;
    margin: 0;
  }

  .ai-collection-menu__item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-collection-menu__link-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.2s ease;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-collection-menu__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    background-color: {{ block.settings.link_hover_background }};
  }

  .ai-collection-menu__separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    user-select: none;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-menu__nav-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
      gap: {{ block.settings.link_spacing | times: 0.8 }}px;
    }

    .ai-collection-menu__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: {{ block.settings.link_padding_vertical | times: 0.8 }}px {{ block.settings.link_padding_horizontal | times: 0.8 }}px;
    }
  }
{% endstyle %}

<collection-menu-{{ ai_gen_id }}
  class="ai-collection-menu-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <nav aria-label="Collection navigation">
    <ul class="ai-collection-menu__nav-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}

        {% if collection != blank %}
          {% unless forloop.first %}
            {% if block.settings.show_separator %}
              <li class="ai-collection-menu__item-{{ ai_gen_id }} ai-collection-menu__separator-{{ ai_gen_id }}" aria-hidden="true">
                {{ block.settings.separator_character }}
              </li>
            {% endif %}
          {% endunless %}

          <li class="ai-collection-menu__item-{{ ai_gen_id }}">
            <a
              href="{{ collection.url }}"
              class="ai-collection-menu__link-{{ ai_gen_id }}"
            >
              {{ collection.title }}
            </a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </nav>
</collection-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionMenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('collection-menu-{{ ai_gen_id }}', CollectionMenu{{ ai_gen_id }});
  })();
</script>

