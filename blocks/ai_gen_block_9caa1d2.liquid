{% doc %}
  @prompt
    Create a brand logo image space  with a link embedded to www.ateliermodernista.com. Can you make the logo centred and its  width being controlled. please centre everything. Please add this header to every page on the site., give the logo a link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-logo-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-brand-logo__link-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: {{ block.settings.max_width }}px;
  }

  .ai-brand-logo__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-brand-logo__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-brand-logo__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-brand-logo__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-logo__link-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_width_percent }}%;
    }

    .ai-brand-logo-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 20px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-brand-logo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a 
    href="{{ block.settings.logo_link }}" 
    class="ai-brand-logo__link-{{ ai_gen_id }}"
    aria-label="Visit {{ shop.name }}"
  >
    {% if block.settings.logo_image %}
      <img
        src="{{ block.settings.logo_image | image_url: width: 1200 }}"
        alt="{{ block.settings.logo_image.alt | default: shop.name | escape }}"
        loading="lazy"
        width="{{ block.settings.logo_image.width }}"
        height="{{ block.settings.logo_image.height }}"
        class="ai-brand-logo__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-brand-logo__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-brand-logo__empty-state-{{ ai_gen_id }}">
          Next, add your brand logo
        </div>
      </div>
    {% endif %}
  </a>
</div>

{% schema %}
{
  "name": "Brand logo",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_width_percent",
      "label": "Mobile width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 100,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Brand logo"
    }
  ]
}
{% endschema %}
