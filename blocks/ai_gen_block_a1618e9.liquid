{% doc %}
  @prompt
    a logo with link that is not connected to any othr pages on the site
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-standalone-logo-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-standalone-logo-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-standalone-logo-link-{{ ai_gen_id }} {
    display: inline-block;
    line-height: 0;
  }

  .ai-standalone-logo-image-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
  }

  .ai-standalone-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    position: relative;
  }

  .ai-standalone-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    max-width: {{ block.settings.logo_width }}px;
  }

  .ai-standalone-logo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 12px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-standalone-logo-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-standalone-logo-image-{{ ai_gen_id }},
    .ai-standalone-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
    }

    .ai-standalone-logo-placeholder-{{ ai_gen_id }} svg {
      max-width: {{ block.settings.logo_width | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-standalone-logo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-standalone-logo-wrapper-{{ ai_gen_id }}">
    {% if block.settings.logo_link != blank %}
      <a href="{{ block.settings.logo_link }}" class="ai-standalone-logo-link-{{ ai_gen_id }}" {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
        {% if block.settings.logo %}
          <img
            src="{{ block.settings.logo | image_url: width: 600 }}"
            alt="{{ block.settings.logo.alt | default: 'Logo' | escape }}"
            class="ai-standalone-logo-image-{{ ai_gen_id }}"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
            loading="lazy"
          >
        {% else %}
          <div class="ai-standalone-logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-standalone-logo-empty-state-{{ ai_gen_id }}">
              Add your logo
            </div>
          </div>
        {% endif %}
      </a>
    {% else %}
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ block.settings.logo.alt | default: 'Logo' | escape }}"
          class="ai-standalone-logo-image-{{ ai_gen_id }}"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
          loading="lazy"
        >
      {% else %}
        <div class="ai-standalone-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-standalone-logo-empty-state-{{ ai_gen_id }}">
            Add your logo
          </div>
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Standalone logo",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Link"
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Standalone logo"
    }
  ]
}
{% endschema %}
