{% doc %}
  @prompt
    A small single product feature box, aligned with the collection cards, and called Designer Edit, please, connect to a prouct, can you make it very narrow and align it with the collections cards below please, can you remove the top button, and make the box wider, and align exactly with the section below, centre it on the page, could you please add an Alignment button, can you give choices for image size please, make it landscape and smaller please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-edit-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-designer-edit-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    text-align: {{ block.settings.alignment }};
  }

  .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 40%;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ai-designer-edit-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-designer-edit-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-designer-edit-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-designer-edit-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-designer-edit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .ai-designer-edit-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0 0 16px;
  }

  .ai-designer-edit-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-designer-edit-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-designer-edit-empty-product-{{ ai_gen_id }} {
    font-size: 14px;
    color: #999;
    text-align: center;
    padding: 20px;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-designer-edit-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-designer-edit-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-designer-edit-image-placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<designer-edit-{{ ai_gen_id }}
  class="ai-designer-edit-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-designer-edit-container-{{ ai_gen_id }}">
    {% if block.settings.product != blank %}
      {% assign product = block.settings.product %}
      
      <div class="ai-designer-edit-image-wrapper-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            class="ai-designer-edit-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-designer-edit-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-designer-edit-content-{{ ai_gen_id }}">
        {% if block.settings.label != blank %}
          <div class="ai-designer-edit-label-{{ ai_gen_id }}">
            {{ block.settings.label }}
          </div>
        {% endif %}

        <h3 class="ai-designer-edit-title-{{ ai_gen_id }}">
          {{ product.title }}
        </h3>

        <div class="ai-designer-edit-price-{{ ai_gen_id }}">
          {{ product.price | money }}
        </div>

        <a
          href="{{ product.url }}"
          class="ai-designer-edit-link-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% else %}
      <div class="ai-designer-edit-image-wrapper-{{ ai_gen_id }}">
        <div class="ai-designer-edit-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
          <div class="ai-designer-edit-empty-state-{{ ai_gen_id }}">
            Next, select a product
          </div>
        </div>
      </div>
      <div class="ai-designer-edit-content-{{ ai_gen_id }}">
        <div class="ai-designer-edit-empty-product-{{ ai_gen_id }}">
          Select a product to display in this Designer Edit box
        </div>
      </div>
    {% endif %}
  </div>
</designer-edit-{{ ai_gen_id }}>

<script>
  (function() {
    class DesignerEdit{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('designer-edit-{{ ai_gen_id }}', DesignerEdit{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Designer edit",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Designer Edit"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "Image height",
      "options": [
        {
          "value": "150",
          "label": "Small"
        },
        {
          "value": "200",
          "label": "Medium"
        },
        {
          "value": "250",
          "label": "Large"
        },
        {
          "value": "300",
          "label": "Extra large"
        }
      ],
      "default": "200"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Designer edit"
    }
  ]
}
{% endschema %}
