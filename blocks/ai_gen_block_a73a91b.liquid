{% doc %}
  @prompt
    ease add a The Cobalt Edition carousel with three image cards which link to a product, day. Have one small image with a link, then three product images all for the same product., make the main left image match in height and width to the product boxes together, make it very petite,  one header image  portrait on the left and three landscape product images aligned t it on the right , can you make it much more condensed, like a left justified portrait and then three landscapes on the right directly aligned with the portait, please make it ONE portrait to the left and three small product boxes to the right of it, aligned
    
    make it all aligned to the collection boxes above please, please align the boxs to line up with the two collection boxes above, Please add in a background colour option for the whole block, and make the main picture much smaller and narrower, and the product image much shorter in length, Can you centre all of it and make the product cards align in height with the main image. Please add a lot of padding between the top of this block and the bottom of the block above. Thank you.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cobalt-carousel-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-cobalt-carousel-container-{{ ai_gen_id }} {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-cobalt-carousel-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 8px;
    align-items: start;
  }

  .ai-cobalt-carousel-portrait-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
  }

  .ai-cobalt-carousel-portrait-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-cobalt-carousel-portrait-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-cobalt-carousel-portrait-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-cobalt-carousel-portrait-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cobalt-carousel-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .ai-cobalt-carousel-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-cobalt-carousel-product-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .ai-cobalt-carousel-product-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-cobalt-carousel-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-cobalt-carousel-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cobalt-carousel-product-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cobalt-carousel-product-info-{{ ai_gen_id }} {
    padding: 12px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-cobalt-carousel-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.card_text_color }};
    line-height: 1.3;
  }

  .ai-cobalt-carousel-product-price-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.card_text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-cobalt-carousel-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-cobalt-carousel-portrait-{{ ai_gen_id }} {
      height: 300px;
    }

    .ai-cobalt-carousel-products-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<cobalt-carousel-{{ ai_gen_id }}
  class="ai-cobalt-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-cobalt-carousel-container-{{ ai_gen_id }}">
    <div class="ai-cobalt-carousel-grid-{{ ai_gen_id }}">
      <div class="ai-cobalt-carousel-portrait-{{ ai_gen_id }}">
        {% if block.settings.portrait_image %}
          {% if block.settings.portrait_link %}
            <a
              href="{{ block.settings.portrait_link }}"
              class="ai-cobalt-carousel-portrait-link-{{ ai_gen_id }}"
            >
              <img
                src="{{ block.settings.portrait_image | image_url: width: 400 }}"
                alt="{{ block.settings.portrait_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.portrait_image.width }}"
                height="{{ block.settings.portrait_image.height }}"
                class="ai-cobalt-carousel-portrait-image-{{ ai_gen_id }}"
              >
            </a>
          {% else %}
            <img
              src="{{ block.settings.portrait_image | image_url: width: 400 }}"
              alt="{{ block.settings.portrait_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.portrait_image.width }}"
              height="{{ block.settings.portrait_image.height }}"
              class="ai-cobalt-carousel-portrait-image-{{ ai_gen_id }}"
            >
          {% endif %}
        {% else %}
          <div class="ai-cobalt-carousel-portrait-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-cobalt-carousel-products-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
          %}

          <div class="ai-cobalt-carousel-product-card-{{ ai_gen_id }}">
            {% if product != blank %}
              <a
                href="{{ product.url }}"
                class="ai-cobalt-carousel-product-link-{{ ai_gen_id }}"
              >
                <div class="ai-cobalt-carousel-product-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 400 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      class="ai-cobalt-carousel-product-image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-cobalt-carousel-product-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-cobalt-carousel-product-info-{{ ai_gen_id }}">
                  <h3 class="ai-cobalt-carousel-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <p class="ai-cobalt-carousel-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
                </div>
              </a>
            {% else %}
              <div class="ai-cobalt-carousel-product-link-{{ ai_gen_id }}">
                <div class="ai-cobalt-carousel-product-image-wrapper-{{ ai_gen_id }}">
                  <div class="ai-cobalt-carousel-product-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                </div>
                <div class="ai-cobalt-carousel-product-info-{{ ai_gen_id }}">
                  <h3 class="ai-cobalt-carousel-product-title-{{ ai_gen_id }}">Product {{ i }}</h3>
                  <p class="ai-cobalt-carousel-product-price-{{ ai_gen_id }}">£0.00</p>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</cobalt-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CobaltCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('cobalt-carousel-{{ ai_gen_id }}', CobaltCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cobalt edition carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Portrait image"
    },
    {
      "type": "image_picker",
      "id": "portrait_image",
      "label": "Portrait image"
    },
    {
      "type": "url",
      "id": "portrait_link",
      "label": "Portrait link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Cobalt edition carousel"
    }
  ]
}
{% endschema %}
