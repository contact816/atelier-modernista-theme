{% doc %}
  @prompt
    please create an 8 box image and text grid for Designers make it easy to see, and have all the images be square and the same size. Font Cormorant Garamond please, insert a text box, add 8 boxes as above plus a description and title
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-designer-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-designer-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-designer-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
  }

  .ai-designer-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-designer-grid__image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-designer-grid__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_description_spacing }}px 0;
  }

  .ai-designer-grid__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-designer-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-designer-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-designer-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-designer-grid__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-designer-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-designer-grid__container-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign title_key = 'title_' | append: i
        assign description_key = 'description_' | append: i
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
      %}
      
      <div class="ai-designer-grid__item-{{ ai_gen_id }}">
        <div class="ai-designer-grid__image-wrapper-{{ ai_gen_id }}">
          {% if item_image %}
            <img
              src="{{ item_image | image_url: width: 600 }}"
              alt="{{ item_image.alt | escape }}"
              loading="lazy"
              width="600"
              height="600"
              class="ai-designer-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag }}
          {% endif %}
        </div>
        
        {% if item_title != blank %}
          <h3 class="ai-designer-grid__title-{{ ai_gen_id }}">{{ item_title }}</h3>
        {% endif %}
        
        {% if item_description != blank %}
          <p class="ai-designer-grid__description-{{ ai_gen_id }}">{{ item_description }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

