{% doc %}
  @prompt
    Create a one-column image section with text overlay. It should display an image with the word "Jewellery" in elegant white serif font overlaid on top. The right column should display a second image. Both images should be side by side, equal width, and fill the full height. The section should be responsive and stack on mobile devices. Include settings to customize the images, text, font, and text position., its suppopose to be a collection selected
    
    THERE SHOULD BE SPACE I  BETWEEN THE CARDS AND IT SHOULD BE IN THE MDDLE THE SECTION SHOULD NOT BE FULL WIDTH
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-cards-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-collection-cards-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    height: {{ block.settings.card_height }}px;
  }

  .ai-collection-card-{{ ai_gen_id }} a {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
    display: flex;
    align-items: {{ block.settings.text_vertical_position }};
    justify-content: {{ block.settings.text_horizontal_position }};
    padding: 20px;
  }

  .ai-collection-card-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-style: {{ block.settings.text_font.style }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-cards-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-collection-card-{{ ai_gen_id }} {
      height: {{ block.settings.card_height_mobile }}px;
    }

    .ai-collection-card-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-collection-cards-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-cards-wrapper-{{ ai_gen_id }}">
    <div class="ai-collection-card-{{ ai_gen_id }}">
      {% if block.settings.collection_1 != blank %}
        <a href="{{ block.settings.collection_1.url }}">
          {% if block.settings.collection_1.featured_image %}
            <img
              src="{{ block.settings.collection_1.featured_image | image_url: width: 1200 }}"
              alt="{{ block.settings.collection_1.featured_image.alt | escape }}"
              class="ai-collection-card-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.collection_1.featured_image.width }}"
              height="{{ block.settings.collection_1.featured_image.height }}"
            >
          {% else %}
            <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-collection-card-overlay-{{ ai_gen_id }}">
            {% if block.settings.text_1 != blank %}
              <h2 class="ai-collection-card-text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</h2>
            {% endif %}
          </div>
        </a>
      {% else %}
        <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
          {{ 'collection-1' | placeholder_svg_tag }}
          <div class="ai-collection-empty-state-{{ ai_gen_id }}">
            Next, select a collection
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-collection-card-{{ ai_gen_id }}">
      {% if block.settings.collection_2 != blank %}
        <a href="{{ block.settings.collection_2.url }}">
          {% if block.settings.collection_2.featured_image %}
            <img
              src="{{ block.settings.collection_2.featured_image | image_url: width: 1200 }}"
              alt="{{ block.settings.collection_2.featured_image.alt | escape }}"
              class="ai-collection-card-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.collection_2.featured_image.width }}"
              height="{{ block.settings.collection_2.featured_image.height }}"
            >
          {% else %}
            <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
              {{ 'collection-2' | placeholder_svg_tag }}
            </div>
          {% endif %}
          <div class="ai-collection-card-overlay-{{ ai_gen_id }}">
            {% if block.settings.text_2 != blank %}
              <h2 class="ai-collection-card-text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</h2>
            {% endif %}
          </div>
        </a>
      {% else %}
        <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
          {{ 'collection-2' | placeholder_svg_tag }}
          <div class="ai-collection-empty-state-{{ ai_gen_id }}">
            Next, select a collection
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection cards",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Card height",
      "default": 500
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Card height on mobile",
      "default": 400
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Left card"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection"
    },
    {
      "type": "inline_richtext",
      "id": "text_1",
      "label": "Text",
      "default": "Jewellery"
    },
    {
      "type": "header",
      "content": "Right card"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Collection"
    },
    {
      "type": "inline_richtext",
      "id": "text_2",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Font",
      "default": "serif"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 16,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 48
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_horizontal_position",
      "label": "Horizontal position",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_vertical_position",
      "label": "Vertical position",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Collection cards"
    }
  ]
}
{% endschema %}
