{% doc %}
  @prompt
    Can you create a centre 8 card grid with a small image and text in Cormorant Garamond, as a Designers page. Big padding either side, add a text box with each image please and set up controls for columns, width etc
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.side_padding }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-designer-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-designer-grid-heading-{{ ai_gen_id }} {
    text-align: center;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-designer-grid-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-designer-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ai-designer-card-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-designer-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-designer-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-designer-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-designer-card-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-designer-card-name-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-designer-card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.description_spacing }}px;
    font-style: italic;
  }

  .ai-designer-card-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-designer-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-designer-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.side_padding | times: 0.5 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-designer-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-designer-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-designer-card-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_size | times: 0.9 }}px;
    }

    .ai-designer-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-designer-card-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<designer-grid-{{ ai_gen_id }} class="ai-designer-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-designer-grid-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-designer-grid-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-designer-grid-wrapper-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign image_key = 'designer_' | append: i | append: '_image'
          assign name_key = 'designer_' | append: i | append: '_name'
          assign title_key = 'designer_' | append: i | append: '_title'
          assign description_key = 'designer_' | append: i | append: '_description'
          
          assign designer_image = block.settings[image_key]
          assign designer_name = block.settings[name_key]
          assign designer_title = block.settings[title_key]
          assign designer_description = block.settings[description_key]
        %}

        <div class="ai-designer-card-{{ ai_gen_id }}">
          <div class="ai-designer-card-image-wrapper-{{ ai_gen_id }}">
            {% if designer_image %}
              <img
                src="{{ designer_image | image_url: width: 600 }}"
                alt="{{ designer_name | escape }}"
                loading="lazy"
                width="600"
                height="600"
                class="ai-designer-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-designer-card-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-designer-card-content-{{ ai_gen_id }}">
            {% if designer_name != blank %}
              <h3 class="ai-designer-card-name-{{ ai_gen_id }}">{{ designer_name }}</h3>
            {% endif %}

            {% if designer_title != blank %}
              <p class="ai-designer-card-title-{{ ai_gen_id }}">{{ designer_title }}</p>
            {% endif %}

            {% if designer_description != blank %}
              <div class="ai-designer-card-description-{{ ai_gen_id }}">{{ designer_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</designer-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class DesignerGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('designer-grid-{{ ai_gen_id }}', DesignerGrid{{ ai_gen_id }});
  })();
</script>

