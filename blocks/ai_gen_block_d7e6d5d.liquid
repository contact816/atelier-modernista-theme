{% doc %}
  @prompt
    8 blocks with small image, title and descriptor, plus a large header box above,, and a space for the logo above that, in Cormorant Garamond font please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
  }

  .ai-designer-grid__logo-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-designer-grid__logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
  }

  .ai-designer-grid__logo-placeholder-{{ ai_gen_id }} {
    display: inline-block;
    background-color: #f4f4f4;
    padding: 20px 40px;
    border-radius: 8px;
  }

  .ai-designer-grid__logo-placeholder-{{ ai_gen_id }} svg {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    max-height: 100px;
  }

  .ai-designer-grid__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    padding: {{ block.settings.header_padding }}px;
    border-radius: {{ block.settings.header_border_radius }}px;
    margin-bottom: 40px;
    text-align: center;
  }

  .ai-designer-grid__header-title-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.header_title_size }}px;
    color: {{ block.settings.header_text_color }};
    margin: 0 0 15px;
    font-weight: 600;
  }

  .ai-designer-grid__header-description-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.header_description_size }}px;
    color: {{ block.settings.header_text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-designer-grid__items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-designer-grid__item-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-designer-grid__item-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 15px;
    border-radius: {{ block.settings.item_border_radius }}px;
    overflow: hidden;
  }

  .ai-designer-grid__item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-designer-grid__item-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-designer-grid__item-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-designer-grid__item-title-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.item_title_size }}px;
    color: {{ block.settings.item_text_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-designer-grid__item-description-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.item_description_size }}px;
    color: {{ block.settings.item_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-designer-grid__items-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-designer-grid__items-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-designer-grid__header-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.header_title_size }}px * 0.8);
    }

    .ai-designer-grid__header-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.header_description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-designer-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-designer-grid__logo-{{ ai_gen_id }}">
    {% if block.settings.logo %}
      <img
        src="{{ block.settings.logo | image_url: width: 600 }}"
        alt="{{ block.settings.logo.alt | escape }}"
        width="{{ block.settings.logo.width }}"
        height="{{ block.settings.logo.height }}"
        loading="lazy"
      >
    {% else %}
      <div class="ai-designer-grid__logo-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-designer-grid__header-{{ ai_gen_id }}">
    {% if block.settings.header_title != blank %}
      <h2 class="ai-designer-grid__header-title-{{ ai_gen_id }}">{{ block.settings.header_title }}</h2>
    {% endif %}
    {% if block.settings.header_description != blank %}
      <div class="ai-designer-grid__header-description-{{ ai_gen_id }}">{{ block.settings.header_description }}</div>
    {% endif %}
  </div>

  <div class="ai-designer-grid__items-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% liquid
        assign image_key = 'item_' | append: i | append: '_image'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        
        assign item_image = block.settings[image_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
      %}
      
      <div class="ai-designer-grid__item-{{ ai_gen_id }}">
        <div class="ai-designer-grid__item-image-{{ ai_gen_id }}">
          {% if item_image %}
            <img
              src="{{ item_image | image_url: width: 400 }}"
              alt="{{ item_image.alt | escape }}"
              width="{{ item_image.width }}"
              height="{{ item_image.height }}"
              loading="lazy"
            >
          {% else %}
            <div class="ai-designer-grid__item-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        {% if item_title != blank %}
          <h3 class="ai-designer-grid__item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
        {% endif %}
        
        {% if item_description != blank %}
          <div class="ai-designer-grid__item-description-{{ ai_gen_id }}">{{ item_description }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

