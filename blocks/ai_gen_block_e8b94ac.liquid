{% doc %}
  @prompt
    create a small elegant horizontal menu under the main text, in cormorant garamond, for the other collections with links and padding options
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-menu-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-collection-menu__wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    flex-wrap: wrap;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-collection-menu__item-{{ ai_gen_id }} {
    font-family: 'Cormorant Garamond', serif;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-collection-menu__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    position: relative;
    transition: color 0.3s ease;
    display: inline-block;
  }

  .ai-collection-menu__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
  }

  {% if block.settings.show_underline %}
    .ai-collection-menu__link-{{ ai_gen_id }}::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 1px;
      background-color: {{ block.settings.text_hover_color }};
      transition: width 0.3s ease;
    }

    .ai-collection-menu__link-{{ ai_gen_id }}:hover::after {
      width: 100%;
    }
  {% endif %}

  .ai-collection-menu__separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-menu__wrapper-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
      gap: {{ block.settings.mobile_item_spacing }}px;
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-collection-menu__item-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }

    .ai-collection-menu__separator-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-menu-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-collection-menu__wrapper-{{ ai_gen_id }}" aria-label="Collection navigation">
    {% for i in (1..6) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign label_key = 'collection_' | append: i | append: '_label'
        assign collection = block.settings[collection_key]
        assign label = block.settings[label_key]
      %}

      {% if collection != blank %}
        {% if forloop.first == false and block.settings.show_separator %}
          <span class="ai-collection-menu__separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator_character }}</span>
        {% endif %}

        <div class="ai-collection-menu__item-{{ ai_gen_id }}">
          <a href="{{ collection.url }}" class="ai-collection-menu__link-{{ ai_gen_id }}">
            {% if label != blank %}
              {{ label }}
            {% else %}
              {{ collection.title }}
            {% endif %}
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </nav>
</div>

