{% doc %}
  @prompt
    A single product feature box, aligned with the collection cards, and called Designer Edit, please, connect to a prouct, can you make it very narrow and align it with the collections cards below please, can you remove the top button, and make the box wider, and align exactly with the section below, centre it on the page, could you please add an Alignment button, can you give choices for image size please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-designer-edit-container-{{ ai_gen_id }} {
    display: flex;
    width: 100%;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.alignment == 'right' %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-designer-edit-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-designer-edit-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.corner_radius }}px;
    overflow: hidden;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    {% if block.settings.border_thickness > 0 %}
      border: {{ block.settings.border_thickness }}px solid rgba({{ block.settings.text_color | color_extract: 'red' }}, {{ block.settings.text_color | color_extract: 'green' }}, {{ block.settings.text_color | color_extract: 'blue' }}, {{ block.settings.border_opacity | divided_by: 100.0 }});
    {% endif %}
    {% if block.settings.shadow_opacity > 0 %}
      box-shadow: {{ block.settings.shadow_horizontal_offset }}px {{ block.settings.shadow_vertical_offset }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .ai-designer-edit-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    {% if block.settings.shadow_opacity > 0 %}
      box-shadow: {{ block.settings.shadow_horizontal_offset }}px {{ block.settings.shadow_vertical_offset | plus: 4 }}px {{ block.settings.shadow_blur | plus: 5 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 1.2 }});
    {% endif %}
  }

  .ai-designer-edit-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    {% if block.settings.image_padding > 0 %}
      padding: {{ block.settings.image_padding }}px;
    {% endif %}
  }

  .ai-designer-edit-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    {% if block.settings.image_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.image_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.image_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.image_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% elsif block.settings.image_ratio == 'adapt' %}
      aspect-ratio: 1 / 1;
    {% endif %}
  }

  .ai-designer-edit-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-designer-edit-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-designer-edit-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-designer-edit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }

  .ai-designer-edit-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
    margin: 0;
    flex-grow: 1;
  }

  .ai-designer-edit-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-designer-edit-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_corner_radius }}px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    transition: background-color 0.3s ease;
    margin-top: 8px;
    {% if block.settings.text_alignment == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-designer-edit-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-designer-edit-container-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-designer-edit-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

{% liquid
  assign product = block.settings.product
%}

<div class="ai-designer-edit-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-designer-edit-{{ ai_gen_id }}">
    {% if product != blank %}
      <a href="{{ product.url }}" class="ai-designer-edit-card-{{ ai_gen_id }}">
    {% else %}
      <div class="ai-designer-edit-card-{{ ai_gen_id }}">
    {% endif %}
      
      <div class="ai-designer-edit-image-wrapper-{{ ai_gen_id }}">
        {% if product != blank and product.featured_image %}
          <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  srcset="{{ product.featured_image | image_url: width: 200 }} 200w,
                          {{ product.featured_image | image_url: width: 400 }} 400w,
                          {{ product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) calc(50vw - 20px), 400px"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-carousel-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="{{ 400 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
        {% else %}
          <div class="ai-designer-edit-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
            <div class="ai-designer-edit-empty-state-{{ ai_gen_id }}">
              Next, select a product
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-designer-edit-content-{{ ai_gen_id }}">
        {% if product != blank %}
          <h3 class="ai-designer-edit-title-{{ ai_gen_id }}">{{ product.title }}</h3>

          {% if block.settings.show_description and product.description != blank %}
            <div class="ai-designer-edit-description-{{ ai_gen_id }}">
              {{ product.description | strip_html | truncate: 120 }}
            </div>
          {% endif %}

          {% if block.settings.show_price %}
            <div class="ai-designer-edit-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
          {% endif %}

          {% if block.settings.button_text != blank %}
            <span class="ai-designer-edit-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </span>
          {% endif %}
        {% else %}
          <h3 class="ai-designer-edit-title-{{ ai_gen_id }}">Designer Edit</h3>
          <div class="ai-designer-edit-description-{{ ai_gen_id }}">
            Select a product to feature
          </div>
        {% endif %}
      </div>

    {% if product != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Designer Edit",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "image_padding",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Image padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#334fb4"
    },
    {
      "type": "range",
      "id": "button_corner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button corner radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Block alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Content padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Border opacity",
      "default": 10
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Shadow opacity",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_horizontal_offset",
      "min": -40,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Shadow horizontal offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "shadow_vertical_offset",
      "min": -40,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Shadow vertical offset",
      "default": 4
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 5
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 14
    },
    {
      "type": "range",
      "id": "price_size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Price size",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Designer Edit"
    }
  ]
}
{% endschema %}
