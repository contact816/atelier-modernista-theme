{% doc %}
  @prompt
    4 collection cards and one menu , make five cards, add one more collection card please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-menu-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-collection-menu-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-collection-menu-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.menu_spacing }}px;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-collection-card-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-card-content-{{ ai_gen_id }} {
    padding: 16px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-collection-card-count-{{ ai_gen_id }} {
    margin: 8px 0 0;
    font-size: {{ block.settings.count_size }}px;
    color: {{ block.settings.count_color }};
  }

  .ai-collection-card-empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    background-color: #f9f9f9;
    border-radius: {{ block.settings.card_border_radius }}px;
    color: #999;
    font-size: 14px;
  }

  .ai-menu-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.menu_background }};
    border-radius: {{ block.settings.menu_border_radius }}px;
    padding: {{ block.settings.menu_padding }}px;
  }

  .ai-menu-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.menu_item_gap }}px;
    justify-content: {{ block.settings.menu_alignment }};
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-menu-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-menu-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    text-decoration: none;
    color: {{ block.settings.menu_text_color }};
    font-size: {{ block.settings.menu_text_size }}px;
    border-radius: {{ block.settings.menu_item_radius }}px;
    transition: all 0.3s ease;
    background-color: {{ block.settings.menu_item_background }};
  }

  .ai-menu-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.menu_item_hover_background }};
    color: {{ block.settings.menu_text_hover_color }};
  }

  .ai-menu-empty-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
    font-style: italic;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-menu-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-menu-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-menu-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-menu-link-{{ ai_gen_id }} {
      text-align: center;
    }
  }
{% endstyle %}

<collection-menu-{{ ai_gen_id }} class="ai-collection-menu-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-menu-container-{{ ai_gen_id }}">
    <div class="ai-collection-menu-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign collection_key = 'collection_' | append: i
          assign collection = block.settings[collection_key]
        %}

        {% if collection != blank %}
          <div class="ai-collection-card-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-collection-card-link-{{ ai_gen_id }}">
              <div class="ai-collection-card-image-wrapper-{{ ai_gen_id }}">
                {% if collection.featured_image %}
                  <img
                    src="{{ collection.featured_image | image_url: width: 600 }}"
                    alt="{{ collection.featured_image.alt | escape }}"
                    class="ai-collection-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% else %}
                  <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-collection-card-content-{{ ai_gen_id }}">
                <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                {% if block.settings.show_product_count %}
                  <p class="ai-collection-card-count-{{ ai_gen_id }}">{{ collection.products_count }} products</p>
                {% endif %}
              </div>
            </a>
          </div>
        {% else %}
          <div class="ai-collection-card-{{ ai_gen_id }}">
            <div class="ai-collection-card-empty-{{ ai_gen_id }}">
              Select a collection for card {{ i }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="ai-menu-wrapper-{{ ai_gen_id }}">
      {% if linklists[block.settings.menu].links.size > 0 %}
        <ul class="ai-menu-{{ ai_gen_id }}">
          {% for link in linklists[block.settings.menu].links %}
            <li class="ai-menu-item-{{ ai_gen_id }}">
              <a href="{{ link.url }}" class="ai-menu-link-{{ ai_gen_id }}">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <div class="ai-menu-empty-{{ ai_gen_id }}">
          Select a menu to display navigation links
        </div>
      {% endif %}
    </div>
  </div>
</collection-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionMenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('collection-menu-{{ ai_gen_id }}', CollectionMenu{{ ai_gen_id }});
  })();
</script>

