{% comment %}
  sections/am-hero-carousel.liquid
  AM Homepage Hero Carousel
  — Up to 5 slides via schema blocks
  — First slide (and slide 1 on every return) lingers longer
  — Crossfade transition, dot nav, prev/next arrows
  — Pauses on hover; arrows hidden on mobile
  — root font-size 10px throughout, all sizes in px
{% endcomment %}

<div class="am-carousel"
     id="am-carousel-{{ section.id }}"
     data-first-duration="{{ section.settings.first_slide_duration | times: 1000 }}"
     data-duration="{{ section.settings.slide_duration | times: 1000 }}"
     style="--am-ch: {{ section.settings.carousel_height }}px; --am-chm: {{ section.settings.mobile_height }}px; --am-cw: {{ section.settings.carousel_width }}%;">

  <div class="am-carousel__track">
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}
        {%- assign overlay_dec = block.settings.overlay_opacity | divided_by: 100.0 -%}
        {%- if forloop.first -%}
          {%- assign img_loading = 'eager' -%}
        {%- else -%}
          {%- assign img_loading = 'lazy' -%}
        {%- endif -%}
        <div class="am-carousel__slide{% if forloop.first %} is-active{% endif %}"
             data-index="{{ forloop.index0 }}"
             {{ block.shopify_attributes }}>

          <div class="am-carousel__image-wrap">
            {{- block.settings.image
              | image_url: width: 2000
              | image_tag:
                loading: img_loading,
                widths: '375, 750, 1100, 1500, 2000',
                sizes: '100vw',
                class: 'am-carousel__img',
                fetchpriority: forloop.first | default: 'auto' -}}
          </div>

          <div class="am-carousel__overlay" style="opacity: {{ overlay_dec }};"></div>

          <div class="am-carousel__content am-carousel__content--{{ block.settings.text_color | default: 'light' }}">
            {%- if block.settings.heading != blank -%}
              <h2 class="am-carousel__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="am-carousel__sub">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}"
                 class="am-carousel__cta">
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="am-carousel__dots" role="tablist" aria-label="Carousel slides"></div>

    <button class="am-carousel__arrow am-carousel__arrow--prev" aria-label="Previous slide">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M14 5L8 11L14 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button class="am-carousel__arrow am-carousel__arrow--next" aria-label="Next slide">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M8 5L14 11L8 17" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {%- endif -%}

</div>

<style>
/* ── AM Hero Carousel ─────────────────────────────────────── */
.am-hero-carousel-section {
  background: #fdf6e3;
  padding: 40px 0;
}

.am-carousel {
  position: relative;
  width: var(--am-cw, 70%);
  margin: 0 auto;
  height: var(--am-ch, 700px);
  overflow: hidden;
  background: #fdf6e3;
  user-select: none;
}

.am-carousel__track {
  position: relative;
  width: 100%;
  height: 100%;
}

.am-carousel__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1.1s ease;
  pointer-events: none;
  will-change: opacity;
}

.am-carousel__slide.is-active {
  opacity: 1;
  pointer-events: auto;
  z-index: 1;
}

.am-carousel__image-wrap {
  position: absolute;
  inset: 0;
}

.am-carousel__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.am-carousel__overlay {
  position: absolute;
  inset: 0;
  background: #000;
  z-index: 1;
  pointer-events: none;
}

/* ── Content ───────────────────────────────────────────────── */
.am-carousel__content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  text-align: center;
  padding: 40px 32px 100px;
  z-index: 2;
}

.am-carousel__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 62px;
  font-weight: 300;
  letter-spacing: 0.04em;
  line-height: 1.08;
  margin: 0 0 20px;
  max-width: 820px;
}

.am-carousel__sub {
  font-family: 'Jost', Arial, sans-serif;
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin: 0 0 36px;
  max-width: 480px;
  line-height: 1.7;
}

.am-carousel__cta {
  display: inline-block;
  font-family: 'Jost', Arial, sans-serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 15px 36px;
  border: 1px solid currentColor;
  transition: background 0.35s ease, color 0.35s ease;
}

/* Light text (cream on dark) */
.am-carousel__content--light .am-carousel__heading,
.am-carousel__content--light .am-carousel__sub,
.am-carousel__content--light .am-carousel__cta { color: #fdf6e3; }

.am-carousel__content--light .am-carousel__cta:hover {
  background: #fdf6e3;
  color: #1a1a1a;
}

/* Dark text (dark on light) */
.am-carousel__content--dark .am-carousel__heading,
.am-carousel__content--dark .am-carousel__sub,
.am-carousel__content--dark .am-carousel__cta { color: #1a1a1a; }

.am-carousel__content--dark .am-carousel__cta:hover {
  background: #fdf6e3;
  color: #fdf6e3;
}

/* ── Arrows ────────────────────────────────────────────────── */
.am-carousel__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 14px;
  color: #fdf6e3;
  opacity: 0.55;
  transition: opacity 0.25s;
  line-height: 0;
}

.am-carousel__arrow:hover { opacity: 1; }
.am-carousel__arrow--prev { left: 20px; }
.am-carousel__arrow--next { right: 20px; }

/* ── Dots ──────────────────────────────────────────────────── */
.am-carousel__dots {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 10;
}

.am-carousel__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(253, 246, 227, 0.4);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background 0.35s, transform 0.35s;
}

.am-carousel__dot.is-active {
  background: #fdf6e3;
  transform: scale(1.5);
}

/* ── Mobile ────────────────────────────────────────────────── */
@media (max-width: 749px) {
  .am-hero-carousel-section {
  background: #fdf6e3;
  padding: 40px 0;
}

.am-carousel { height: var(--am-chm, 520px); }
  .am-carousel__heading { font-size: 36px; }
  .am-carousel__sub { font-size: 11px; }
  .am-carousel__cta { padding: 13px 28px; font-size: 10px; }
  .am-carousel__arrow { display: none; }
}
</style>

<script>
(function() {
  'use strict';

  const carousel = document.getElementById('am-carousel-{{ section.id }}');
  if (!carousel) return;

  const slides    = Array.from(carousel.querySelectorAll('.am-carousel__slide'));
  const dotsWrap  = carousel.querySelector('.am-carousel__dots');
  if (slides.length <= 1) return;

  const FIRST_DURATION = parseInt(carousel.dataset.firstDuration, 10) || 7000;
  const DURATION       = parseInt(carousel.dataset.duration, 10) || 4000;

  let current = 0;
  let timer   = null;
  let dots    = [];

  /* ── Build dots ─────────────────────────────────────────── */
  slides.forEach(function(_, i) {
    const btn = document.createElement('button');
    btn.className   = 'am-carousel__dot' + (i === 0 ? ' is-active' : '');
    btn.setAttribute('role', 'tab');
    btn.setAttribute('aria-label', 'Slide ' + (i + 1));
    btn.addEventListener('click', function() { goTo(i); });
    dotsWrap.appendChild(btn);
    dots.push(btn);
  });

  /* ── Navigation ─────────────────────────────────────────── */
  function goTo(index) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    current = ((index % slides.length) + slides.length) % slides.length;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    schedule();
  }

  function schedule() {
    clearTimeout(timer);
    /* Slide 0 always gets the longer duration */
    var d = (current === 0) ? FIRST_DURATION : DURATION;
    timer = setTimeout(function() { goTo(current + 1); }, d);
  }

  carousel.querySelector('.am-carousel__arrow--prev')
    .addEventListener('click', function() { goTo(current - 1); });
  carousel.querySelector('.am-carousel__arrow--next')
    .addEventListener('click', function() { goTo(current + 1); });

  /* Pause on hover / focus */
  carousel.addEventListener('mouseenter', function() { clearTimeout(timer); });
  carousel.addEventListener('mouseleave', schedule);
  carousel.addEventListener('focusin',    function() { clearTimeout(timer); });
  carousel.addEventListener('focusout',   schedule);

  /* Touch swipe */
  var touchX = null;
  carousel.addEventListener('touchstart', function(e) {
    touchX = e.changedTouches[0].clientX;
  }, { passive: true });
  carousel.addEventListener('touchend', function(e) {
    if (touchX === null) return;
    var diff = e.changedTouches[0].clientX - touchX;
    if (Math.abs(diff) > 40) { diff < 0 ? goTo(current + 1) : goTo(current - 1); }
    touchX = null;
  }, { passive: true });

  /* Kick off — first slide gets its long look */
  schedule();
})();
</script>

{% schema %}
{
  "name": "AM Hero Carousel",
  "tag": "section",
  "class": "am-hero-carousel-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "range",
      "id": "carousel_height",
      "min": 400,
      "max": 900,
      "step": 25,
      "unit": "px",
      "label": "Desktop height",
      "default": 700
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 650,
      "step": 25,
      "unit": "px",
      "label": "Mobile height",
      "default": 500
    },
    {
      "type": "range",
      "id": "carousel_width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Width",
      "default": 70
    },
    {
      "type": "header",
      "content": "Timing"
    },
    {
      "type": "range",
      "id": "first_slide_duration",
      "min": 4,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Slide 1 duration (first impression)",
      "default": 7
    },
    {
      "type": "range",
      "id": "slide_duration",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "All other slides duration",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "Text colour",
          "options": [
            { "value": "light", "label": "Light — cream on dark" },
            { "value": "dark",  "label": "Dark — charcoal on light" }
          ],
          "default": "light"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 70,
          "step": 5,
          "unit": "%",
          "label": "Dark overlay opacity",
          "default": 25
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AM Hero Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
