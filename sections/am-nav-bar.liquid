<style>
  .am-header { font-family: 'Jost', sans-serif; }

  /* Announcement bar */
  .am-header__announcement {
    background-color: #1f2c8a;
    color: #fdf6e3;
    text-align: center;
    padding: 10px 1rem;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .am-announcement-link {
    color: #fdf6e3;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin: 0 0.3rem;
    transition: opacity 0.15s ease;
  }
  .am-announcement-link:hover {
    opacity: 0.75;
  }

  /* Nav bar */
  .am-header__nav-bar {
    background-color: #fdf6e3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    height: 72px;
    position: relative;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  /* Left nav */
  .am-header__left {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .am-header__left a {
    font-family: var(--am-serif);
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: #1a1a1a;
    transition: color 0.15s;
  }
  .am-header__left a:hover { color: #1f2c8a; }

  /* Logo banner (own row, below nav bar) */
  .am-header__logo-banner {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.5rem 0;
    background-color: #fdf6e3;
  }
 .am-header__logo-banner img {
  height: 22rem;   /* ~320px — big, closer to a hero-style logo */
  width: auto;
  display: block;
}

  /* Right icons */
  .am-header__right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .am-header__right a {
    font-family: var(--am-serif);
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    color: #1a1a1a;
    transition: color 0.15s;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .am-header__right a:hover { color: #1f2c8a; }

  /* Cart bubble */
  .am-cart-count {
    background: #1f2c8a;
    color: #fff;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    font-size: 0.65rem;
    gap: 0.4rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Collections dropdown toggle */
  .am-header__dd {
    position: relative;
  }
  .am-header__dd-toggle {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    align-items: center;
    gap: 5px;
    font-family: var(--am-serif) !important;
    font-size: 1.4rem;
    font-weight: 400 !important;
    letter-spacing: 0.15em;
    color: #1a1a1a;
    transition: color 0.15s;
  }
  .am-header__dd-toggle:hover { color: #1f2c8a; }
  .am-dd-chevron {
    width: 5px;
    height: 5px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    display: inline-block;
    margin-top: -2px;
  }

  /* Sidebar */
  .am-sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .am-sidebar-overlay.open { opacity: 1; visibility: visible; }
  .am-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100%;
    width: 320px;
    max-width: 85vw;
    background: #fdf6e3;
    z-index: 999;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    padding: 3rem 2.5rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  .am-sidebar.open { transform: translateX(0); }
  .am-sidebar__close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: #3C3228;
  }
  .am-sidebar__close svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }
  .am-sidebar__heading {
    font-family: 'Jost', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #6B5B4E;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(60,50,40,0.15);
  }
  .am-sidebar__link {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: #3C3228;
    text-decoration: none;
    padding: 0.4rem 0;
    transition: color 0.15s, padding-left 0.15s;
    line-height: 1.3;
  }
  .am-sidebar__link:hover { color: #1f2c8a; padding-left: 0.5rem; }
  .am-sidebar__divider {
    border: none;
    border-top: 1px solid rgba(60,50,40,0.15);
    margin: 1rem 0;
  }

  .am-header-section { padding: 0 !important; margin: 0 !important; }

  /* ── HAMBURGER (hidden on desktop) ── */
  .am-header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .am-header__hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #1a1a1a;
    transition: background 0.15s;
  }
  .am-header__hamburger:hover span { background: #1f2c8a; }

  /* ── MOBILE ── */
  @media screen and (max-width: 749px) {
    .am-header__nav-bar {
      padding: 0 1.25rem;
      min-height: 60px;
      height: auto;
      justify-content: space-between;
    }
    .am-header__hamburger { display: flex; }
    .am-header__left { display: none; }
    .am-header__logo-banner { padding: 1.5rem 0; }
    .am-header__logo-banner img { height: 3.5rem; }
    .am-header__right { gap: 0; }
    .am-header__right a[href*="search"],
    .am-header__right a[href*="account"] { display: none; }
    .am-header__right a[href*="cart"] {
      font-size: 1.2rem;
      letter-spacing: 0.06em;
    }
    .am-header__announcement {
      font-size: 0.95rem;
      letter-spacing: 0.12em;
      padding: 8px 1rem;
    }
  }

  /* Neutralise the leftover hidden Dawn header */
  #shopify-section-sections--30221351354705__header {
    display: none !important;
  }
</style>

<!-- Announcement bar -->
<div class="am-header__announcement">
  FREE UK DELIVERY FOR ATELIER CIRCLE MEMBERS ·
  <a href="/pages/atelier-circle" class="am-announcement-link">
    JOIN HERE
  </a>
  ·
</div>

<!-- Nav bar -->
<div class="am-header__nav-bar am-header">

  <!-- Hamburger (mobile only) -->
  <button class="am-header__hamburger" aria-label="Open menu"
    onclick="document.getElementById('am-sidebar').classList.add('open');document.getElementById('am-overlay').classList.add('open')">
    <span></span><span></span><span></span>
  </button>

  <!-- Left nav links -->
  <div class="am-header__left">
    {%- for link in section.settings.menu.links -%}
      {%- if link.links != blank -%}
        <div class="am-header__dd">
          <button class="am-header__dd-toggle" onclick="document.getElementById('am-sidebar').classList.toggle('open');document.getElementById('am-overlay').classList.toggle('open')">
            {{ link.title }}&nbsp;<span class="am-dd-chevron"></span>
          </button>
        </div>
      {%- else -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <!-- Right icons -->
  <div class="am-header__right">
    <a href="{{ routes.search_url }}">Search</a>
    <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">Account</a>
    <a href="{{ routes.cart_url }}">
      Bag
      <span class="am-cart-count">{{ cart.item_count }}</span>
    </a>
  </div>

</div>

<!-- Logo banner (own row, below nav bar) -->
<a href="{{ routes.root_url }}" class="am-header__logo-banner">
  {%- if section.settings.logo != blank -%}
    {{ section.settings.logo | image_url: width: 400 | image_tag: loading: 'eager', alt: shop.name }}
  {%- else -%}
    <span style="font-family: var(--am-serif); font-size: 1.8rem; letter-spacing: 0.1em;">{{ shop.name }}</span>
  {%- endif -%}
</a>

<!-- Sidebar overlay -->
<div class="am-sidebar-overlay" id="am-overlay" onclick="document.getElementById('am-sidebar').classList.remove('open');this.classList.remove('open')"></div>

<!-- Sidebar -->
<div class="am-sidebar" id="am-sidebar">
  <button class="am-sidebar__close" onclick="document.getElementById('am-sidebar').classList.remove('open');document.getElementById('am-overlay').classList.remove('open')" aria-label="Close menu">
    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  {%- for link in section.settings.menu.links -%}
    {%- if link.links != blank -%}
      <p class="am-sidebar__heading">{{ link.title }}</p>
      {%- for childlink in link.links -%}
        <a class="am-sidebar__link" href="{{ childlink.url }}">{{ childlink.title }}</a>
      {%- endfor -%}
      <hr class="am-sidebar__divider">
    {%- endif -%}
  {%- endfor -%}

  {%- for link in section.settings.menu.links -%}
    {%- unless link.links != blank -%}
      <a class="am-sidebar__link" href="{{ link.url }}">{{ link.title }}</a>
    {%- endunless -%}
  {%- endfor -%}
  {%- comment -%} Mobile-only extras {%- endcomment -%}
  <hr class="am-sidebar__divider">
  <a class="am-sidebar__link" href="{{ routes.search_url }}">Search</a>
  <a class="am-sidebar__link" href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}">Account</a>
</div>

{% schema %}
{
  "name": "AM Nav Bar",
  "tag": "section",
  "class": "section am-header-section",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "FREE UK DELIVERY ON ALL ORDERS ·"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "AM Nav Bar"
    }
  ]
}
{% endschema %}
