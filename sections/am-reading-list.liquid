{% if use_bulk_import %}
<script>
  (function () {
    var container = document.getElementById('AMReadingBulkGrid-{{ section.id }}');
    var dataEl = document.getElementById('AMReadingBulkLinks-{{ section.id }}');
    var nav = document.getElementById('AMReadingNav-{{ section.id }}');
    if (!container || !dataEl) return;

    var hideTitles = container.getAttribute('data-hide-titles') === 'true';

    var raw;
    try {
      raw = JSON.parse(dataEl.textContent);
    } catch (e) {
      return;
    }

    var lines = raw
  .split(/\r?\n/)
  .map(function (l) { return l.trim(); })
  .filter(Boolean);

    function slugify(value) {
      return value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/&/g, ' and ').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }

    function extractIsbn(url) {
      // Anchored to the end of the URL so an affiliate ID earlier in the
      // path (e.g. /a/17748/9783836527835) can never be mistaken for it.
      var match = url.match(/(\d{9,12}[\dXx])\/?(?:[?#].*)?$/);
      return match ? match[1] : null;
    }

    var entries = [];

lines.forEach(function (line) {

  /* Subject heading */

  if (line.indexOf('##') === 0) {

    var headingTitle = line.replace(/^##\s*/, '').trim();
    entries.push({
      type: 'heading',
      title: headingTitle,
      id: 'am-reading-{{ section.id }}-' + slugify(headingTitle)
    });

    return;
  }

  /* Book */

  var parts = line.split('|').map(function (p) {
    return p.trim();
  });

  entries.push({
    type: 'book',
    link: parts[0],
    manualCover: parts[1] || null,
    manualTitle: parts[2] || null,
    isbn: extractIsbn(parts[0])
  });

});

    var showBasketBtn = container.getAttribute('data-show-basket-btn') === 'true';
    var fallbackCount = 0;

    function tryGoogleBooksCover(entry) {
      var delay = fallbackCount * 400;
      fallbackCount++;
      setTimeout(function () {
        fetch('https://www.googleapis.com/books/v1/volumes?q=isbn:' + entry.isbn)
          .then(function (res) { return res.ok ? res.json() : null; })
          .then(function (data) {
            var item = data && data.items && data.items[0];
            var links = item && item.volumeInfo && item.volumeInfo.imageLinks;
            var cover = links && (links.thumbnail || links.smallThumbnail);
            if (!cover) return;
            entry.img.onload = function () {
              entry.img.style.display = '';
            };
            entry.img.onerror = null;
            entry.img.src = cover.replace('http://', 'https://');
          })
          .catch(function () {});
      }, delay);
    }

    entries.forEach(function (entry) {
      if (entry.type === 'heading') {

  var heading = document.createElement('div');
  var headingTitle = document.createElement('h2');
  heading.className = 'am-reading__subject-heading';
  heading.id = entry.id;
  headingTitle.textContent = entry.title;
  heading.appendChild(headingTitle);
  container.appendChild(heading);

  if (nav) {
    var li = document.createElement('li');
    var navLink = document.createElement('a');
    navLink.href = '#' + entry.id;
    navLink.textContent = entry.title;
    li.appendChild(navLink);
    nav.appendChild(li);
    nav.classList.add('is-ready');
  }

  return;
}
      var article = document.createElement('article');
      article.className = 'am-reading__card';

      var coverLink = document.createElement('a');
      coverLink.className = 'am-reading__cover-link';
      coverLink.href = entry.link;
      coverLink.target = '_blank';
      coverLink.rel = 'noopener sponsored';

      var img = document.createElement('img');
      img.className = 'am-reading__cover';
      img.alt = 'Book cover';
      img.style.display = 'none';

      coverLink.appendChild(img);
      article.appendChild(coverLink);

      var meta = document.createElement('div');
      meta.className = 'am-reading__meta';
      if (hideTitles) meta.style.display = 'none';

      var h3 = document.createElement('h3');
      h3.className = 'am-reading__book-title';
      var titleLink = document.createElement('a');
      titleLink.className = 'am-reading__book-link';
      titleLink.href = entry.link;
      titleLink.target = '_blank';
      titleLink.rel = 'noopener sponsored';
      titleLink.textContent = entry.manualTitle || 'View on Bookshop.org';
      h3.appendChild(titleLink);
      meta.appendChild(h3);
      article.appendChild(meta);

      if (showBasketBtn) {
        var basketBtn = document.createElement('a');
        basketBtn.className = 'am-reading__basket-btn';
        basketBtn.href = entry.link;
        basketBtn.target = '_blank';
        basketBtn.rel = 'noopener sponsored';
        basketBtn.textContent = 'Add to My Library';
        meta.appendChild(basketBtn);
      }

      container.appendChild(article);

      entry.img = img;
      entry.titleLink = titleLink;
      entry.meta = meta;

      // Covers load as plain images, independent of the metadata lookup
      // below and not subject to the same API rate limits. Bookshop.org's
      // own cover CDN is tried first since it has the best coverage for
      // their catalogue; Open Library and Google Books are fallbacks.
      if (entry.manualCover) {
        img.onload = function () {
          img.style.display = '';
        };
        img.onerror = function () {
          img.style.display = 'none';
        };
        img.src = entry.manualCover;

      } else if (entry.isbn) {
        img.onload = function () {
          img.style.display = '';
        };

        img.onerror = function () {
          img.onerror = function () {
            img.style.display = 'none';
            tryGoogleBooksCover(entry);
          };
          img.src = 'https://covers.openlibrary.org/b/isbn/' + entry.isbn + '-L.jpg?default=false';
        };

        img.src = 'https://images-eu.bookshop.org/images/' + entry.isbn + '.jpg?v=enc-v1';

      } else {
        img.style.display = 'none';
      }
    });

    // Titles and authors for every book in a single batched request —
    // one call for all 41 books, not 41 separate calls. This is what
    // was tripping the rate limit before, even when spaced out.
    var isbns = entries.filter(function (e) { return e.isbn; }).map(function (e) { return e.isbn; });
    if (!isbns.length) return;

    var bibkeys = isbns.map(function (i) { return 'ISBN:' + i; }).join(',');

    fetch('https://openlibrary.org/api/books?bibkeys=' + encodeURIComponent(bibkeys) + '&format=json&jscmd=data')
      .then(function (res) { return res.ok ? res.json() : null; })
      .then(function (data) {
        if (!data) return;
        entries.forEach(function (entry) {
          if (!entry.isbn) return;
          var book = data['ISBN:' + entry.isbn];
          if (!book) return;
          if (book.title && !entry.manualTitle) {
            entry.titleLink.textContent = book.title;
            entry.img.alt = book.title;
          }
    
        });
      })
      .catch(function () {});
  })();
</script>
{% endif %}

{% unless use_bulk_import %}
<script>
  (function () {
    var root = document.getElementById('AMReadingList-{{ section.id }}');
    var nav = document.getElementById('AMReadingNav-{{ section.id }}');
    if (!root || !nav) return;
    var headings = root.querySelectorAll('[data-category-label]');
    headings.forEach(function (heading) {
      var label = heading.getAttribute('data-category-label');
      if (!label) return;
      var li = document.createElement('li');
      var link = document.createElement('a');
      link.href = '#' + heading.id;
      link.textContent = label;
      li.appendChild(link);
      nav.appendChild(li);
    });
    if (nav.children.length) nav.classList.add('is-ready');
  })();
</script>
{% endunless %}

