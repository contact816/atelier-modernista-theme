{% comment %}
  Atelier Modernista Reading List
  Now supports two layouts, set per-page via the "Layout" setting:
    - editorial : the existing number / cover / title / author / note / link layout
    - grid      : compact cover-forward grid for a "Browse the Library" page

  Requires:
  - assets/am-reading-list.css   (editorial layout styling — unchanged, still loads)
  - Tally script added once before </head> in theme.liquid:
    <script async src="https://tally.so/widgets/embed.js"></script>

  Grid-mode styling is self-contained in the <style> block below, so it
  does not depend on the external asset file staying in sync.
{% endcomment %}

{{ 'am-reading-list.css' | asset_url | stylesheet_tag }}

<style>
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
  {{ section.settings.intro_font | font_face: font_display: 'swap' }}
  {{ section.settings.category_font | font_face: font_display: 'swap' }}
  {{ section.settings.nav_font | font_face: font_display: 'swap' }}
</style>

<section
  id="AMReadingList-{{ section.id }}"
  class="am-reading am-reading--{{ section.settings.layout }}{% if section.settings.layout == 'grid' and section.settings.hide_grid_titles %} am-reading--hide-grid-titles{% endif %}"
  style="
    --am-reading-background: {{ section.settings.background_colour }};
    --am-reading-text: {{ section.settings.text_colour }};
    --am-reading-muted: {{ section.settings.muted_colour }};
    --am-reading-accent: {{ section.settings.accent_colour }};
    --am-reading-border: {{ section.settings.border_colour }};

    --am-reading-heading-font:
      {{ section.settings.heading_font.family }},
      {{ section.settings.heading_font.fallback_families }};

    --am-reading-body-font:
      {{ section.settings.body_font.family }},
      {{ section.settings.body_font.fallback_families }};

    --am-reading-page-title-size: {{ section.settings.page_title_size }}px;
    --am-reading-page-title-mobile: {{ section.settings.page_title_size_mobile }}px;
    --am-reading-category-size: {{ section.settings.category_title_size }}px;
    --am-reading-book-title-size: {{ section.settings.book_title_size }}px;
    --am-reading-body-size: {{ section.settings.body_size }}px;
    --am-reading-cover-width: {{ section.settings.cover_width }}px;
    --am-reading-max-width: {{ section.settings.max_width }}px;
    --am-reading-columns: {{ section.settings.columns_desktop }};
    --am-reading-grid-columns: {{ section.settings.grid_columns_desktop }};
    --am-reading-grid-cover-max-width: {{ section.settings.grid_cover_max_width }}px;

    --am-reading-intro-font:
      {{ section.settings.intro_font.family }},
      {{ section.settings.intro_font.fallback_families }};
    --am-reading-intro-size: {{ section.settings.intro_size }}px;
    --am-reading-intro-line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    --am-reading-intro-max-width: {{ section.settings.intro_max_width }}px;
    --am-reading-intro-align: {{ section.settings.intro_alignment }};

    --am-reading-category-font:
      {{ section.settings.category_font.family }},
      {{ section.settings.category_font.fallback_families }};
    --am-reading-category-line-height: {{ section.settings.category_line_height | divided_by: 100.0 }};
    --am-reading-category-weight: {{ section.settings.category_weight }};
    --am-reading-category-align: {{ section.settings.category_alignment }};
    --am-reading-category-space-above: {{ section.settings.category_space_above }}px;
    --am-reading-category-space-below: {{ section.settings.category_space_below }}px;

    --am-reading-nav-font:
      {{ section.settings.nav_font.family }},
      {{ section.settings.nav_font.fallback_families }};
    --am-reading-nav-size: {{ section.settings.nav_size }}px;
    --am-reading-nav-weight: {{ section.settings.nav_weight }};
    --am-reading-nav-letter-spacing: {{ section.settings.nav_letter_spacing | divided_by: 100.0 }}em;
    --am-reading-nav-gap: {{ section.settings.nav_gap }}px;
    --am-reading-nav-transform: {% if section.settings.nav_uppercase %}uppercase{% else %}none{% endif %};

    --am-reading-grid-title-size: {{ section.settings.grid_title_size }}px;
    --am-reading-grid-title-line-height: {{ section.settings.grid_title_line_height | divided_by: 100.0 }};
    --am-reading-grid-title-gap: {{ section.settings.grid_title_gap }}px;
    --am-reading-grid-column-gap: {{ section.settings.grid_column_gap }}px;
    --am-reading-grid-row-gap: {{ section.settings.grid_row_gap }}px;
  "
>
  <div class="am-reading__inner">

    {% comment %} PAGE HEADER {% endcomment %}
    <header class="am-reading__header am-reading__header--{{ section.settings.header_alignment }}">
      {% if section.settings.eyebrow != blank %}
        <p class="am-reading__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="am-reading__title {% if section.settings.show_title_rule %}am-reading__title--ruled{% endif %}">
          {{ section.settings.heading | escape }}
        </h1>
      {% endif %}

      {% if section.settings.intro != blank %}
        <div class="am-reading__intro rte">{{ section.settings.intro }}</div>
      {% endif %}

     <div class="am-reading__header-actions">

  {% if section.settings.show_form %}
    <button
      type="button"
      class="am-reading__shelf-trigger"
      data-tally-open="{{ section.settings.tally_form_id | escape }}"
      data-tally-auto-close="0"
      data-tally-form-events-forwarding="1"
    >
      {{ section.settings.shelf_link_label | escape }}
    </button>
  {% endif %}

  <nav class="am-reading__category-nav-wrap" aria-label="Library sections">
    <ul class="am-reading__category-nav" id="AMReadingNav-{{ section.id }}"></ul>
  </nav>

</div>
    </header>

    {% comment %} BOOKSHOP.ORG EMBED — editorial layout only {% endcomment %}
    {% if section.settings.show_bookshop_embed and section.settings.layout == 'editorial' %}
      <section class="am-reading__bookshop">
        {% if section.settings.bookshop_heading != blank %}
          <h2 class="am-reading__bookshop-heading">{{ section.settings.bookshop_heading | escape }}</h2>
        {% endif %}

        {% if section.settings.bookshop_intro != blank %}
          <div class="am-reading__bookshop-intro rte">{{ section.settings.bookshop_intro }}</div>
        {% endif %}

        <div class="am-reading__bookshop-embed">
          <script
            src="https://uk.bookshop.org/widgets.js"
            data-type="list"
            data-list-slug="{{ section.settings.bookshop_list_slug | escape }}"
          ></script>
        </div>

        {% if section.settings.main_bookshop_url != blank %}
          <a class="am-reading__bookshop-button" href="{{ section.settings.main_bookshop_url }}" target="_blank" rel="noopener sponsored">
            {{ section.settings.main_link_label | escape }}
          </a>
        {% endif %}
      </section>
    {% endif %}


    {% comment %} BOOKS {% endcomment %}
    {% assign use_bulk_import = false %}
    {% if section.settings.layout == 'grid' and section.settings.bulk_book_links != blank %}
      {% assign use_bulk_import = true %}
    {% endif %}

    {% if use_bulk_import %}
      <div
        class="am-reading__grid am-reading__grid--bulk"
        id="AMReadingBulkGrid-{{ section.id }}"
        data-hide-titles="{{ section.settings.hide_grid_titles }}"
        data-show-basket-btn="{{ section.settings.show_grid_basket_button }}"
      >
        {% comment %} Populated client-side from the pasted links — see script at the bottom. {% endcomment %}
      </div>
      <script type="application/json" id="AMReadingBulkLinks-{{ section.id }}">
        {{ section.settings.bulk_book_links | json }}
      </script>
    {% else %}
    <div class="am-reading__grid">
      {% assign book_counter = 0 %}

      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'category' %}
            {% comment %} Category dividers only make sense in editorial layout {% endcomment %}
            {% if section.settings.layout == 'editorial' %}
              {% assign category_id = block.settings.label | handleize %}
              <header
                class="am-reading__category-wrap"
                id="am-reading-{{ section.id }}-{{ category_id }}"
                data-category-label="{{ block.settings.label | escape }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.label != blank %}
                  <h2 class="am-reading__category">{{ block.settings.label | escape }}</h2>
                {% endif %}
                {% if block.settings.introduction != blank %}
                  <div class="am-reading__category-intro rte">{{ block.settings.introduction }}</div>
                {% endif %}
              </header>
            {% endif %}


          {% when 'book' %}
            {% assign book_counter = book_counter | plus: 1 %}

            {% liquid
              assign book_url = block.settings.bookshop_url
              if book_url == blank
                assign book_url = section.settings.main_bookshop_url
              endif

              assign cover_alt = block.settings.cover.alt
              if cover_alt == blank
                assign cover_alt = 'Cover of ' | append: block.settings.title
                if block.settings.author != blank
                  assign cover_alt = cover_alt | append: ' by ' | append: block.settings.author
                endif
              endif
            %}

            <article
              class="
                am-reading__card
                {% if block.settings.cover == blank %}am-reading__card--no-cover{% endif %}
                {% if block.settings.featured %}am-reading__card--featured{% endif %}
              "
              {{ block.shopify_attributes }}
            >
              {% if section.settings.show_numbers and section.settings.layout == 'editorial' %}
                <span class="am-reading__index">
                  {% if block.settings.number != blank %}
                    {{ block.settings.number | escape }}
                  {% else %}
                    {{ book_counter | prepend: '000' | slice: -3, 3 }}
                  {% endif %}
                </span>
              {% endif %}

              {% if block.settings.cover != blank %}
                {% assign img = block.settings.cover %}

                {% if book_url != blank %}
                  <a class="am-reading__cover-link" href="{{ book_url }}" target="_blank" rel="noopener sponsored" aria-label="View {{ block.settings.title | escape }} on Bookshop.org">
                {% endif %}
<img
                    class="am-reading__cover"
                    src="{{ img | image_url: width: 400 }}"
                    srcset="
                      {{ img | image_url: width: 160 }} 160w,
                      {{ img | image_url: width: 240 }} 240w,
                      {{ img | image_url: width: 400 }} 400w,
                      {{ img | image_url: width: 600 }} 600w
                    "
                    sizes="(min-width: 990px) {{ section.settings.cover_width }}px, 80px"
                    width="{{ img.width }}"
                    height="{{ img.height }}"
                    loading="lazy"
                    alt="{{ cover_alt | escape }}"
                  >

                {% if book_url != blank %}</a>{% endif %}
              {% endif %}

              <div class="am-reading__meta">
                {% if section.settings.layout == 'editorial' %}
                  {% if block.settings.kicker != blank %}
                    <p class="am-reading__kicker">{{ block.settings.kicker | escape }}</p>
                  {% endif %}
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3 class="am-reading__book-title">
                    {% if book_url != blank %}
                      <a class="am-reading__book-link" href="{{ book_url }}" target="_blank" rel="noopener sponsored">
                        {{ block.settings.title | escape }}
                      </a>
                    {% else %}
                      {{ block.settings.title | escape }}
                    {% endif %}
                  </h3>
                {% endif %}


                {% if section.settings.layout == 'editorial' %}
                  {% if section.settings.show_notes and block.settings.note != blank %}
                    <div class="am-reading__note rte">{{ block.settings.note }}</div>
                  {% endif %}

                  {% if section.settings.show_book_links and book_url != blank %}
                    <a class="am-reading__shop-link" href="{{ book_url }}" target="_blank" rel="noopener sponsored">
                      {% if block.settings.link_label != blank %}
                        {{ block.settings.link_label | escape }}
                      {% else %}
                        {{ section.settings.default_book_link_label | escape }}
                      {% endif %}
                    </a>
                  {% endif %}
                {% endif %}

                {% if section.settings.layout == 'grid' and section.settings.show_grid_basket_button and book_url != blank %}
                  <a class="am-reading__basket-btn" href="{{ book_url }}" target="_blank" rel="noopener sponsored">
                    Add to My Library
                  </a>
                {% endif %}
              </div>
            </article>

        {% endcase %}
      {% endfor %}
    </div>
    {% endif %}



  </div>
</section>


<style>
  #AMReadingList-{{ section.id }} {
    --am-reading-background: {{ section.settings.background_colour }};
    --am-reading-text: {{ section.settings.text_colour }};
    --am-reading-muted: {{ section.settings.muted_colour }};
    --am-reading-accent: {{ section.settings.accent_colour }};
    --am-reading-border: {{ section.settings.border_colour }};
    --am-reading-heading-font: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    --am-reading-body-font: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
    --am-reading-page-title-size: {{ section.settings.page_title_size }}px;
    --am-reading-page-title-mobile: {{ section.settings.page_title_size_mobile }}px;
    --am-reading-category-size: {{ section.settings.category_title_size }}px;
    --am-reading-book-title-size: {{ section.settings.book_title_size }}px;
    --am-reading-body-size: {{ section.settings.body_size }}px;
    --am-reading-cover-width: {{ section.settings.cover_width }}px;
    --am-reading-max-width: {{ section.settings.max_width }}px;
    --am-reading-columns: {{ section.settings.columns_desktop }};
    --am-reading-grid-columns: {{ section.settings.grid_columns_desktop }};
    --am-reading-grid-cover-max-width: {{ section.settings.grid_cover_max_width }}px;

    width: 100%;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    background: var(--am-reading-background);
    color: var(--am-reading-text);
    box-sizing: border-box;
  }
#AMReadingList-{{ section.id }} .am-reading__header-actions {
  margin-top: 30px;
}

#AMReadingList-{{ section.id }} .am-reading__shelf-trigger {
  appearance: none;
  margin: 0;
  padding: 0 0 5px;
  border: 0;
  border-bottom: 1px solid var(--am-reading-accent);
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  cursor: pointer;

  font-family: var(--am-reading-nav-font);
  font-size: var(--am-reading-nav-size);
  font-weight: var(--am-reading-nav-weight);
  line-height: 1.3;
  letter-spacing: var(--am-reading-nav-letter-spacing);
  text-transform: var(--am-reading-nav-transform);
  color: var(--am-reading-text);

  transition:
    color 180ms ease,
    border-color 180ms ease;
}

#AMReadingList-{{ section.id }} .am-reading__shelf-trigger:hover {
  color: var(--am-reading-accent);
  border-color: var(--am-reading-accent);
}
  #AMReadingList-{{ section.id }} *,
  #AMReadingList-{{ section.id }} *::before,
  #AMReadingList-{{ section.id }} *::after { box-sizing: border-box; }

  #AMReadingList-{{ section.id }} .am-reading__inner {
    width: 100%;
    max-width: var(--am-reading-max-width);
    margin: 0 auto;
  }

  #AMReadingList-{{ section.id }} .am-reading__header {
    width: 100%;
    max-width: 1040px;
    margin: 0 auto 64px;
    text-align: center;
  }

  #AMReadingList-{{ section.id }} .am-reading__eyebrow {
    margin: 0 0 22px;
    font-family: var(--am-reading-body-font);
    font-size: 12px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--am-reading-accent);
  }

  #AMReadingList-{{ section.id }} .am-reading__title {
    width: fit-content;
    max-width: 100%;
    margin: 0 auto 28px;
    font-family: var(--am-reading-heading-font);
    font-size: var(--am-reading-page-title-size);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -.03em;
    text-wrap: balance;
    color: var(--am-reading-text);
  }

  #AMReadingList-{{ section.id }} .am-reading__title--ruled {
    padding-bottom: 18px;
    border-bottom: 3px solid var(--am-reading-accent);
  }

  #AMReadingList-{{ section.id }} .am-reading__intro {
    max-width: var(--am-reading-intro-max-width);
    margin: 0 auto;
    font-family: var(--am-reading-intro-font) !important;
    font-size: var(--am-reading-intro-size) !important;
    font-weight: 400 !important;
    font-style: normal !important;
    line-height: var(--am-reading-intro-line-height) !important;
    letter-spacing: 0 !important;
    text-align: var(--am-reading-intro-align);
    color: var(--am-reading-muted);
  }

  #AMReadingList-{{ section.id }} .am-reading__intro,
  #AMReadingList-{{ section.id }} .am-reading__intro p,
  #AMReadingList-{{ section.id }} .am-reading__intro em,
  #AMReadingList-{{ section.id }} .am-reading__intro strong,
  #AMReadingList-{{ section.id }} .am-reading__intro span {
    font-family: var(--am-reading-intro-font) !important;
    font-size: var(--am-reading-intro-size) !important;
    font-weight: 400 !important;
    font-style: normal !important;
    line-height: var(--am-reading-intro-line-height) !important;
    letter-spacing: 0 !important;
  }

  #AMReadingList-{{ section.id }} .am-reading__intro p { margin: 0; }

  #AMReadingList-{{ section.id }} .am-reading__category-nav {
    display: none;
    justify-content: center;
    align-items: center;
    column-gap: var(--am-reading-nav-gap);
    row-gap: 10px;
    margin: 34px auto 0;
    padding: 0;
    list-style: none;
    flex-wrap: wrap;
  }
  #AMReadingList-{{ section.id }} .am-reading__category-nav.is-ready { display: flex; }
  #AMReadingList-{{ section.id }} .am-reading__category-nav a {
    position: relative;
    font-family: var(--am-reading-nav-font);
    font-size: var(--am-reading-nav-size);
    font-weight: var(--am-reading-nav-weight);
    line-height: 1.3;
    letter-spacing: var(--am-reading-nav-letter-spacing);
    text-transform: var(--am-reading-nav-transform);
    text-decoration: none;
    color: var(--am-reading-text);
  }
  #AMReadingList-{{ section.id }} .am-reading__category-nav a::after {
    content: '';
    position: absolute;
    right: 0; bottom: -5px; left: 0;
    height: 1px;
    background: var(--am-reading-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 180ms ease;
  }
  #AMReadingList-{{ section.id }} .am-reading__category-nav a:hover::after,
  #AMReadingList-{{ section.id }} .am-reading__category-nav a:focus-visible::after { transform: scaleX(1); }

  #AMReadingList-{{ section.id }} .am-reading__grid { display: grid; width: 100%; }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__grid {
    grid-template-columns: repeat(var(--am-reading-grid-columns), minmax(0,1fr));
    column-gap: var(--am-reading-grid-column-gap);
    row-gap: var(--am-reading-grid-row-gap);
    align-items: stretch;
  }
  #AMReadingList-{{ section.id }}.am-reading--editorial .am-reading__grid {
    grid-template-columns: repeat(var(--am-reading-columns), minmax(0,1fr));
    column-gap: 54px;
  }

  #AMReadingList-{{ section.id }} .am-reading__subject-heading,
  #AMReadingList-{{ section.id }} .am-reading__category-wrap {
    grid-column: 1 / -1;
    scroll-margin-top: 110px;
  }
  #AMReadingList-{{ section.id }} .am-reading__subject-heading {
    margin: var(--am-reading-category-space-above) 0 var(--am-reading-category-space-below);
    padding-top: 30px;
    {% if section.settings.show_category_dividers %}
      border-top: 1px solid rgba(0,71,171,.16);
    {% else %}
      border-top: 0;
    {% endif %}
  }
  #AMReadingList-{{ section.id }} .am-reading__subject-heading:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }
  #AMReadingList-{{ section.id }} .am-reading__subject-heading h2,
  #AMReadingList-{{ section.id }} .am-reading__category {
    margin: 0;
    font-family: var(--am-reading-category-font);
    font-size: var(--am-reading-category-size);
    font-weight: var(--am-reading-category-weight);
    line-height: var(--am-reading-category-line-height);
    text-align: var(--am-reading-category-align);
    color: var(--am-reading-text);
  }
  #AMReadingList-{{ section.id }} .am-reading__category-intro {
    max-width: 720px;
    margin-top: 14px;
    font-family: var(--am-reading-body-font);
    font-size: var(--am-reading-body-size);
    line-height: 1.65;
    color: var(--am-reading-muted);
  }

  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-width: 0;
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__cover-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: var(--am-reading-grid-cover-max-width);
    height: calc(var(--am-reading-grid-cover-max-width) * 1.58);
    margin: 0 auto;
    overflow: hidden;
    text-decoration: none;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__cover {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: calc(var(--am-reading-grid-cover-max-width) * 1.6);
    object-fit: contain;
    object-position: center bottom;
    border: 0;
    background: transparent;
    box-shadow: none;
    transition: transform 220ms ease;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__cover-link:hover .am-reading__cover { transform: translateY(-4px); }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__meta {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-top: 18px;
    text-align: center;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__book-title {
    margin: 0 0 var(--am-reading-grid-title-gap);
    font-family: var(--am-reading-heading-font);
    font-size: var(--am-reading-grid-title-size);
    font-weight: 400;
    line-height: var(--am-reading-grid-title-line-height);
    text-align: center;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__book-link { color: inherit; text-decoration: none; }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__book-link:hover {
    color: var(--am-reading-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__basket-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 230px;
    min-height: 46px;
    margin: auto auto 0;
    padding: 11px 18px;
    border: 1px solid var(--am-reading-accent);
    border-radius: 999px;
    background: var(--am-reading-accent);
    font-family: var(--am-reading-body-font);
    font-size: 10px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    color: #fff;
    transition: opacity 180ms ease, transform 180ms ease;
  }
  #AMReadingList-{{ section.id }}.am-reading--grid .am-reading__basket-btn:hover { opacity: .86; transform: translateY(-1px); }
  #AMReadingList-{{ section.id }}.am-reading--grid.am-reading--hide-grid-titles .am-reading__meta { display: none; }

