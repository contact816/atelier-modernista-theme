<script>
(function() {
  const root = document.getElementById('byl-page-{{ section.id }}');
  if (!root) return;

  const SAVINGS = 0.15;
  const CURRENCY = '{{ cart.currency.iso_code }}';
  let allProducts = [];
  let slots = { 1: null, 2: null, 3: null }; // { id, price, name, variantId }
  let toastTimer = null;

  function money(cents) {
    return new Intl.NumberFormat(undefined, {
      style: 'currency', currency: CURRENCY, maximumFractionDigits: 2
    }).format((Number(cents) || 0) / 100);
  }

  function showToast(msg) {
    const el = root.querySelector('[data-bylp-toast]');
    if (!el) return;
    clearTimeout(toastTimer);
    el.textContent = msg;
    el.classList.add('is-visible');
    toastTimer = setTimeout(() => el.classList.remove('is-visible'), 2800);
  }

  // ---- Fetch products ----
  async function fetchProducts() {
    const loadingEl = root.querySelector('[data-bylp-loading]');
    if (loadingEl) loadingEl.classList.add('is-visible');
    try {
      let products = [], page = 1;
      while (true) {
        const res = await fetch('/products.json?limit=250&page=' + page);
        const data = await res.json();
        if (!data.products || !data.products.length) break;
        products = products.concat(data.products);
        if (data.products.length < 250) break;
        page++;
      }
      allProducts = products;
      populateAllDropdowns();
    } catch(e) {
      console.error('[BYL Page]', e);
    } finally {
      if (loadingEl) loadingEl.classList.remove('is-visible');
    }
  }

  function populateAllDropdowns() {
    [1, 2, 3].forEach(slotNum => {
      const dropdown = root.querySelector('[data-bylp-select="' + slotNum + '"]');
      if (!dropdown) return;
      allProducts.forEach(p => {
        const opt = document.createElement('option');
        opt.value = p.id;
        opt.textContent = p.title;
        dropdown.appendChild(opt);
      });
    });
  }

  // ---- Slot management ----
  function fillSlot(slotNum, productId) {
    const product = allProducts.find(p => p.id === Number(productId));
    if (!product) return;

    const card = root.querySelector('[data-bylp-card="' + slotNum + '"]');
    const emptyEl = root.querySelector('[data-bylp-slot-empty="' + slotNum + '"]');
    const imgEl = root.querySelector('[data-bylp-card-img="' + slotNum + '"]');
    const titleEl = root.querySelector('[data-bylp-card-title="' + slotNum + '"]');
    const variantSelect = root.querySelector('[data-bylp-variant-select="' + slotNum + '"]');
    const priceEl = root.querySelector('[data-bylp-card-price="' + slotNum + '"]');

    // Image
    imgEl.innerHTML = '';
    if (product.images && product.images[0]) {
      const img = document.createElement('img');
      img.src = product.images[0].src;
      img.alt = product.title;
      imgEl.appendChild(img);
    }

    // Title
    titleEl.textContent = product.title;

    // Variants
    variantSelect.innerHTML = '';
    product.variants.forEach(v => {
      const opt = document.createElement('option');
      opt.value = v.id;
      opt.dataset.price = Math.round(parseFloat(v.price) * 100);
      opt.textContent = product.variants.length > 1 ? v.title : product.title;
      if (!v.available) { opt.disabled = true; opt.textContent += ' — Sold out'; }
      variantSelect.appendChild(opt);
    });

    const firstVariant = product.variants[0];
    const priceInCents = Math.round(parseFloat(firstVariant.price) * 100);

    card.dataset.currentVariantId = String(firstVariant.id);
    card.dataset.currentPrice = String(priceInCents);
    priceEl.textContent = money(priceInCents);

    slots[slotNum] = { name: product.title, price: priceInCents, variantId: firstVariant.id };

    emptyEl.style.display = 'none';
    card.style.display = 'grid';

    updateSummary();
  }

  function clearSlot(slotNum) {
    const card = root.querySelector('[data-bylp-card="' + slotNum + '"]');
    const emptyEl = root.querySelector('[data-bylp-slot-empty="' + slotNum + '"]');
    const dropdown = root.querySelector('[data-bylp-select="' + slotNum + '"]');

    if (card) { card.style.display = 'none'; card.dataset.currentVariantId = ''; card.dataset.currentPrice = '0'; }
    if (emptyEl) emptyEl.style.display = 'flex';
    if (dropdown) dropdown.value = '';

    slots[slotNum] = null;
    updateSummary();
  }

  // ---- Summary ----
  function updateSummary() {
    const filledSlots = [1, 2, 3].filter(n => slots[n] !== null);
    const subtotal = filledSlots.reduce((sum, n) => sum + slots[n].price, 0);
    const saving = Math.round(subtotal * SAVINGS);
    const total = subtotal - saving;
    const allFilled = filledSlots.length === 3;

    // Per-row summary
    [1, 2, 3].forEach(n => {
      const row = root.querySelector('[data-bylp-summary-row="' + n + '"]');
      const nameEl = root.querySelector('[data-bylp-summary-name="' + n + '"]');
      const priceEl = root.querySelector('[data-bylp-summary-price="' + n + '"]');
      if (!row) return;
      if (slots[n]) {
        nameEl.textContent = slots[n].name;
        priceEl.textContent = money(slots[n].price);
        row.style.display = 'flex';
      } else {
        row.style.display = 'none';
      }
    });

    // Totals
    const totalsEl = root.querySelector('[data-bylp-totals]');
    const emptyEl = root.querySelector('[data-bylp-summary-empty]');
    if (filledSlots.length > 0) {
      if (emptyEl) emptyEl.style.display = 'none';
    } else {
      if (emptyEl) emptyEl.style.display = 'block';
    }

    if (allFilled && totalsEl) {
      totalsEl.style.display = 'block';
      const subtotalEl = root.querySelector('[data-bylp-subtotal]');
      const savingEl = root.querySelector('[data-bylp-saving]');
      const totalEl = root.querySelector('[data-bylp-total]');
      if (subtotalEl) subtotalEl.textContent = money(subtotal);
      if (savingEl) savingEl.textContent = '−' + money(saving);
      if (totalEl) totalEl.textContent = money(total);
    } else if (totalsEl) {
      totalsEl.style.display = 'none';
    }

    // CTA
    const btn = root.querySelector('[data-bylp-add-btn]');
    const hint = root.querySelector('[data-bylp-cta-hint]');
    if (btn) btn.disabled = !allFilled;
    if (hint) hint.classList.toggle('is-hidden', allFilled);
  }

  // ---- Events ----
  root.addEventListener('change', function(e) {
    const t = e.target;

    // Product dropdown
    const selectNum = t.getAttribute('data-bylp-select');
    if (selectNum) {
      Number(t.value) ? fillSlot(Number(selectNum), t.value) : clearSlot(Number(selectNum));
      return;
    }

    // Variant select inside filled card
    const variantNum = t.getAttribute('data-bylp-variant-select');
    if (variantNum) {
      const slotNum = Number(variantNum);
      const selectedOpt = t.options[t.selectedIndex];
      const price = Number(selectedOpt.dataset.price || 0);
      const card = root.querySelector('[data-bylp-card="' + slotNum + '"]');
      const priceEl = root.querySelector('[data-bylp-card-price="' + slotNum + '"]');
      if (card) { card.dataset.currentVariantId = selectedOpt.value; card.dataset.currentPrice = String(price); }
      if (priceEl) priceEl.textContent = money(price);
      if (slots[slotNum]) { slots[slotNum].price = price; slots[slotNum].variantId = Number(selectedOpt.value); }
      updateSummary();
    }
  });

  root.addEventListener('click', function(e) {
    const removeBtn = e.target.closest('[data-bylp-remove]');
    if (removeBtn) clearSlot(Number(removeBtn.getAttribute('data-bylp-remove')));
  });

  // ---- Add to cart ----
  const addBtn = root.querySelector('[data-bylp-add-btn]');
  if (addBtn) {
    addBtn.addEventListener('click', async function() {
      const filledSlots = [1, 2, 3].filter(n => slots[n] !== null);
      if (filledSlots.length < 3) { showToast('Please select all three pieces first.'); return; }

      const items = filledSlots.map(n => {
        const card = root.querySelector('[data-bylp-card="' + n + '"]');
        return { id: Number(card.dataset.currentVariantId), quantity: 1 };
      });

      addBtn.disabled = true;
      addBtn.textContent = 'Adding…';

      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ items })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.description || 'Error');

        showToast('Your look has been added to your bag.');
        addBtn.textContent = 'Added ✓';
        document.dispatchEvent(new CustomEvent('cart:refresh'));

        setTimeout(() => {
          addBtn.textContent = '{{ section.settings.cta_label | escape }}';
          addBtn.disabled = false;
        }, 2000);
      } catch(err) {
        showToast('Something went wrong — please try again.');
        addBtn.textContent = '{{ section.settings.cta_label | escape }}';
        addBtn.disabled = false;
      }
    });
  }

  // ---- Init ----
  updateSummary();
  fetchProducts();
})();
</script>

