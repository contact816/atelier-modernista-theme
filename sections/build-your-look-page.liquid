{% comment %}
  Build Your Look — Standalone Page Template
  File: templates/page.build-your-look.json  (creates a new page template)
  Or: sections/build-your-look-page.liquid   (used by that template)

  HOW TO INSTALL:
  1. In Shopify Admin > Online Store > Themes > Edit code
  2. Create a new file: sections/build-your-look-page.liquid
  3. Paste this entire file into it
  4. Create a new file: templates/page.build-your-look.json with:
     { "sections": { "main": { "type": "build-your-look-page" } }, "order": ["main"] }
  5. Go to Pages > Create new page, set template to "build-your-look"
  6. Set the page handle to "build-your-look"
{% endcomment %}

<div id="byl-page-{{ section.id }}" class="byl-page">

  {%- comment %} Page header {%- endcomment %}
  <div class="byl-page__header">
    <p class="byl-page__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="byl-page__title">{{ section.settings.heading }}</h1>
    <p class="byl-page__subtitle">{{ section.settings.subheading }}</p>
    <div class="byl-page__badge">
      <span class="byl-page__badge-number">15%</span>
      <span class="byl-page__badge-text">off when you build a look of 3 pieces</span>
    </div>
  </div>

  <div class="byl-page__body">

    {%- comment %} Slot column {%- endcomment %}
    <div class="byl-page__slots">

      <div class="byl-page__slots-header">
        <p class="byl-page__slots-label">Your selection</p>
        <p class="byl-page__slots-hint">Pick any three pieces — the discount applies automatically.</p>
      </div>

      {%- for i in (1..3) -%}
        {%- assign slot_num = i -%}
        <div class="byl-page__slot" data-bylp-slot="{{ slot_num }}">

          {%- comment %} Empty state {%- endcomment %}
          <div class="byl-page__slot-empty" data-bylp-slot-empty="{{ slot_num }}">
            <div class="byl-page__slot-number">{{ slot_num }}</div>
            <div class="byl-page__slot-select-wrap">
              <label class="byl-page__slot-slabel" for="bylp-select-{{ slot_num }}">
                {%- if slot_num == 1 -%}First piece
                {%- elsif slot_num == 2 -%}Second piece
                {%- else -%}Third piece{%- endif -%}
              </label>
              <select id="bylp-select-{{ slot_num }}" class="byl-page__slot-dropdown" data-bylp-select="{{ slot_num }}">
                <option value="">— Choose from collection —</option>
              </select>
            </div>
          </div>

          {%- comment %} Filled card {%- endcomment %}
          <article class="byl-page__slot-card" data-bylp-card="{{ slot_num }}" style="display:none"
            data-current-variant-id="" data-current-price="0">
            <div class="byl-page__slot-card-img" data-bylp-card-img="{{ slot_num }}"></div>
            <div class="byl-page__slot-card-body">
              <p class="byl-page__slot-card-num">Piece {{ slot_num }}</p>
              <h3 class="byl-page__slot-card-title" data-bylp-card-title="{{ slot_num }}"></h3>
              <select class="byl-page__slot-card-variants" data-bylp-variant-select="{{ slot_num }}"></select>
              <div class="byl-page__slot-card-price-row">
                <span class="byl-page__slot-card-price" data-bylp-card-price="{{ slot_num }}">—</span>
              </div>
              <button class="byl-page__slot-remove" data-bylp-remove="{{ slot_num }}" type="button">
                Remove
              </button>
            </div>
          </article>

        </div>
      {%- endfor -%}

      {%- comment %} Loading indicator {%- endcomment %}
      <p class="byl-page__loading" data-bylp-loading aria-live="polite">Loading collection…</p>

    </div>

    {%- comment %} Summary sidebar {%- endcomment %}
    <aside class="byl-page__summary">
      <div class="byl-page__summary-inner">

        <p class="byl-page__summary-label">Your look</p>

        <div class="byl-page__summary-rows">
          <div class="byl-page__summary-row" data-bylp-summary-row="1" style="display:none">
            <span data-bylp-summary-name="1" class="byl-page__summary-row-name">—</span>
            <span data-bylp-summary-price="1">—</span>
          </div>
          <div class="byl-page__summary-row" data-bylp-summary-row="2" style="display:none">
            <span data-bylp-summary-name="2" class="byl-page__summary-row-name">—</span>
            <span data-bylp-summary-price="2">—</span>
          </div>
          <div class="byl-page__summary-row" data-bylp-summary-row="3" style="display:none">
            <span data-bylp-summary-name="3" class="byl-page__summary-row-name">—</span>
            <span data-bylp-summary-price="3">—</span>
          </div>
        </div>

        <div class="byl-page__summary-empty" data-bylp-summary-empty>
          <p>Your look is empty.<br>Add three pieces to unlock your discount.</p>
        </div>

        <div class="byl-page__summary-totals" data-bylp-totals style="display:none">
          <div class="byl-page__summary-divider"></div>
          <div class="byl-page__summary-line">
            <span>Subtotal</span>
            <span data-bylp-subtotal>—</span>
          </div>
          <div class="byl-page__summary-line byl-page__summary-line--saving">
            <span>15% look discount</span>
            <span data-bylp-saving>—</span>
          </div>
          <div class="byl-page__summary-line byl-page__summary-line--total">
            <span>Your price</span>
            <span data-bylp-total>—</span>
          </div>
        </div>

        <button type="button" class="byl-page__cta" data-bylp-add-btn disabled>
          {{ section.settings.cta_label }}
        </button>

        <p class="byl-page__cta-hint" data-bylp-cta-hint>Add 3 pieces to unlock</p>
        <p class="byl-page__toast" data-bylp-toast role="status" aria-live="polite"></p>

      </div>
    </aside>

  </div>
</div>

<style>
