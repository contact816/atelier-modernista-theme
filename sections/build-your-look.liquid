{% comment %}
  Atelier Modernista — Product Pairing

  A quiet, conversion-focused recommendation beneath the main product.
  Full styling experience:
  /pages/build-your-look
{% endcomment %}

{%- assign pairing_products = product.metafields.custom.look_products.value -%}

{%- if pairing_products != blank and pairing_products.size > 0 or request.design_mode -%}

  <section
    id="am-pairing-{{ section.id }}"
    class="am-pairing"
  >
    <div class="page-width">
      <div class="am-pairing__inner">

        <header class="am-pairing__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="am-pairing__eyebrow">
              {{ section.settings.eyebrow }}
            </p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="am-pairing__heading">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <div class="am-pairing__subheading">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}
        </header>

        <div class="am-pairing__products">
          {%- if pairing_products != blank and pairing_products.size > 0 -%}

            {%- for pairing_product in pairing_products limit: 2 -%}
              {%- assign pairing_variant = pairing_product.selected_or_first_available_variant -%}
              {%- assign pairing_image = pairing_product.featured_image -%}

              {%- if pairing_product != blank and pairing_variant != blank -%}
                <article class="am-pairing-card">

                  <a
                    href="{{ pairing_product.url }}"
                    class="am-pairing-card__image-link"
                    aria-label="View {{ pairing_product.title | escape }}"
                  >
                    {%- if pairing_image != blank -%}
                      <img
                        src="{{ pairing_image | image_url: width: 800 }}"
                        srcset="
                          {{ pairing_image | image_url: width: 320 }} 320w,
                          {{ pairing_image | image_url: width: 480 }} 480w,
                          {{ pairing_image | image_url: width: 640 }} 640w,
                          {{ pairing_image | image_url: width: 800 }} 800w
                        "
                        sizes="
                          (max-width: 749px) 88vw,
                          (max-width: 989px) 420px,
                          380px
                        "
                        alt="{{ pairing_image.alt | default: pairing_product.title | escape }}"
                        width="{{ pairing_image.width }}"
                        height="{{ pairing_image.height }}"
                        loading="lazy"
                      >
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'am-pairing-card__placeholder' }}
                    {%- endif -%}
                  </a>

                  <div class="am-pairing-card__content">
                    <h3 class="am-pairing-card__title">
                      <a href="{{ pairing_product.url }}">
                        {{ pairing_product.title }}
                      </a>
                    </h3>

                    <p class="am-pairing-card__price">
                      {{ pairing_variant.price | money_without_trailing_zeros }}
                    </p>

                    <div class="am-pairing-card__actions">
                      {%- if pairing_variant.available -%}
                        <button
                          type="button"
                          class="am-pairing-card__add"
                          data-am-pairing-add
                          data-variant-id="{{ pairing_variant.id }}"
                          data-default-label="{{ section.settings.product_cta_label | escape }}"
                        >
                          {{ section.settings.product_cta_label }}
                        </button>
                      {%- else -%}
                        <button
                          type="button"
                          class="am-pairing-card__add"
                          disabled
                        >
                          Sold out
                        </button>
                      {%- endif -%}

                      <a
                        href="{{ pairing_product.url }}"
                        class="am-pairing-card__details"
                      >
                        View details
                      </a>
                    </div>

                    <p
                      class="am-pairing-card__message"
                      data-am-pairing-message
                      role="status"
                      aria-live="polite"
                    ></p>
                  </div>

                </article>
              {%- endif -%}
            {%- endfor -%}

          {%- elsif request.design_mode -%}

            <article class="am-pairing-card">
              <div class="am-pairing-card__image-link">
                {{ 'product-1' | placeholder_svg_tag: 'am-pairing-card__placeholder' }}
              </div>

              <div class="am-pairing-card__content">
                <h3 class="am-pairing-card__title">
                  Complementary piece
                </h3>

                <p class="am-pairing-card__price">£00</p>

                <button
                  type="button"
                  class="am-pairing-card__add"
                  disabled
                >
                  Add to bag
                </button>
              </div>
            </article>

          {%- endif -%}
        </div>

       {% comment %}
<footer class="am-pairing__footer">
  <p class="am-pairing__footer-label">
    Prefer to create your own combination?
  </p>

  <a
    href="{{ section.settings.builder_url | default: '/pages/build-your-look' }}"
    class="am-pairing__builder-link"
  >
    {{ section.settings.builder_label }}
    <span aria-hidden="true">→</span>
  </a>
</footer>
{% endcomment %}

      </div>
    </div>
  </section>

{%- endif -%}


<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background_colour }};
  }

  #am-pairing-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #am-pairing-{{ section.id }} .am-pairing__inner {
    max-width: 1120px;
    margin: 0 auto;
    padding-top: 44px;
    border-top: 1px solid rgba(17, 17, 17, 0.13);
  }

  #am-pairing-{{ section.id }} .am-pairing__header {
    max-width: 690px;
    margin-bottom: 38px;
  }

  #am-pairing-{{ section.id }} .am-pairing__eyebrow {
    margin: 0 0 13px;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: #0047ab;
  }

  #am-pairing-{{ section.id }} .am-pairing__heading {
    margin: 0 0 14px;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 4vw, 50px);
    font-weight: 400;
    line-height: 1.04;
    letter-spacing: -0.015em;
    color: #111111;
  }

  #am-pairing-{{ section.id }} .am-pairing__subheading {
    max-width: 590px;
    margin: 0;
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(17, 17, 17, 0.62);
  }

  #am-pairing-{{ section.id }} .am-pairing__products {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 380px));
    gap: 44px;
    justify-content: start;
  }

  #am-pairing-{{ section.id }}
  .am-pairing__products:has(.am-pairing-card:only-child) {
    grid-template-columns: minmax(0, 380px);
  }

  #am-pairing-{{ section.id }} .am-pairing-card {
    min-width: 0;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__image-link {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(0, 71, 171, 0.025);
  }

  #am-pairing-{{ section.id }} .am-pairing-card__image-link img,
  #am-pairing-{{ section.id }} .am-pairing-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__image-link img {
    transition: transform 320ms ease;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__image-link:hover img {
    transform: scale(1.018);
  }

  #am-pairing-{{ section.id }} .am-pairing-card__content {
    padding-top: 17px;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__title {
    margin: 0 0 6px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 1.18;
    color: #111111;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__title a {
    color: inherit;
    text-decoration: none;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__title a:hover {
    color: #0047ab;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__price {
    margin: 0 0 18px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 1.3;
    color: #111111;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 13px;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__add {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 50px;
    padding: 13px 22px;
    border: 1px solid #111111;
    border-radius: 0;
    background: #111111;
    color: #ffffff;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      opacity 180ms ease;
  }

  #am-pairing-{{ section.id }}
  .am-pairing-card__add:hover:not(:disabled) {
    background: #0047ab;
    border-color: #0047ab;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__add:disabled {
    opacity: 0.48;
    cursor: not-allowed;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__add.is-loading {
    opacity: 0.7;
    cursor: wait;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__details {
    align-self: flex-start;
    padding-bottom: 3px;
    border-bottom: 1px solid rgba(17, 17, 17, 0.25);
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(17, 17, 17, 0.68);
  }

  #am-pairing-{{ section.id }} .am-pairing-card__details:hover {
    color: #0047ab;
    border-bottom-color: #0047ab;
  }

  #am-pairing-{{ section.id }} .am-pairing-card__message {
    min-height: 18px;
    margin: 10px 0 0;
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    line-height: 1.4;
    letter-spacing: 0.05em;
    color: #0047ab;
  }

  #am-pairing-{{ section.id }} .am-pairing__footer {
    max-width: 540px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(17, 17, 17, 0.12);
  }

  #am-pairing-{{ section.id }} .am-pairing__footer-label {
    margin: 0 0 10px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(17, 17, 17, 0.55);
  }

  #am-pairing-{{ section.id }} .am-pairing__builder-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding-bottom: 5px;
    border-bottom: 1px solid rgba(0, 71, 171, 0.4);
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: #0047ab;
    transition:
      gap 180ms ease,
      border-color 180ms ease;
  }

  #am-pairing-{{ section.id }} .am-pairing__builder-link:hover {
    gap: 13px;
    border-bottom-color: #0047ab;
  }

  @media screen and (max-width: 749px) {
    #am-pairing-{{ section.id }} .am-pairing__inner {
      padding-top: 32px;
    }

    #am-pairing-{{ section.id }} .am-pairing__header {
      margin-bottom: 28px;
    }

    #am-pairing-{{ section.id }} .am-pairing__heading {
      font-size: 38px;
    }

    #am-pairing-{{ section.id }} .am-pairing__subheading {
      font-size: 15px;
    }

    #am-pairing-{{ section.id }} .am-pairing__products,
    #am-pairing-{{ section.id }}
    .am-pairing__products:has(.am-pairing-card:only-child) {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    #am-pairing-{{ section.id }} .am-pairing-card {
      max-width: 100%;
    }

    #am-pairing-{{ section.id }} .am-pairing-card__title {
      font-size: 22px;
    }

    #am-pairing-{{ section.id }} .am-pairing__footer {
      margin-top: 38px;
    }
  }
</style>


<script>
  (function () {
    const root = document.getElementById('am-pairing-{{ section.id }}');

    if (!root || root.dataset.amPairingInitialised === 'true') return;

    root.dataset.amPairingInitialised = 'true';

    root.addEventListener('click', async function (event) {
      const button = event.target.closest('[data-am-pairing-add]');

      if (!button || button.disabled) return;

      const variantId = Number(button.dataset.variantId);
      const defaultLabel = button.dataset.defaultLabel || 'Add to bag';
      const card = button.closest('.am-pairing-card');
      const message = card
        ? card.querySelector('[data-am-pairing-message]')
        : null;

      if (!variantId) return;

      button.disabled = true;
      button.classList.add('is-loading');
      button.textContent = 'Adding…';

      if (message) message.textContent = '';

      try {
        const response = await fetch(
          window.Shopify.routes.root + 'cart/add.js',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
              items: [
                {
                  id: variantId,
                  quantity: 1
                }
              ]
            })
          }
        );

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.description || 'Unable to add product');
        }

        button.textContent = 'Added to bag';

        if (message) {
          message.textContent = 'This piece is now in your bag.';
        }

        document.dispatchEvent(
          new CustomEvent('cart:refresh', {
            bubbles: true
          })
        );

        document.dispatchEvent(
          new CustomEvent('cart:update', {
            bubbles: true,
            detail: result
          })
        );

        setTimeout(function () {
          button.textContent = defaultLabel;
          button.disabled = false;
          button.classList.remove('is-loading');
        }, 1900);

      } catch (error) {
        console.error('[AM Pairing]', error);

        button.textContent = 'Please try again';

        if (message) {
          message.textContent = 'This piece could not be added. Please try again.';
        }

        setTimeout(function () {
          button.textContent = defaultLabel;
          button.disabled = false;
          button.classList.remove('is-loading');
        }, 1900);
      }
    });
  })();
</script>


<div class="page-width" style="padding-bottom: 64px;">
  {% render 'next-product', product: product, collection: collection %}
</div>


{% schema %}
{
  "name": "Product pairing",
  "tag": "section",
  "class": "build-your-look-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Pairs beautifully with"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete the composition"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A complementary piece selected for its balance of colour, proportion and form."
    },
    {
      "type": "text",
      "id": "product_cta_label",
      "label": "Recommended product button",
      "default": "Add to bag"
    },
    {
      "type": "text",
      "id": "builder_label",
      "label": "Builder link label",
      "default": "Explore the Atelier Edits"
    },
    {
      "type": "url",
      "id": "builder_url",
      "label": "Atelier Edits page"
    },
    {
      "type": "color",
      "id": "background_colour",
      "label": "Background colour",
      "default": "#fdf6e3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Product pairing"
    }
  ]
}
{% endschema %}