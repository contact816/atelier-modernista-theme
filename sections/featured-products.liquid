<style>
.am-featured{width:{{ section.settings.desktop_width }}%;margin:0 auto;padding:{{ section.settings.padding }}px 0}
.am-featured__heading{text-align:center;font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:400;letter-spacing:0.08em;color:#0047AB;margin-bottom:2rem}
.am-featured__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:{{ section.settings.gap }}px}
.am-featured__card{display:flex;flex-direction:column;text-align:center}
.am-featured__img-wrap{width:100%;aspect-ratio:1/1;overflow:hidden;background:#f5f0e8}
.am-featured__img-wrap img{width:100%;height:100%;object-fit:cover;object-position:center;display:block}
.am-featured__img-wrap a{display:block;width:100%;height:100%}
.am-featured__info{padding:{{ section.settings.space_below_image }}px 0 0;flex:1;display:flex;flex-direction:column}
.am-featured__title{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:400;letter-spacing:0.04em;color:#111;line-height:1.4;margin-bottom:0.5rem}
.am-featured__title a{color:inherit;text-decoration:none}
.am-featured__price{font-family:'Jost',sans-serif;font-size:0.85rem;font-weight:300;letter-spacing:0.06em;color:#111;margin-bottom:1rem;flex:1}
.am-featured__btn{display:block;background:#0047AB;color:#fff;font-family:'Jost',sans-serif;font-size:0.75rem;font-weight:400;letter-spacing:0.14em;text-transform:uppercase;padding:0.75rem 1rem;border:none;cursor:pointer;width:100%;transition:background 0.2s}
.am-featured__btn:hover{background:#003380}
@media(max-width:749px){.am-featured__grid{grid-template-columns:1fr;gap:2rem}}
</style>

<div class="am-featured">
  {%- if section.settings.heading != blank -%}
    <h2 class="am-featured__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="am-featured__grid">
    {%- for i in (1..3) -%}
      {%- assign product_setting = 'product_' | append: i -%}
      {%- assign product = section.settings[product_setting] -%}
      {%- if product != blank -%}
        <div class="am-featured__card">
          <div class="am-featured__img-wrap">
            <a href="{{ product.url }}">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 400 }}"
                  srcset="{{ product.featured_image | image_url: width: 200 }} 200w,
                          {{ product.featured_image | image_url: width: 400 }} 400w,
                          {{ product.featured_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) calc(50vw - 20px), 400px"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-carousel-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="{{ 400 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {%- endif -%}
            </a>
          </div>
          <div class="am-featured__info">
            <p class="am-featured__title"><a href="{{ product.url }}">{{ product.title }}</a></p>
            <p class="am-featured__price">{{ product.price | money }}</p>
            <button class="am-featured__btn" onclick="fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:{{ product.first_available_variant.id }},quantity:1})}).then(()=>window.location='/cart')">{{ section.settings.button_text }}</button>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Bestsellers"},
    {"type":"product","id":"product_1","label":"Product 1"},
    {"type":"product","id":"product_2","label":"Product 2"},
    {"type":"product","id":"product_3","label":"Product 3"},
    {"type":"text","id":"button_text","label":"Button text","default":"Add to Bag"},
    {"type":"range","id":"desktop_width","min":50,"max":100,"step":5,"unit":"%","label":"Desktop width","default":80},
    {"type":"range","id":"gap","min":10,"max":60,"step":5,"unit":"px","label":"Gap between cards","default":30},
    {"type":"range","id":"padding","min":0,"max":100,"step":5,"unit":"px","label":"Section padding","default":40},
    {"type":"range","id":"space_below_image","min":5,"max":40,"step":5,"unit":"px","label":"Space below image","default":15}
  ],
  "presets":[{"name":"Featured Products"}]
}
{% endschema %}