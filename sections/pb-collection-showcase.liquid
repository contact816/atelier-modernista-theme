{%- assign pt = section.settings.padding_top -%}
{%- assign pb = section.settings.padding_bottom -%}

<section class="am-editorial-banner am-editorial-banner--inset" style="margin-top: {{ pt }}px; margin-bottom: {{ pb }}px;">
  
  <div class="am-editorial-banner__image">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'am-editorial-banner__placeholder' }}
    {%- endif -%}
  </div>
  <div class="am-editorial-banner__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="am-eyebrow am-eyebrow--yellow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h2 class="am-editorial-banner__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.description != blank -%}
      <p class="am-editorial-banner__desc">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.settings.meta_1_label != blank or section.settings.meta_2_label != blank -%}
      <div class="am-editorial-banner__meta">
        {%- if section.settings.meta_1_label != blank -%}
          <span><b>{{ section.settings.meta_1_label }}</b>{{ section.settings.meta_1_value }}</span>
        {%- endif -%}
        {%- if section.settings.meta_2_label != blank -%}
          <span><b>{{ section.settings.meta_2_label }}</b>{{ section.settings.meta_2_value }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}" class="am-btn-ghost" style="margin-top: 32px;">
        {{ section.settings.cta_label }} →
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "AM — Collection Showcase",
  "tag": "section",
  "class": "am-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Collection image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Atelier Modernista"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cobalt Season"
      
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Cobalt is our signature colour — rich yet subtle, striking yet refined."
    },
    {
      "type": "header",
      "content": "Meta details"
    },
    {
      "type": "text",
      "id": "meta_1_label",
      "label": "Meta 1 label",
      "default": "From"
    },
    {
      "type": "text",
      "id": "meta_1_value",
      "label": "Meta 1 value",
      "default": "£45"
    },
    {
      "type": "text",
      "id": "meta_2_label",
      "label": "Meta 2 label",
      "default": "Pieces"
    },
    {
      "type": "text",
      "id": "meta_2_value",
      "label": "Meta 2 value",
      "default": "12"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "View the edit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Space above",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Space below",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "AM — Collection Showcase"
    }
  ]
}
{% endschema %}