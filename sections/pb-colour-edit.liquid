<div class="am-colour-edit">
  <div class="am-colour-edit__inner">
    <div class="am-colour-edit__text">
      {%- if section.settings.eyebrow != blank -%}
        <div class="am-eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="am-colour-edit__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.body != blank -%}
        <p class="am-colour-edit__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="am-btn-primary">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="am-colour-edit__grid">
  {%- for block in section.blocks -%}
    {%- if block.settings.use_gradient -%}
      {%- assign swatch_style = 'background: ' | append: block.settings.gradient_css | append: '; color: ' | append: block.settings.text_colour_hex | append: ';' -%}
    {%- else -%}
      {%- assign swatch_style = 'background-color: ' | append: block.settings.colour_hex | append: '; color: ' | append: block.settings.text_colour_hex | append: ';' -%}
    {%- endif -%}
    <a href="{{ block.settings.url }}" class="am-colour-edit__swatch am-colour-edit__swatch--{{ block.settings.colour_key }}" style="{{ swatch_style }}" {{ block.shopify_attributes }}>
      <span class="am-colour-edit__swatch-label">{{ block.settings.label }}</span>
      <span class="am-colour-edit__swatch-count">{{ block.settings.piece_count }}</span>
    </a>
  {%- endfor -%}
</div>
<style>
  .am-colour-edit {
    padding: 80px 60px;
    background: #fdf6e3;
  }

  .am-colour-edit__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: center;
  }

  .am-colour-edit__text .am-eyebrow {
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    letter-spacing: 0.32em !important;
    text-transform: uppercase !important;
    color: #0047AB !important;
    font-weight: 500 !important;
    margin-bottom: 16px !important;
  }

  .am-colour-edit__heading {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: clamp(36px, 4vw, 56px) !important;
    font-weight: 400 !important;
    line-height: 1.1 !important;
    margin-bottom: 20px !important;
    letter-spacing: -0.01em !important;
    color: #1a1a18 !important;
  }

  .am-colour-edit__body {
    font-family: 'Jost', sans-serif !important;
    font-size: 16px !important;
    line-height: 1.75 !important;
    color: #6b6b6b !important;
    margin-bottom: 36px !important;
    font-weight: 300 !important;
  }

  .am-colour-edit__text .am-btn-primary {
    display: inline-block !important;
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    font-weight: 500 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    padding: 16px 38px !important;
    background-color: #0047AB !important;
    color: #fdf6e3 !important;
    border: 1px solid #0047AB !important;
    border-radius: 0 !important;
  }

  .am-colour-edit__text .am-btn-primary:hover {
    background-color: #1a1a18 !important;
    border-color: #1a1a18 !important;
  }

  .am-colour-edit__grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
    aspect-ratio: 16 / 11;
    background: #1a1a18;
    padding: 6px;
  }

  .am-colour-edit__swatch {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 24px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .am-colour-edit__swatch:hover {
    opacity: 0.85;
  }

  .am-colour-edit__swatch--vermilion,
  .am-colour-edit__swatch--Red {
    grid-row: 1 / 3;
  }

  .am-colour-edit__swatch-label {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: 28px !important;
    font-weight: 400 !important;
    display: block !important;
    line-height: 1 !important;
  }

  .am-colour-edit__swatch-count {
    position: absolute;
    top: 18px;
    right: 18px;
    font-family: 'Jost', sans-serif !important;
    font-size: 10px !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
    font-weight: 500 !important;
    opacity: 0.7 !important;
  }

  @media (max-width: 1024px) {
    .am-colour-edit__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .am-colour-edit {
      padding: 60px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "AM — Colour Edit",
  "tag": "section",
  "class": "am-section",
  "max_blocks": 7,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by Colour"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Colour Edit."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "The collection is organised by its dominant hue — modernist colour theory translated into wearable form."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Explore the Edit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "colour",
      "name": "Colour swatch",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Colour name",
          "default": "Cobalt"
        },
        {
          "type": "text",
          "id": "piece_count",
          "label": "Piece count label",
          "default": "12 pieces"
        },
        {
          "type": "checkbox",
          "id": "use_gradient",
          "label": "Use gradient background",
          "default": false
        },
        {
          "type": "color",
          "id": "colour_hex",
          "label": "Background colour (solid)",
          "default": "#1f2c8a"
        },
        {
          "type": "text",
          "id": "gradient_css",
          "label": "Gradient CSS (if using gradient)",
          "default": "linear-gradient(135deg, #d72d1f 33%, #0047AB 33% 66%, #f5c518 66%)"
        },
        {
          "type": "color",
          "id": "text_colour_hex",
          "label": "Text colour",
          "default": "#f7eed8"
        },
        {
          "type": "text",
          "id": "colour_key",
          "label": "CSS key (cobalt / vermilion / ochre / gold / silver / polychrome)",
          "default": "cobalt"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AM — Colour Edit",
      "blocks": [
        {
          "type": "colour",
          "settings": {
            "label": "Vermilion",
            "piece_count": "8 pieces",
            "colour_hex": "#d72d1f",
            "text_colour_hex": "#f7eed8",
            "colour_key": "vermilion"
          }
        },
        {
          "type": "colour",
          "settings": {
            "label": "Cobalt",
            "piece_count": "12 pieces",
            "colour_hex": "#0047AB",
            "text_colour_hex": "#f7eed8",
            "colour_key": "cobalt"
          }
        },
        {
          "type": "colour",
          "settings": {
            "label": "Ochre",
            "piece_count": "5 pieces",
            "colour_hex": "#f5c518",
            "text_colour_hex": "#1a1a18",
            "colour_key": "ochre"
          }
        },
        {
          "type": "colour",
          "settings": {
            "label": "Gold",
            "piece_count": "6 pieces",
            "colour_hex": "#C9A96E",
            "text_colour_hex": "#1a1a18",
            "colour_key": "gold"
          }
        },
        {
          "type": "colour",
          "settings": {
            "label": "Silver",
            "piece_count": "8 pieces",
            "colour_hex": "#A8A9AD",
            "text_colour_hex": "#1a1a18",
            "colour_key": "silver"
          }
