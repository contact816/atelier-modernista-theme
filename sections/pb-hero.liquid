<div class="am-hero">
  <div class="am-hero__image">
    {%- if section.settings.hero_image != blank -%}
      <a href="{{ section.settings.primary_cta_url }}" class="am-hero__image-link" aria-label="{{ section.settings.primary_cta_label | default: 'Shop the collection' | escape }}">
        <img
          src="{{ section.settings.hero_image | image_url: width: 1600 }}"
          alt="{{ section.settings.hero_image.alt | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
        >
      </a>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'am-hero__placeholder' }}
    {%- endif -%}
  </div>
  <div class="am-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="am-hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
   <h1 class="am-hero__headline">
  {%- if section.settings.headline_plain != blank -%}{{ section.settings.headline_plain }}<br>{%- endif -%}
  {%- if section.settings.headline_italic != blank -%}<em>{{ section.settings.headline_italic }}</em>{%- endif -%}
</h1>
    {%- if section.settings.subheading != blank -%}
      <div class="am-hero__sub">{{ section.settings.subheading }}</div>
    {%- endif -%}
    <div class="am-hero__cta-row">
      <a href="{{ section.settings.primary_cta_url }}" class="am-btn-primary">
        {{ section.settings.primary_cta_label }}
      </a>
      {%- if section.settings.secondary_cta_label != blank -%}
        <a href="{{ section.settings.secondary_cta_url }}" class="am-btn-secondary">
          {{ section.settings.secondary_cta_label }}
        </a>
      {%- endif -%}
    </div>
    {%- if section.settings.show_trust_strip -%}
      <div class="am-hero__trust">
        <span><span class="am-dot"></span>{{ section.settings.trust_1 }}</span>
        <span><span class="am-dot"></span>{{ section.settings.trust_2 }}</span>
        <span><span class="am-dot"></span>{{ section.settings.trust_3 }}</span>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .am-hero {
    display: grid;

    grid-template-columns: minmax(600px, 780px) minmax(540px, 700px);

    justify-content: center;

    gap: 24px;

    max-width: 1650px;

    margin: 0 auto;

    min-height: 70vh;  
}

  .am-hero__image {
    position: relative;
    overflow: hidden;
    background-color: #fdf6e3 !important;

    display: flex;
    justify-content: center;
    align-items: center;

    padding: 60px 24px 24px 48px !important;

    box-sizing: border-box !important;
}

  .am-hero__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

.am-hero__image {
    display: flex;
    justify-content: center;
    align-items: center;
}

.am-hero__image img {
    width: 100%;
    height: 100%;

    object-fit: scale-down;
object-position: center center;
}
  .am-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;

    padding: 40px 80px 80px 80px;

    transform: translateY(-40px);
}
  .am-hero .am-hero__content .am-hero__eyebrow {
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    font-weight: 400 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: #0047AB !important;
    margin: 0 0 24px !important;
  }

  .am-hero .am-hero__content h1.am-hero__headline,
  .am-hero .am-hero__content .am-hero__headline {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-size: clamp(32px, 6vw, 64px) !important;
    font-weight: 400 !important;
    letter-spacing: -0.01em !important;
    line-height: 1.05 !important;
    color: #1a1a18 !important;
    margin: 0 0 28px !important;
    text-align: left !important;
}


  .am-hero .am-hero__content .am-hero__sub {
    font-family: 'Jost', sans-serif !important;
    font-size: 16px !important;
    font-weight: 300 !important;
    line-height: 1.75 !important;
    color: #3a3a35 !important;
    max-width: 480px !important;
    margin: 0 0 40px !important;
  }

  .am-hero .am-hero__content .am-hero__cta-row {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 16px !important;
    align-items: center !important;
    margin-bottom: 48px !important;
  }

  .am-hero .am-hero__content .am-btn-primary {
    display: inline-block !important;
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    font-weight: 500 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    padding: 16px 38px !important;
    background-color: #0047AB !important;
    color: #fdf6e3 !important;
    border: 1px solid #0047AB !important;
    border-radius: 0 !important;
  }

  .am-hero .am-hero__content .am-btn-primary:hover {
    background-color: #1a1a18 !important;
    border-color: #1a1a18 !important;
    color: #fdf6e3 !important;
  }

  .am-hero .am-hero__content .am-btn-secondary {
    display: inline-block !important;
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    font-weight: 500 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    padding: 4px 0 !important;
    background: transparent !important;
    color: #1a1a18 !important;
    border: none !important;
    border-bottom: 1px solid #1a1a18 !important;
    border-radius: 0 !important;
  }

  .am-hero .am-hero__content .am-btn-secondary:hover {
    color: #0047AB !important;
    border-color: #0047AB !important;
  }

  .am-hero .am-hero__content .am-hero__trust {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 6px 32px !important;
    padding-top: 28px !important;
    border-top: 1px solid rgba(26,26,24,0.1) !important;
    font-family: 'Jost', sans-serif !important;
    font-size: 11px !important;
    font-weight: 400 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: #9e9a90 !important;
    margin-top: 0 !important;
  }

  .am-hero .am-hero__content .am-hero__trust span {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    color: #9e9a90 !important;
    font-size: 11px !important;
  }

  .am-hero .am-hero__content .am-dot {
    display: inline-block !important;
    width: 5px !important;
    height: 5px !important;
    border-radius: 50% !important;
    background-color: #0047AB !important;
    flex-shrink: 0 !important;
  }

  @media (max-width: 1024px) {
    .am-hero .am-hero__content {
      padding: 60px 40px !important;
    }
  }

  @media (max-width: 768px) {
    .am-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .am-hero__image {
      height: 60vw;
      position: relative;
    }
    .am-hero__image {
      padding: 16px !important;
    }
    .am-hero__image img {
      position: static;
    }
    .am-hero .am-hero__content {
      padding: 48px 28px !important;
    }
    .am-hero .am-hero__content h1.am-hero__headline,
    .am-hero .am-hero__content .am-hero__headline {
      font-size: clamp(36px, 9vw, 52px) !important;
    }
    .am-hero .am-hero__content .am-btn-primary {
      width: 100% !important;
      text-align: center !important;
    }
  }
</style>

{% schema %}
{
  "name": "AM — Hero",
  "tag": "section",
  "class": "am-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "A small edit, considered"
    },
    {
  "type": "text",
  "id": "headline_plain",
  "label": "Headline — plain part",
  "default": "Jewellery with"
},
{
  "type": "text",
  "id": "headline_italic",
  "label": "Headline — italic part",
  "default": "a point of view."
},
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "A curated edit of bold enamel jewellery in cobalt, vermilion, and recycled silver. Pieces selected for their geometry, their colour, and the conviction with which they were made."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Button label",
      "default": "Shop the Edit"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Button label",
      "default": "The Philosophy"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Trust strip"
    },
    {
      "type": "checkbox",
      "id": "show_trust_strip",
      "label": "Show trust strip",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Curated in London"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Small Editions"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "Free UK Delivery"
    }
  ],
  "presets": [
    {
      "name": "AM — Hero"
    }
  ]
}
{% endschema %}