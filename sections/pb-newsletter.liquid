<section class="am-newsletter am-newsletter--circle">
  {%- if section.settings.eyebrow != blank -%}
    <div class="am-newsletter__eyebrow">
      {{ section.settings.eyebrow }}
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="am-newsletter__heading">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  {%- if section.settings.subtext != blank -%}
    <p class="am-newsletter__sub">
      {{ section.settings.subtext }}
    </p>
  {%- endif -%}

  <div class="am-newsletter__form-wrap">
    <div class="klaviyo-form-R2kMnB"></div>
  </div>
</section>
.am-newsletter--circle {
  width: 100%;
  padding: 48px 20px 40px;
  background: #fef7e8;
  text-align: center;
}

.am-newsletter--circle .am-newsletter__eyebrow {
  margin: 0 0 12px;
  font-family: Jost, sans-serif;
  font-size: 1.1rem;
  line-height: 1.3;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #0047ab;
}

.am-newsletter--circle .am-newsletter__heading {
  margin: 0 0 14px;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(3.2rem, 4vw, 4.8rem);
  font-weight: 400;
  line-height: 1.05;
  color: #292929;
}

.am-newsletter--circle .am-newsletter__sub {
  max-width: 620px;
  margin: 0 auto 24px;
  font-family: Jost, sans-serif;
  font-size: 1.5rem;
  line-height: 1.6;
  letter-spacing: 0;
  color: #3c3228;
}

.am-newsletter--circle .am-newsletter__form-wrap {
  max-width: 620px;
  margin: 0 auto;
}

@media screen and (max-width: 749px) {
  .am-newsletter--circle {
    padding: 36px 20px 30px;
  }
}