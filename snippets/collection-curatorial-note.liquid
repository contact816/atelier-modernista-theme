{%- if note_text != blank -%}
{%- assign note_image = collection.metafields.custom.curatorial_note_image -%}
<div class="am-curatorial-split">
  {%- if note_image != blank -%}
    <div class="am-curatorial-split__image">
      <img src="{{ note_image | image_url: width: 800 }}" alt="Curatorial note" loading="lazy">
    </div>
  {%- endif -%}
  <div class="am-curatorial-split__content{% unless note_image != blank %} am-curatorial-split__content--full{% endunless %}">
    <p class="am-curatorial-split__eyebrow">A Curatorial Note</p>
    <blockquote class="am-curatorial-split__quote">
      <p>&#8220;{{ note_text }}&#8221;</p>
    </blockquote>
    <cite class="am-curatorial-split__cite">From the Journal · Atelier Modernista</cite>
  </div>
</div>
<style>
  .am-curatorial-split {
    grid-column: 1 / -1 !important;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
    margin: 3rem 0;
    background: #fdf6e3;
    border: 1px solid rgba(26,26,24,0.08);
  }
  .am-curatorial-split__image {
    overflow: hidden;
  }
  .am-curatorial-split__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .am-curatorial-split__content {
    padding: clamp(48px, 6vw, 80px) clamp(40px, 5vw, 72px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .am-curatorial-split__content--full {
    grid-column: 1 / -1;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .am-curatorial-split__eyebrow {
    font-family: 'Jost', sans-serif !important;
    font-size: 9px !important;
    font-weight: 500 !important;
    letter-spacing: 0.22em !important;
    text-transform: uppercase !important;
    color: #0047AB !important;
    margin: 0 0 24px !important;
  }
  .am-curatorial-split__quote {
    margin: 0 0 24px;
    padding: 0;
    border: none;
  }
  .am-curatorial-split__quote p {
    font-family: 'Cormorant Garamond', Georgia, serif !important;
    font-style: italic !important;
    font-size: clamp(22px, 2.8vw, 34px) !important;
    font-weight: 300 !important;
    line-height: 1.55 !important;
    color: #1a1a18 !important;
    margin: 0 !important;
    letter-spacing: -0.01em !important;
  }
  .am-curatorial-split__cite {
    font-family: 'Jost', sans-serif;
    font-style: normal;
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #9e9a90;
    display: block;
  }
  @media (max-width: 749px) {
    .am-curatorial-split {
      grid-template-columns: 1fr;
    }
    .am-curatorial-split__image {
      height: 280px;
    }
    .am-curatorial-split__content {
      padding: 40px 24px;
    }
  }
</style>
{%- endif -%}