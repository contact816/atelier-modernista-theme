{% assign current_collection = collection %}
{% if current_collection == blank %}
  {% assign current_collection = product.collections | first %}
{% endif %}

{% if current_collection and current_collection.products.size > 1 %}
  {% assign found_index = nil %}
  {% assign col_products = current_collection.products %}

  {% for col_product in col_products %}
    {% if col_product.id == product.id %}
      {% assign found_index = forloop.index0 %}
    {% endif %}
  {% endfor %}

  {% if found_index != nil %}
    {% assign total = col_products.size %}
    {% assign prev_index = found_index | minus: 1 %}
    {% assign next_index = found_index | plus: 1 %}

    {% if prev_index < 0 %}
      {% assign prev_index = total | minus: 1 %}
    {% endif %}
    {% if next_index >= total %}
      {% assign next_index = 0 %}
    {% endif %}

    {% assign next_product = col_products[next_index] %}
    {% assign prev_product = col_products[prev_index] %}

    <div class="next-prev-band">
      <p class="next-prev-label">{{ current_collection.title }}</p>
      <div class="next-prev-row">

        {% if prev_product and prev_product.id != product.id %}
          <a class="next-prev-card prev-card" href="{{ prev_product.url }}?collection={{ current_collection.handle }}">
            <div class="next-prev-chevron prev-chevron">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12.5 4L6.5 10L12.5 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="next-prev-image">
              {% if prev_product.featured_image %}
                <img
                  src="{{ prev_product.featured_image | image_url: width: 240 }}"
                  alt="{{ prev_product.featured_image.alt | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="next-prev-info prev-info">
              <span class="next-prev-direction">Previous</span>
              <span class="next-prev-title">{{ prev_product.title }}</span>
              <span class="next-prev-price">{{ prev_product.price | money }}</span>
            </div>
          </a>
        {% else %}
          <div class="next-prev-placeholder"></div>
        {% endif %}

        {% if next_product and next_product.id != product.id %}
          <a class="next-prev-card next-card" href="{{ next_product.url }}?collection={{ current_collection.handle }}">
            <div class="next-prev-info next-info">
              <span class="next-prev-direction">Next</span>
              <span class="next-prev-title">{{ next_product.title }}</span>
              <span class="next-prev-price">{{ next_product.price | money }}</span>
            </div>
            <div class="next-prev-image">
              {% if next_product.featured_image %}
                <img
                  src="{{ next_product.featured_image | image_url: width: 240 }}"
                  alt="{{ next_product.featured_image.alt | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <div class="next-prev-chevron next-chevron">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.5 4L13.5 10L7.5 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        {% else %}
          <div class="next-prev-placeholder"></div>
        {% endif %}

      </div>
    </div>
  {% endif %}
{% endif %}
<style>
  .next-prev-band {
    max-width: 1100px;
    margin: 64px auto 0;
    padding: 36px 0;
    border-top: 1px solid rgba(0, 71, 171, 0.18);
  }

  .next-prev-label {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(17,17,17,0.55);
    margin: 0 0 18px;
  }

  .next-prev-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .next-prev-card {
    display: grid;
    grid-template-columns: auto 80px 1fr;
    gap: 16px;
    align-items: center;
    text-decoration: none !important;
    color: #111111 !important;
    background: #fdf6e3;
    padding: 18px;
    border: 1px solid rgba(0, 71, 171, 0.18);
  }

  .next-card {
    grid-template-columns: 1fr 80px auto;
    text-align: right;
  }

  .next-prev-image img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    display: block;
  }

  .next-prev-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .next-prev-direction {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0047AB;
  }

  .next-prev-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    line-height: 1.1;
    color: #111111;
  }

  .next-prev-price {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    color: rgba(17,17,17,0.6);
  }

  .next-prev-chevron {
    color: #0047AB;
    display: flex;
  }

  @media screen and (max-width: 749px) {
    .next-prev-row {
      grid-template-columns: 1fr;
    }

    .next-prev-card,
    .next-card {
      grid-template-columns: auto 72px 1fr;
      text-align: left;
    }

    .next-card .next-prev-chevron {
      order: -1;
    }

    .next-prev-image img {
      width: 72px;
      height: 72px;
    }
  }
</style>