{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"padding_top":28,"padding_bottom":28}},"177462817241fe8f78":{"type":"_blocks","settings":{}},"1776202336a9220bf4":{"type":"_blocks","settings":{}},"custom_liquid_pNMYAC":{"type":"custom-liquid","disabled":true,"name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!--\n  PHILOSOPHY page — three image left column\n \n-->\n\n<style>\n  .am-nw3,\n  .am-nw3 *,\n  .am-nw3 p,\n  .am-nw3 h1,\n  .am-nw3 h2,\n  .am-nw3 h3,\n  .am-nw3 a,\n  .am-nw3 span,\n  .am-nw3 div {\n    box-sizing: border-box;\n    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif !important;\n  }\n\n  .am-nw3 {\n    max-width: 1600px;\n    margin: 0 auto;\n    padding: 28px 24px 64px;\n    color: #1a1a1a !important;\n    background: transparent;\n  }\n\n  .am-nw3__layout {\n    display: grid;\n    grid-template-columns: 220px 1fr;\n    gap: 36px;\n    align-items: start;\n  }\n\n  .am-nw3__images {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n    position: sticky;\n    top: 24px;\n  }\n\n  .am-nw3__img-item {\n    width: 100%;\n  }\n\n  .am-nw3__img-wrap {\n    width: 100%;\n    overflow: hidden;\n    border: 1px solid rgba(0,71,171,0.2);\n  }\n\n  .am-nw3__img-wrap img {\n    width: 100% !important;\n    height: auto !important;\n    display: block !important;\n  }\n\n  .am-nw3__img-caption {\n    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif !important;\n    font-size: 12px !important;\n    letter-spacing: 1.5px !important;\n    text-transform: uppercase !important;\n    color: rgba(0,71,171,0.55) !important;\n    margin: 5px 0 0 !important;\n    display: block !important;\n    text-align: center !important;\n    line-height: 1.5 !important;\n  }\n\n  .am-nw3__frame {\n    border: 3px solid rgba(0,71,171,0.75);\n    padding: 48px 56px 44px;\n    position: relative;\n  }\n\n  .am-nw3__frame::after {\n    content: '';\n    position: absolute;\n    top: 5px;\n    left: 5px;\n    right: 5px;\n    bottom: 5px;\n    border: 2px solid rgba(0,71,171,0.45);\n    pointer-events: none;\n  }\n\n  .am-nw3__heading {\n    font-size: 32px !important;\n    font-weight: 500 !important;\n    letter-spacing: 4px !important;\n    color: #0047AB !important;\n    margin: 0 0 6px !important;\n    display: block;\n    line-height: 1.4 !important;\n  }\n\n  .am-nw3__subheading {\n    font-size: 22px !important;\n    font-weight: 500 !important;\n    letter-spacing: 2px !important;\n    color: rgba(0,50,130,0.65) !important;\n    margin: 0 0 36px !important;\n    display: block;\n  }\n\n  .am-nw3__body p {\n    font-size: 16px !important;\n    line-height: 1.75 !important;\n    margin: 0 0 20px !important;\n    color: #1a1a1a !important;\n    font-weight: 400 !important;\n  }\n\n  .am-nw3__body a,\n  .am-nw3__body a:visited {\n    color: #0047AB !important;\n    text-decoration: underline !important;\n    text-underline-offset: 3px !important;\n  }\n\n  .am-nw3__divider {\n    border: none !important;\n    border-top: 0.5px solid rgba(0,71,171,0.15) !important;\n    margin: 28px 0 !important;\n    background: none !important;\n  }\n\n  .am-nw3__signoff {\n    margin-top: 32px !important;\n  }\n\n  .am-nw3__signoff-line {\n    font-size: 20px !important;\n    line-height: 1.75 !important;\n    color: #1a1a1a !important;\n    font-style: italic !important;\n    margin: 0 0 4px !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-name {\n    font-size: 18px !important;\n    color: #1a1a1a !important;\n    margin: 4px 0 2px !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-role {\n    font-size: 18px !important;\n    color: rgba(0,71,171,0.8) !important;\n    margin: 2px 0 !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-email {\n    font-size: 18px !important;\n    color: rgba(0,71,171,0.7) !important;\n    text-decoration: underline !important;\n    text-underline-offset: 3px !important;\n    margin: 2px 0 0 !important;\n    display: block;\n  }\n\n  @media (max-width: 768px) {\n    .am-nw3__layout {\n      grid-template-columns: 1fr;\n    }\n    .am-nw3__images {\n      flex-direction: row;\n      position: static;\n      gap: 12px;\n    }\n    .am-nw3__img-item {\n      flex: 1;\n    }\n    .am-nw3__frame {\n      padding: 28px 22px 32px !important;\n    }\n  }\n<\/style>\n\n<div class=\"am-nw3\">\n  <div class=\"am-nw3__layout\">\n\n    <!-- LEFT: three images -->\n<div class=\"am-nw3__images\">\n\n  <div class=\"am-nw3__img-item\">\n    <div class=\"am-nw3__img-wrap\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/500px-Marc_Chagall_9_9_17_-lacma_-theater__40584496951.jpg?v=1776450819\" alt=\"Marc Chagall, Fantasies for the Stage\" loading=\"lazy\">\n    <\/div>\n    <span class=\"am-nw3__img-caption\">Marc Chagall<br>Fantasies for the Stage<br>Photo: Sharon Mollerus \/ CC BY 2.0<\/span>\n  <\/div>\n\n  <div class=\"am-nw3__img-item\">\n    <div class=\"am-nw3__img-wrap\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/250px-Sophie_Taeuber-Arp__1889_1943__Composition__1931.png?v=1776855678loading=\"lazy\">\n    <\/div>\n    <span class=\"am-nw3__img-caption\">Sophie Taeuber-Arp, 'Composition' - 1931 <br\/>\nOil + distemper on canvas, Muzeum Sztuki, Łódź<\/span>\n  <\/div>\n\n  <div class=\"am-nw3__img-item\">\n    <div class=\"am-nw3__img-wrap\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/250px-Blaise_cendrars__fernad_leger__locandina_per_la_fin_du_monde__1919_1.jpg?v=1776452377\" loading=\"lazy\">\n    <\/div>\n    <span class=\"am-nw3__img-caption\">Fernand Léger<br>La Fin du Monde, 1919<br>Photo: Francesco Bini \/ CC BY-SA 4.0<\/span>\n  <\/div>\n\n<\/div>\n\n    <!-- RIGHT: bordered content -->\n    <div class=\"am-nw3__frame\">\n\n      <span class=\"am-nw3__heading\" style=\"text-align:center;display:block;\">Our Philosophy<\/span>\n      <span class=\"am-nw3__subheading\" style=\"text-align:center;display:block;\">Less, But Better<\/span>\n\n      <div class=\"am-philosophy\">\n  <div class=\"am-philosophy__inner\">\n\n    <p class=\"am-philosophy__lead\">Most jewellery is designed to match most things. It sits quietly, coordinates politely, then disappears. There is a whole industry built around this kind of discretion, and it produces beautiful, forgettable things in enormous quantities.<\/p>\n\n    <p class=\"am-philosophy__body\">Atelier Modernista was born from an opposite impulse: a love of jewellery that has genuine presence. The reference points here are not other jewellery brands - they are Sophie Taeuber-Arp's colour-richness and geometry, Chagall's flying lovers, Léger's vivid lettering, Le Brocquy's Táin illustrations, Jane South's geometric paper sculptures.<\/p>\n\n    <p class=\"am-philosophy__body\">Therefore we built Atelier Modernista on a few simple convictions: of buying less but buying better; that colour is everyone's friend; and that jewellery made by artists, chosen with rigour, is worth more than almost anything produced at scale.<\/p>\n\n    <blockquote class=\"am-philosophy__quote\">\n      \"Make the things we own more beautiful.\"\n      <cite>Sophie Taeuber-Arp<\/cite>\n    <\/blockquote>\n\n    <p class=\"am-philosophy__body\">This desire is embodied in every piece we offer you. Each piece has presence, and has earned its place. Our jewellery range is small and ever-rotating, meaning you can regularly find new ideas at play.<\/p>\n\n    <p class=\"am-philosophy__body\">Presence does not require noise to make it alive. Just a small dart of colour, a good-surprise texture, or a cobalt richness that makes you feel interesting things are ahead.<\/p>\n\n    <p class=\"am-philosophy__body\">Our Edits are always kept small. We would rather show you ten things we believe in completely than a hundred things we think you might like. The pieces we offer are chosen because they do something we think is special -  something that makes us feel more vivid when we wear them.<\/p>\n\n    <p class=\"am-philosophy__signoff\">Less, but better.<\/p>\n\n    <div class=\"am-philosophy__signature\">\n      <p>Warmest wishes,<\/p>\n      <p><strong>Antonia<\/strong><br>\n      Founder, Atelier Modernista<br>\n      <a href=\"mailto:antonia@ateliermodernista.com\">antonia@ateliermodernista.com<\/a><\/p>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<style>\n.am-philosophy {\n  max-width: 720px;\n  margin: 60px auto;\n  padding: 0 24px;\n}\n.am-philosophy__inner {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n.am-philosophy__lead {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 22px;\n  font-weight: 500;\n  line-height: 1.6;\n  color: #111111;\n  margin: 0;\n}\n.am-philosophy__body {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 18px;\n  font-weight: 400;\n  line-height: 1.75;\n  color: #111111;\n  opacity: 0.85;\n  margin: 0;\n}\n.am-philosophy__quote {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 24px;\n  font-weight: 400;\n  font-style: italic;\n  line-height: 1.5;\n  color: #0047AB;\n  border-left: 2px solid #0047AB;\n  margin: 16px 0;\n  padding: 12px 0 12px 28px;\n}\n.am-philosophy__quote cite {\n  display: block;\n  font-size: 13px;\n  font-style: normal;\n  font-weight: 500;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: #111111;\n  opacity: 0.6;\n  margin-top: 10px;\n}\n.am-philosophy__signoff {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 22px;\n  font-weight: 500;\n  font-style: italic;\n  color: #111111;\n  margin: 16px 0 0;\n}\n.am-philosophy__signature {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 16px;\n  line-height: 1.7;\n  color: #111111;\n  opacity: 0.8;\n  border-top: 0.5px solid #0047AB;\n  padding-top: 24px;\n  margin-top: 8px;\n}\n.am-philosophy__signature a {\n  color: #0047AB;\n  text-decoration: none;\n}\n.am-philosophy__signature a:hover {\n  text-decoration: underline;\n}\n@media (max-width: 768px) {\n  .am-philosophy {\n    margin: 40px auto;\n  }\n  .am-philosophy__lead {\n    font-size: 19px;\n  }\n  .am-philosophy__body {\n    font-size: 16px;\n  }\n  .am-philosophy__quote {\n    font-size: 20px;\n    padding-left: 20px;\n  }\n}\n<\/style>\n\n      <\/div>\n\n      <div class=\"am-nw3__signoff\">\n       With warmest wishes,<\/span>\n        <span class=\"am-nw3__signoff-name\">Antonia<\/span>\n        <span class=\"am-nw3__signoff-role\">Founder, Atelier Modernista<\/span>\n        <a class=\"am-nw3__signoff-email\" href=\"mailto:antonia@ateliermodernista.com\">antonia@ateliermodernista.com<\/a>\n      <\/div>\n\n      <!-- ATELIER CIRCLE -->\n      <div style=\"background:#0047AB;border-radius:2px;padding:26px 28px 28px;margin:32px 0 0;\">\n\n        <div style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:10px !important;font-weight:400 !important;letter-spacing:3px !important;text-transform:uppercase !important;color:rgba(253,246,227,0.6) !important;margin:0 0 8px !important;display:block !important;\">The Atelier Circle<\/div>\n\n        <div style=\"font-family:'Cormorant Garamond',Georgia,serif !important;font-size:22px !important;font-weight:400 !important;color:#fdf6e3 !important;margin:0 0 8px !important;line-height:1.4 !important;display:block !important;\">Stay in the edit.<\/div>\n\n        <div style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:13px !important;font-weight:400 !important;letter-spacing:0.3px !important;color:rgba(253,246,227,0.7) !important;margin:0 0 22px !important;line-height:1.7 !important;display:block !important;\">Join The Atelier Circle for exclusive early access to sales and new arrivals, and occasional Collector&rsquo;s Notes. Unsubscribe any time.<\/div>\n\n        <form id=\"am-circle-form\" style=\"display:flex;gap:0;max-width:480px;\">\n          <input\n            id=\"am-circle-email\"\n            type=\"email\"\n            name=\"contact[email]\"\n            placeholder=\"Your email address\"\n            required\n            autocomplete=\"email\"\n            style=\"flex:1;padding:12px 16px;font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:13px;letter-spacing:0.5px;color:#1a1a1a !important;background:#fdf6e3 !important;border:none !important;border-radius:2px 0 0 2px;outline:none;min-width:0;-webkit-appearance:none;\"\n          >\n          <button\n            type=\"submit\"\n            style=\"padding:12px 20px;font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:10px;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:#0047AB !important;background:#fdf6e3 !important;border:none;border-left:1px solid rgba(0,71,171,0.15);border-radius:0 2px 2px 0;cursor:pointer;white-space:nowrap;\"\n            onmouseover=\"this.style.background='#e8dfc8'\"\n            onmouseout=\"this.style.background='#fdf6e3'\"\n          >Join the Circle<\/button>\n        <\/form>\n\n        <div id=\"am-circle-success\" style=\"display:none;font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:11px !important;letter-spacing:1px !important;text-transform:uppercase !important;color:rgba(253,246,227,0.85) !important;margin-top:14px !important;\">&#10003; &nbsp;You&rsquo;re in. Welcome to the Circle.<\/div>\n\n        <div style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:10px !important;letter-spacing:0.3px !important;color:rgba(253,246,227,0.35) !important;margin:12px 0 0 !important;display:block !important;\">Your details are kept private.<\/div>\n\n      <\/div>\n\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\n(function() {\n  var form = document.getElementById('am-circle-form');\n  var success = document.getElementById('am-circle-success');\n  if (!form) return;\n  form.addEventListener('submit', function(e) {\n    e.preventDefault();\n    var email = document.getElementById('am-circle-email').value;\n    if (!email) return;\n    fetch('\/contact', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application\/x-www-form-urlencoded' },\n      body: 'form_type=customer&utf8=%E2%9C%93&contact%5Bemail%5D='\n        + encodeURIComponent(email)\n        + '&contact%5Btags%5D=newsletter%2CNW3CIRCLE'\n    }).then(function() {\n      form.style.display = 'none';\n      success.style.display = 'block';\n    }).catch(function() {\n      form.style.display = 'none';\n      success.style.display = 'block';\n    });\n  });\n})();\n<\/script>","color_scheme":"","padding_top":40,"padding_bottom":52}},"custom_liquid_CPeKki":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .am-philosophy-page,\n  .am-philosophy-page * {\n    box-sizing: border-box;\n  }\n\n  .am-philosophy-page {\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: 28px 24px 64px;\n    color: #1a1a1a;\n  }\n\n  .am-philosophy-layout {\n    display: grid;\n    grid-template-columns: 220px 1fr;\n    gap: 36px;\n    align-items: start;\n  }\n\n  .am-philosophy-images {\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n    position: sticky;\n    top: 24px;\n  }\n\n  .am-philosophy-image-wrap {\n    overflow: hidden;\n    border: 1px solid rgba(0,71,171,0.2);\n  }\n\n  .am-philosophy-image-wrap img {\n    width: 100%;\n    height: auto;\n    display: block;\n  }\n\n  .am-philosophy-caption {\n    font-family: 'Jost', Arial, sans-serif;\n    font-size: 10px;\n    letter-spacing: 1.4px;\n    text-transform: uppercase;\n    color: rgba(0,71,171,0.55);\n    margin-top: 6px;\n    text-align: center;\n    line-height: 1.5;\n  }\n\n  .am-philosophy-frame {\n    border: 3px solid rgba(0,71,171,0.75);\n    padding: 48px 56px 44px;\n    position: relative;\n  }\n\n  .am-philosophy-frame::after {\n    content: '';\n    position: absolute;\n    inset: 5px;\n    border: 2px solid rgba(0,71,171,0.45);\n    pointer-events: none;\n 