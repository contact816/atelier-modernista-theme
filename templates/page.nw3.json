{"sections":{"custom_liquid_ytntL3":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .am-nw3,\n  .am-nw3 *,\n  .am-nw3 p,\n  .am-nw3 h1,\n  .am-nw3 h2,\n  .am-nw3 h3,\n  .am-nw3 a,\n  .am-nw3 span,\n  .am-nw3 div {\n    box-sizing: border-box;\n    font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif !important;\n  }\n\n  .am-nw3 {\n    max-width: 780px;\n    margin: 0 auto;\n    padding: 28px 24px 64px;\n    color: #1a1a1a !important;\n    background: transparent;\n  }\n\n  .am-nw3__layout {\n    display: grid;\n    grid-template-columns: 1fr;\n    gap: 32px;\n    align-items: start;\n  }\n\n  .am-nw3__frame {\n    border: 3px solid rgba(0,71,171,0.75);\n    padding: 40px 48px 44px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .am-nw3__frame::after {\n    content: '';\n    position: absolute;\n    top: 5px;\n    left: 5px;\n    right: 5px;\n    bottom: 5px;\n    border: 2px solid rgba(0,71,171,0.45);\n    pointer-events: none;\n  }\n\n  .am-nw3__heading {\n    font-size: 40px !important;\n    font-weight: 400 !important;\n    letter-spacing: 4px !important;\n    color: #0047AB !important;\n    margin: 0 0 6px !important;\n    display: block;\n  }\n\n  .am-nw3__subheading {\n    font-size: 22px !important;\n    font-weight: 500 !important;\n    letter-spacing: 2px !important;\n    color: rgba(0,50,130,0.65) !important;\n    margin: 0 0 36px !important;\n    display: block;\n  }\n\n  .am-nw3__strip {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 12px;\n    margin: 0 0 36px;\n  }\n\n  .am-nw3__body p {\n    font-size: 18px !important;\n    line-height: 1.75 !important;\n    margin: 0 0 20px !important;\n    color: #1a1a1a !important;\n    font-weight: 500 !important;\n  }\n\n  .am-nw3__body a,\n  .am-nw3__body a:visited {\n    color: #0047AB !important;\n    text-decoration: underline !important;\n    text-underline-offset: 3px !important;\n  }\n\n  .am-nw3__offer {\n    background: rgba(0,71,171,0.08) !important;\n    border-left: 3px solid rgba(0,71,171,0.85) !important;\n    border-radius: 2px !important;\n    padding: 20px 22px 22px !important;\n    margin: 32px 0 !important;\n  }\n\n  .am-nw3__offer-label {\n    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif !important;\n    font-size: 10px !important;\n    font-weight: 400 !important;\n    letter-spacing: 1.5px !important;\n    text-transform: uppercase !important;\n    color: rgba(0,71,171,0.65) !important;\n    margin: 0 0 8px !important;\n    display: block;\n  }\n\n  .am-nw3__offer-code {\n    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif !important;\n    font-size: 17px !important;\n    font-weight: 400 !important;\n    letter-spacing: 4px !important;\n    color: #0047AB !important;\n    margin: 0 0 8px !important;\n    display: block !important;\n  }\n\n  .am-nw3__offer-detail {\n    font-family: 'Jost', 'Helvetica Neue', Arial, sans-serif !important;\n    font-size: 11px !important;\n    letter-spacing: 0.5px !important;\n    color: rgba(0,71,171,0.6) !important;\n    margin: 0 !important;\n    display: block;\n  }\n\n  .am-nw3__signoff {\n    margin-top: 32px !important;\n  }\n\n  .am-nw3__signoff-line {\n    font-size: 18px !important;\n    line-height: 1.75 !important;\n    color: #1a1a1a !important;\n    font-style: italic !important;\n    margin: 0 0 4px !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-name {\n    font-size: 18px !important;\n    color: #1a1a1a !important;\n    margin: 4px 0 2px !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-role {\n    font-size: 14px !important;\n    color: rgba(0,71,171,0.8) !important;\n    margin: 2px 0 !important;\n    display: block;\n  }\n\n  .am-nw3__signoff-email {\n    font-size: 14px !important;\n    color: rgba(0,71,171,0.7) !important;\n    text-decoration: underline !important;\n    text-underline-offset: 3px !important;\n    margin: 2px 0 0 !important;\n    display: block;\n  }\n\n  @media (max-width: 600px) {\n    .am-nw3 {\n      padding: 12px 8px 40px;\n      overflow: hidden;\n    }\n    .am-nw3__layout {\n      overflow: hidden;\n    }\n    .am-nw3__frame {\n      padding: 20px 12px 24px !important;\n      overflow: hidden;\n      word-wrap: break-word;\n      overflow-wrap: break-word;\n    }\n    .am-nw3__frame::after {\n      top: 3px;\n      left: 3px;\n      right: 3px;\n      bottom: 3px;\n    }\n    .am-nw3__heading {\n      font-size: 26px !important;\n      letter-spacing: 2px !important;\n    }\n    .am-nw3__subheading {\n      font-size: 13px !important;\n      letter-spacing: 1px !important;\n      margin: 0 0 18px !important;\n    }\n    .am-nw3__strip {\n      grid-template-columns: 1fr 1fr 1fr;\n      gap: 6px;\n      margin: 0 0 18px;\n    }\n    .am-nw3__body p {\n      font-size: 14px !important;\n      line-height: 1.6 !important;\n      margin: 0 0 12px !important;\n      overflow-wrap: break-word;\n    }\n    .am-nw3__offer {\n      padding: 12px 12px 14px !important;\n      margin: 18px 0 !important;\n    }\n    .am-nw3__offer-code {\n      font-size: 12px !important;\n      letter-spacing: 1.5px !important;\n    }\n    .am-nw3__signoff {\n      margin-top: 18px !important;\n    }\n    .am-nw3__signoff-line,\n    .am-nw3__signoff-name {\n      font-size: 14px !important;\n    }\n  }\n<\/style>\n\n<div class=\"am-nw3\">\n  <div class=\"am-nw3__layout\">\n\n    <!-- MAIN FRAME -->\n    <div class=\"am-nw3__frame\">\n\n      <span class=\"am-nw3__heading\" style=\"text-align:center;display:block;\">Atelier Modernista<\/span>\n      <span class=\"am-nw3__subheading\" style=\"text-align:center;display:block;\">Art Jewellery &middot; Hampstead &middot; London<\/span>\n\n      <!-- THREE IMAGE STRIP -->\n      <div class=\"am-nw3__strip\">\n\n        <div>\n          <a href=\"\/products\/coda-cobalt-necklace\" style=\"text-decoration:none;\">\n            <div style=\"overflow:hidden;border:1px solid rgba(0,71,171,0.2);\">\n              <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/BG_Better_Coda_Set_Image.jpg?v=1775145120\"\n                loading=\"lazy\" alt=\"Atelier Modernista - The Coda Set\"\n                style=\"width:100%;height:auto;display:block;\">\n            <\/div>\n            <span style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(0,71,171,0.55);margin:5px 0 0;display:block;text-align:center;line-height:1.5;\">Atelier Modernista<br>Cobalt Coda Set<\/span>\n          <\/a>\n        <\/div>\n\n        <div>\n          <div style=\"overflow:hidden;border:1px solid rgba(0,71,171,0.2);\">\n            <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/250px-Kenwood_House__July_2022_24.jpg?v=1776508192\"\n              loading=\"lazy\" alt=\"Cobalt Lantern, Kenwood House\"\n              style=\"width:100%;height:auto;display:block;\">\n          <\/div>\n          <span style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(0,71,171,0.55);margin:5px 0 0;display:block;text-align:center;line-height:1.5;\">Cobalt Lantern<br>Kenwood House<\/span>\n        <\/div>\n\n        <div>\n          <a href=\"\/products\/ruby-14k-gold-vermeil-earrings\" style=\"text-decoration:none;\">\n            <div style=\"overflow:hidden;border:1px solid rgba(0,71,171,0.2);\">\n              <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0974\/7480\/6097\/files\/BG_Pinkish_Ruby_Earrings_e724a61b-3f2e-4a3c-bcc4-f75102230acb.jpg?v=1775146677\"\n                loading=\"lazy\" alt=\"Vermeil Gold and Ruby Earrings\"\n                style=\"width:100%;height:auto;display:block;\">\n            <\/div>\n            <span style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(0,71,171,0.55);margin:5px 0 0;display:block;text-align:center;line-height:1.5;\">Atelier Modernista<br>Vermeil Gold &amp; Ruby Earrings<\/span>\n          <\/a>\n        <\/div>\n\n      <\/div><!-- \/.am-nw3__strip -->\n\n      <div class=\"am-nw3__body\">\n\n        <p>Atelier Modernista is a Hampstead-based independent curator of contemporary art jewellery. Every piece is chosen for its combination of tradition and innovation - you can find our full collection online <a href=\"\/collections\/all\">here<\/a>.<\/p>\n\n        <p>Like Hampstead, our range is both classical and contemporary, and unusual.<\/p>\n\n        <p>We are very fond of our Modernist Cobalt Edition, much as we are of a coffee at Mani's, and Everyman's sofas on a Sunday night. We offer the colour-rich Bauhaus Earrings with the same delight we feel about Leonard Cohen once living on the High Street - above what is now Petit Bateau - and that George Orwell once sold paperbacks from South End Green Gail's.<\/p>\n\n        <p>We celebrate the innovation of 2 Willow Road, Spedan Close and the Hopkins&rsquo; House with our Architect Earrings. <\/p>\n\n        <p>We love Hampstead because we love when innovation combines with tradition to make something magnificent. Such as creating the Camden Art Centre from the old library; or Michael Rosen and Natasha Brown&rsquo;s Book Labs at Burgh House; or an exquisite puppet theatre from a disused pottery. The best of Hampstead seems to happen when we mix tradition with innovation. And this mix is at the heart of what we are doing at Atelier Modernista.<\/p>\n\n        <p>Therefore we built Atelier Modernista on a few simple convictions: of buying less but buying better; that colour is everyone&rsquo;s friend; and that jewellery made by artists, chosen with rigour, is worth more than almost anything produced at scale. Each piece has presence, and has earned its place. Our jewellery range is small and ever-rotating, meaning you can regularly find new ideas at play.<\/p>\n\n      <\/div>\n\n      <!-- OFFER BLOCK -->\n    \n<a href=\"\/collections\/the-atelier-collection\" style=\"text-decoration:none;display:block;\">\n  <div class=\"am-nw3__offer\">\n    <span class=\"am-nw3__offer-label\">A Hampstead Welcome<\/span>\n    <span class=\"am-nw3__offer-code\">NW3CIRCLE — 15% off your initial order<\/span>\n    <span class=\"am-nw3__offer-detail\">No minimum spend &nbsp;&middot;&nbsp; Applied at checkout<\/span>\n      <\/div>\n\n      <div class=\"am-nw3__body\">\n        <p>As a Hampstead local, we invite you to explore the full edit with a special 15% off your initial order, using the code NW3CIRCLE. There is no minimum spend.<\/p>\n\n        <p>We hope you enjoy our selection, and you&rsquo;re very welcome to stay in touch through our Atelier Circle, to avail of advance offers and exclusive access.<\/p>\n\n        <p>You may spot me in my red Arc Earrings or beloved Ruby Necklace around the village. Do stop and say hi if you do - it&rsquo;d be really lovely to meet you.<\/p>\n      <\/div>\n\n      <!-- SIGN OFF -->\n      <div class=\"am-nw3__signoff\">\n        <span class=\"am-nw3__signoff-line\">Warmest wishes,<\/span>\n        <span class=\"am-nw3__signoff-name\">Antonia<\/span>\n        <span class=\"am-nw3__signoff-role\">Founder, Atelier Modernista<\/span>\n        <a class=\"am-nw3__signoff-email\" href=\"mailto:antonia@ateliermodernista.com\">antonia@ateliermodernista.com<\/a>\n      <\/div>\n\n      <!-- ATELIER CIRCLE SIGNUP -->\n      <div style=\"background:#0047AB;border-radius:2px;padding:26px 28px 28px;margin:32px 0 0;\">\n\n        <div style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:10px !important;font-weight:400 !important;letter-spacing:3px !important;text-transform:uppercase !important;color:rgba(253,246,227,0.6) !important;margin:0 0 8px !important;display:block !important;\">The Atelier Circle<\/div>\n\n        <div style=\"font-family:'Cormorant Garamond',Georgia,serif !important;font-size:22px !important;font-weight:400 !important;color:#fdf6e3 !important;margin:0 0 8px !important;line-height:1.4 !important;display:block !important;\">Stay in the edit.<\/div>\n\n        <div style=\"font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:13px !important;font-weight:400 !important;letter-spacing:0.3px !important;color:rgba(253,246,227,0.7) !important;margin:0 0 22px !important;line-height:1.7 !important;display:block !important;\">Join The Atelier Circle for exclusive early access to sales and new arrivals, and occasional Collector&rsquo;s Notes. Unsubscribe any time.<\/div>\n\n        <form id=\"am-circle-form\" style=\"display:flex;gap:0;max-width:480px;\">\n          <input\n            id=\"am-circle-email\"\n            type=\"email\"\n            name=\"contact[email]\"\n            placeholder=\"Your email address\"\n            required\n            autocomplete=\"email\"\n            style=\"flex:1;padding:12px 16px;font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:13px;letter-spacing:0.5px;color:#1a1a1a !important;background:#fdf6e3 !important;border:none !important;border-radius:2px 0 0 2px;outline:none;min-width:0;-webkit-appearance:none;\"\n          >\n          <button\n            type=\"submit\"\n            style=\"padding:12px 20px;font-family:'Jost','Helvetica Neue',Arial,sans-serif;font-size:10px;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:#0047AB !important;background:#fdf6e3 !important;border:none;border-left:1px solid rgba(0,71,171,0.15);border-radius:0 2px 2px 0;cursor:pointer;white-space:nowrap;\"\n            onmouseover=\"this.style.background='#e8dfc8'\"\n            onmouseout=\"this.style.background='#fdf6e3'\"\n          >Join the Circle<\/button>\n        <\/form>\n\n        <div id=\"am-circle-success\" style=\"display:none;font-family:'Jost','Helvetica Neue',Arial,sans-serif !important;font-size:11px !important;letter-spacing:1px !important;text-transform:uppercase !important;color:rgba(253,246,227,0.85) !important;margin-top:14px !important;\">&#10003; &nbsp;You&rsquo;re in. Welcome to the Circle.<\/div>\n\n        <div style=\"margin-top:12px;display:flex;align-items:flex-start;gap:10px;font-family:'Jost',sans-serif;font-size:13px;color:rgba(253,246,227,0.6);\">\n          <input type=\"checkbox\" id=\"am-gdpr\" required style=\"margin-top:2px;accent-color:rgba(253,246,227,0.6);flex-shrink:0;\">\n          <label for=\"am-gdpr\">I agree to receive emails from Atelier Modernista. You can unsubscribe at any time. <a href=\"\/policies\/privacy-policy\" style=\"color:rgba(253,246,227,0.6);\">Privacy Policy<\/a>.<\/label>\n        <\/div>\n\n      <\/div>\n\n    <\/div><!-- \/.am-nw3__frame -->\n  <\/div><!-- \/.am-nw3__layout -->\n<\/div>\n\n<script>\n(function() {\n  var form = document.getElementById('am-circle-form');\n  var success = document.getElementById('am-circle-success');\n  if (!form) return;\n  form.addEventListener('submit', function(e) {\n    e.preventDefault();\n    var email = document.getElementById('am-circle-email').value;\n    if (!email) return;\n    fetch('\/contact', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application\/x-www-form-urlencoded' },\n      body: 'form_type=customer&utf8=%E2%9C%93&contact%5Bemail%5D='\n        + encodeURIComponent(email)\n        + '&contact%5Btags%5D=newsletter%2CNW3CIRCLE'\n    }).then(function() {\n      form.style.display = 'none';\n      success.style.display = 'block';\n    }).catch(function() {\n      form.style.display = 'none';\n      success.style.display = 'block';\n    });\n  });\n})();\n<\/script>","color_scheme":"","padding_top":40,"padding_bottom":52}},"main":{"type":"main-page","disabled":true,"settings":{"padding_top":28,"padding_bottom":28}}},"order":["custom_liquid_ytntL3","main"]}