        "custom_liquid_hRWYcw": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<aside class=\"am-circle-invite\" aria-labelledby=\"am-circle-heading\">\n\n  {% if customer and customer.accepts_marketing %}\n\n    <p class=\"am-circle-invite__eyebrow\">\n      The Atelier Circle\n    </p>\n\n    <h2 id=\"am-circle-heading\" class=\"am-circle-invite__heading\">\n      Welcome back{% if customer.first_name != blank %}, {{ customer.first_name | escape }}{% endif %}.\n    </h2>\n\n    <p class=\"am-circle-invite__subheading\">\n      Your Free UK Delivery is active.\n    </p>\n\n    <div class=\"am-circle-member-message\">\n      <span class=\"am-circle-member-message__dot\" aria-hidden=\"true\"></span>\n\n      <p>\n        Free UK delivery is included when you use\n        <strong>{{ customer.email | escape }}</strong>\n        at checkout.\n      </p>\n    </div>\n\n  {% else %}\n\n    <p class=\"am-circle-invite__eyebrow\">\n     The Atelier Circle\n    </p>\n\n    <h2 id=\"am-circle-heading\" class=\"am-circle-invite__heading\"      Join The Atelier Circle \n    </h2>\n\n    <p class=\"am-circle-invite__subheading\">\n      Membership is free.\n    </p>\n\n    <div class=\"am-circle-benefits\">\n      <span><i aria-hidden=\"true\"></i>Free UK delivery</span>\n      <span><i aria-hidden=\"true\"></i>Early access to new collections and offers</span>\n      <span><i aria-hidden=\"true\"></i>Notes from the Atelier</span>\n    </div>\n\n    {% form 'customer', class: 'am-circle-form' %}\n\n      <input\n        type=\"hidden\"\n        name=\"contact[tags]\"\n        value=\"newsletter,Atelier Circle\"\n      >\n\n      <label\n        class=\"visually-hidden\"\n        for=\"AmCircleEmail-{{ section.id }}\"\n      >\n        Email address\n      </label>\n\n      <div class=\"am-circle-form__row\">\n\n        <input\n          id=\"AmCircleEmail-{{ section.id }}\"\n          class=\"am-circle-form__input\"\n          type=\"email\"\n          name=\"contact[email]\"\n          value=\"{% if customer %}{{ customer.email | escape }}{% endif %}\"\n          autocomplete=\"email\"\n          autocorrect=\"off\"\n          autocapitalize=\"off\"\n          placeholder=\"Your email address\"\n          required\n        >\n\n        <button\n          class=\"am-circle-form__button\"\n          type=\"submit\"\n        >\n          <span class=\"am-circle-form__title\">\n           Join the Atelier Circle\n            <span aria-hidden=\"true\">→</span>\n          </span>\n\n          <span class=\"am-circle-form__subtitle\">Free UK delivery included\n            \n          </span>\n        </button>\n\n      </div>\n\n      {% if form.posted_successfully? %}\n        <p class=\"am-circle-form__message\" role=\"status\">\n          You're in! Welcome to the Atelier Circle. Your Free UK Delivery is now active.\n        </p>\n      {% endif %}\n\n      {% if form.errors %}\n        <div\n          class=\"am-circle-form__message am-circle-form__message--error\"\n          role=\"alert\"\n        >\n          {{ form.errors | default_errors }}\n        </div>\n      {% endif %}\n\n      <p class=\"am-circle-form__privacy\">\n        By joining, you agree to receive Atelier Modernista emails.\n        You may unsubscribe at any time.\n      </p>\n\n    {% endform %}\n\n  {% endif %}\n\n</aside>"
          }
        },
