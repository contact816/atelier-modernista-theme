        "collapsible_tab_heD9EU": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care",
            "icon": "none",
            "content": "<p>An Atelier Modernista polishing cloth is enclosed with your purchase to help maintain your AM jewellery. Each piece is delicately crafted, so please limit exposure to water, fragrance, cosmetics, and chemicals. Remove before showers, swimming, or exercise. </p>",
